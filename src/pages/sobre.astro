---
import { Image } from 'astro:assets'
import Layout from '../layouts/Layout.astro'
import Header from '../components/layout/Header.astro'
import Footer from '../components/layout/Footer.astro'
import Container from '../components/ui/Container.astro'
import Breadcrumbs from '../components/seo/Breadcrumbs.astro'
import JornadaTimeline from '../components/sections/JornadaTimeline.astro'
import LicoesDosPps from '../components/sections/LicoesDosPps.astro'
import VerdadesDuras from '../components/sections/VerdadesDuras.astro'
import joelBurigoImage from '../assets/images/joel-burigo-vendas-sem-segredos-2-1200w.webp'

const seo = {
  title: 'Sobre | Joel Burigo',
  description: 'De barraco em 2012 a 140+ clientes. Da quebrada ao bilhão. Manifesto + história + Framework 6Ps.',
  keywords: 'Joel Burigo, história, Framework 6Ps, vendas escaláveis, consultor vendas',
}

// 6Ps (ordem fixa)
const ps6 = [
  { n: 'P1', nome: 'POSICIONAMENTO' },
  { n: 'P2', nome: 'PÚBLICO' },
  { n: 'P3', nome: 'PRODUTO' },
  { n: 'P4', nome: 'PROGRAMAS' },
  { n: 'P5', nome: 'PROCESSOS' },
  { n: 'P6', nome: 'PESSOAS' },
]

// 7 inimigos da Máquina (fonte: 01-marca §01.9)
const inimigos = [
  { n: '01', titulo: 'IMPROVISO', descricao: 'Vendas aleatórias, sem processo, dependendo de sorte ou da agenda do dia.' },
  { n: '02', titulo: 'FÓRMULA MÁGICA', descricao: 'Promessa de atalho. "Passo a passo fácil". Não há fórmula. Há método.' },
  { n: '03', titulo: 'MARKETING SEM VENDAS', descricao: 'Post bonito no Instagram não paga boleto. Marketing sem vendas é hobby caro.' },
  { n: '04', titulo: 'DEPENDÊNCIA DO FUNDADOR', descricao: 'Se tua empresa depende de tu, tu não tem empresa — tu tem emprego.' },
  { n: '05', titulo: 'CRM VAZIO', descricao: 'Ferramenta no lugar errado, processo no lugar nenhum. Leads entram e somem.' },
  { n: '06', titulo: 'TÁTICA SEM SISTEMA', descricao: 'Anúncio sem funil, funil sem script, script sem follow-up. Peça solta não escala.' },
  { n: '07', titulo: 'MOTIVACIONAL VAZIO', descricao: '"Você consegue!". Fica o discurso, some a execução. Sem sistema, motivação é placebo.' },
]

// 6 valores da personalidade (derivados de 01-marca)
const personalidade = [
  { carac: 'DIRETO', significa: 'Fala a verdade sem enrolação.', exemplo: 'Não há fórmula mágica. Há método.' },
  { carac: 'PARCEIRO', significa: 'Implementa junto, não ensina de cima pra baixo.', exemplo: 'Vem comigo. Mostro exatamente como faço.' },
  { carac: 'INTENSO', significa: 'Energia alta, comprometido com resultado real.', exemplo: 'Quando eu entro, eu entro pra valer.' },
  { carac: 'TRANSPARENTE', significa: 'Conta fracassos, não só vitórias.', exemplo: 'Quebrei aos 25. Morei em barraco. Sei como é.' },
  { carac: 'SISTEMÁTICO', significa: 'Foco em sistema replicável, não tática isolada.', exemplo: 'Sistema > Improviso. Base de tudo.' },
  { carac: 'ACESSÍVEL', significa: 'Metodologia profissional ao alcance de MPE.', exemplo: 'Ferramentas e método ao alcance de quem vem de baixo.' },
]

// Stats canônicos (ANTI_DRIFT §4.1)
const stats = [
  { num: '17+', label: 'Anos' },
  { num: '140+', label: 'Clientes' },
  { num: '~R$1BI', label: 'Estruturado' },
  { num: '20+', label: 'Nichos' },
]

// Cicatrizes (fonte bio)
const cicatrizes = [
  'Quebrou empresa aos 25 anos em março/2012 (calote de sócio)',
  'Morou 6 meses em barraco de R$ 300 sem geladeira em Ribeirão das Neves/MG',
  'Trabalhou nos Correios por R$ 1.400/mês enquanto reconstruía',
  'Bateu em 100+ portas com um milheiro de cartões de visita em BH',
  'Atendeu 140+ clientes ao longo de 17+ anos — sabe o que funciona e o que não funciona',
  'Reconstruiu 2×: quebra em 2012 e perda de ~R$ 250k em 2019 (Growth Master/OnSell)',
]
---

<Layout title={seo.title} description={seo.description} keywords={seo.keywords}>
  <Header />

  <section class="bg-ink pt-20 pb-6">
    <Container>
      <Breadcrumbs items={[{ label: 'Home', href: '/' }, { label: 'Sobre', href: '/sobre' }]} />
    </Container>
  </section>

  <main class="relative overflow-hidden bg-ink">
    <div class="grid-overlay"></div>

    <Container class="relative z-10">
      <!-- Hero -->
      <section class="py-16 md:py-24">
        <div class="grid gap-12 lg:grid-cols-[1.4fr_1fr] lg:items-center">
          <div>
            <div class="kicker mb-6">// JOEL_BURIGO · 1987-PRESENTE · RIBEIRÃO_DA_ILHA/SC</div>
            <h1 class="sobre-display">
              <span class="block">Da quebrada</span>
              <span class="block"><span class="stroke-text">ao</span> <span class="text-acid">bilhão.</span></span>
            </h1>
            <p class="mt-8 max-w-xl font-sans text-lg text-[color:var(--jb-cream)] leading-relaxed">
              Março/2012. Barraco de R$ 300 em Ribeirão das Neves/MG. Sem geladeira. Cama em tijolos.
            </p>
            <p class="mt-4 max-w-xl font-sans text-[color:var(--jb-fg-2)] leading-relaxed">
              25 anos, calote do próprio sócio, primeira empresa quebrada. Nos Correios por R$ 1.400/mês colocando encomenda na esteira. Seis meses ali. Juntei cada centavo, comprei um milheiro de cartão de visita e bati em 100+ portas subindo a Afonso Pena em BH.
            </p>
            <p class="mt-4 max-w-xl font-sans text-[color:var(--jb-fg-2)] leading-relaxed">
              Hoje, 17+ anos depois, cicatriz virou metodologia testada em <strong class="text-[color:var(--jb-cream)]">140+ empresas</strong> e <strong class="text-[color:var(--jb-cream)]">~R$ 1 bilhão</strong> em vendas estruturadas.
            </p>
            <p class="mt-4 max-w-xl font-mono text-[13px] uppercase tracking-[0.22em] text-[color:var(--jb-fg-3)]">
              <span class="text-acid">●</span>&nbsp; NASCIDO 1987 · PALHOÇA/SC · JARDIM_ELDORADO
            </p>
          </div>

          <!-- Foto -->
          <aside>
            <div class="border border-[color:var(--jb-acid-border)] bg-[color:var(--jb-ink-2)] overflow-hidden">
              <Image
                src={joelBurigoImage}
                alt="Joel Burigo — especialista em Vendas Escaláveis"
                loading="lazy"
                class="w-full h-auto grayscale contrast-110"
              />
              <div class="p-5 border-t border-[color:var(--jb-hair)]">
                <div class="kicker mb-2" style="color: var(--jb-acid);">// JOEL_BURIGO</div>
                <p class="font-display text-lg text-[color:var(--jb-cream)]">
                  Vendas Escaláveis · Framework 6Ps
                </p>
              </div>
            </div>
          </aside>
        </div>

        <!-- Stats -->
        <div class="mt-16 grid grid-cols-2 gap-px border border-[color:var(--jb-hair)] bg-[color:var(--jb-hair)] md:grid-cols-4">
          {stats.map((s) => (
            <div class="bg-[color:var(--jb-ink)] p-6">
              <div class="font-display text-3xl md:text-4xl text-acid">{s.num}</div>
              <div class="font-mono text-[11px] uppercase tracking-[0.22em] text-[color:var(--jb-fg-muted)]">{s.label}</div>
            </div>
          ))}
        </div>
      </section>

      <!-- Manifesto -->
      <section class="pb-16">
        <div class="border border-[color:var(--jb-fire-border)] bg-[color:var(--jb-ink-2)] p-8 md:p-12">
          <div class="kicker mb-6" style="color: var(--jb-fire);">// MANIFESTO · DA_QUEBRADA_AO_BILHÃO</div>
          <div class="space-y-6 font-sans text-lg text-[color:var(--jb-cream)] leading-relaxed">
            <p>
              Eu acredito em <strong>sistema &gt; improviso</strong>.
            </p>
            <p>
              Acredito que <em>marketing sem vendas é hobby caro</em> — e que <em>post bonito no Instagram não paga boleto</em>.
            </p>
            <p>
              Acredito que <strong>improviso mata mais empresa que crise</strong> e que quem constrói sistema replicável vence no longo prazo.
            </p>
            <p>
              Acredito que metodologia profissional deveria estar ao alcance de quem vem de baixo — não trancada em consultoria de R$ 50-100k.
            </p>
            <p class="font-display text-2xl md:text-3xl text-acid">
              "SE TUA EMPRESA DEPENDE DE TU, TU NÃO TEM EMPRESA — TU TEM EMPREGO."
            </p>
          </div>
        </div>
      </section>
    </Container>

    <!-- Jornada Timeline (componente migrado) -->
    <JornadaTimeline />

    <Container class="relative z-10">
      <!-- Cicatrizes -->
      <section class="py-16">
        <div class="mx-auto max-w-5xl">
          <div class="kicker mb-6">// CICATRIZES · QUE_VIRARAM_SABEDORIA</div>
          <h2 class="heading-2 mb-10 text-[color:var(--jb-cream)]">
            Cada falha ensinou algo que nenhum MBA ensina.
          </h2>
          <ul class="space-y-0 border border-[color:var(--jb-hair)] bg-[color:var(--jb-ink-2)]">
            {cicatrizes.map((c, i) => (
              <li class={`flex items-start gap-5 p-6 ${i > 0 ? 'border-t border-[color:var(--jb-hair)]' : ''}`}>
                <div class="font-mono text-sm font-bold text-acid shrink-0" style="letter-spacing: 0.1em;">{String(i + 1).padStart(2, '0')}</div>
                <p class="font-sans text-[color:var(--jb-fg-2)]">{c}</p>
              </li>
            ))}
          </ul>

          <!-- Insight -->
          <div class="mt-10 border-l-2 border-fire bg-[color:var(--jb-ink-2)] p-6 md:p-8">
            <div class="kicker mb-3" style="color: var(--jb-fire);">// INSIGHT · O_PADRÃO_DEPOIS_DE_17_ANOS</div>
            <p class="font-display text-2xl text-[color:var(--jb-cream)] mb-4">
              "IMPROVISO MATA MAIS EMPRESA QUE CRISE."
            </p>
            <p class="font-sans text-[color:var(--jb-fg-2)] leading-relaxed">
              A maioria das MPEs brasileiras não quebra por falta de mercado. Quebra por falta de sistema replicável. Marketing sozinho não converte — leads chegam mas não viram venda porque falta CRM, processo, follow-up, proposta padronizada.
            </p>
            <p class="mt-3 font-sans text-[color:var(--jb-fg-2)]">
              Foi isso que fez nascer os <strong class="text-[color:var(--jb-cream)]">6Ps das Vendas Escaláveis</strong> — metodologia que integra Marketing + Vendas + Operação num sistema único. Cada P nasceu de erro ou acerto real.
            </p>
          </div>
        </div>
      </section>

      <!-- 6Ps -->
      <section class="pb-16">
        <div class="mx-auto max-w-6xl">
          <div class="kicker mb-6">// FRAMEWORK · 6PS_DAS_VENDAS_ESCALÁVEIS</div>
          <h2 class="heading-2 mb-10 text-[color:var(--jb-cream)]">
            Os 6Ps são sequenciais. Pular etapa é garantia de falha.
          </h2>
          <div class="grid gap-px border border-[color:var(--jb-hair)] bg-[color:var(--jb-hair)] grid-cols-2 md:grid-cols-3 lg:grid-cols-6">
            {ps6.map((p) => (
              <div class="bg-[color:var(--jb-ink-2)] p-5">
                <div class="font-display text-2xl text-acid">{p.n}</div>
                <div class="mt-2 font-mono text-[11px] uppercase tracking-[0.22em] text-[color:var(--jb-cream)]">{p.nome}</div>
              </div>
            ))}
          </div>
          <p class="mt-4 font-mono text-[11px] uppercase tracking-[0.22em] text-[color:var(--jb-fg-muted)]">
            <span class="text-acid">●</span>&nbsp; POSICIONAMENTO → PÚBLICO → PRODUTO → PROGRAMAS → PROCESSOS → PESSOAS
          </p>
        </div>
      </section>
    </Container>

    <!-- Lições dos 6Ps (componente migrado) -->
    <LicoesDosPps />

    <!-- 7 Verdades (componente migrado — mapeia os inimigos) -->
    <VerdadesDuras />

    <Container class="relative z-10">
      <!-- Os 7 Inimigos (data local, mais direto) -->
      <section class="py-16">
        <div class="mx-auto max-w-5xl">
          <div class="kicker mb-6">// OS_7_INIMIGOS · DA_MÁQUINA_DE_CRESCIMENTO</div>
          <h2 class="heading-2 mb-10 text-[color:var(--jb-cream)]">
            O que impede MPE de escalar.
          </h2>
          <div class="grid gap-0 border border-[color:var(--jb-hair)] bg-[color:var(--jb-ink-2)] md:grid-cols-2">
            {inimigos.map((i, idx) => (
              <article class={`p-6 ${idx % 2 === 0 && idx < inimigos.length - 1 ? 'md:border-r md:border-[color:var(--jb-hair)]' : ''} ${idx >= 2 ? 'border-t border-[color:var(--jb-hair)]' : ''} ${idx === 1 ? 'border-t md:border-t-0 border-[color:var(--jb-hair)]' : ''}`}>
                <div class="flex items-baseline gap-3 mb-2">
                  <span class="font-mono text-sm font-bold text-fire" style="letter-spacing: 0.1em;">#{i.n}</span>
                  <h3 class="heading-4 text-[color:var(--jb-cream)]">{i.titulo}</h3>
                </div>
                <p class="font-sans text-sm text-[color:var(--jb-fg-2)] leading-relaxed">{i.descricao}</p>
              </article>
            ))}
          </div>
        </div>
      </section>

      <!-- Personalidade -->
      <section class="pb-16">
        <div class="mx-auto max-w-6xl">
          <div class="kicker mb-6">// COMO_EU_TRABALHO · 6_CARACTERÍSTICAS</div>
          <h2 class="heading-2 mb-10 text-[color:var(--jb-cream)]">
            Como eu trabalho.
          </h2>
          <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
            {personalidade.map((item) => (
              <div class="card">
                <div class="kicker mb-3" style="color: var(--jb-acid);">// {item.carac}</div>
                <p class="font-sans text-[color:var(--jb-cream)] mb-3 font-bold">{item.significa}</p>
                <p class="font-mono text-sm text-[color:var(--jb-fg-2)] border-l-2 border-[color:var(--jb-hair-strong)] pl-3">
                  "{item.exemplo}"
                </p>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- 2 Caminhos -->
      <section class="pb-16">
        <div class="mx-auto max-w-6xl">
          <div class="kicker mb-6">// 2_CAMINHOS · PRA_TRABALHAR_COMIGO</div>
          <h2 class="heading-2 mb-10 text-[color:var(--jb-cream)]">
            Dois caminhos. Escolhe o que faz sentido pro teu momento.
          </h2>

          <div class="grid gap-6 md:grid-cols-2">
            <!-- VSS -->
            <article class="border border-[color:var(--jb-acid-border)] bg-[color:var(--jb-ink-2)] p-8" style="background: linear-gradient(180deg, rgba(198,255,0,0.06), var(--jb-ink-2));">
              <div class="kicker mb-3" style="color: var(--jb-acid);">// DIY · PERPÉTUO · PRINCIPAL</div>
              <h3 class="heading-2 mb-2 text-[color:var(--jb-cream)]">VENDAS SEM SEGREDOS</h3>
              <div class="font-display text-3xl text-acid mb-6">R$ 1.997</div>
              <ul class="space-y-2 font-sans text-sm text-[color:var(--jb-fg-2)]">
                <li><span class="text-acid">▶</span> Pra MPE faturando R$ 10-100k/mês</li>
                <li><span class="text-acid">▶</span> 90 dias guiados + acesso vitalício</li>
                <li><span class="text-acid">▶</span> 15 módulos, 66 aulas práticas</li>
                <li><span class="text-acid">▶</span> Growth CRM incluso (12 meses)</li>
                <li><span class="text-acid">▶</span> 48 mentorias ao vivo semanais</li>
                <li><span class="text-acid">▶</span> Garantia 15 dias incondicional</li>
              </ul>
              <a href="/vendas-sem-segredos" class="btn-primary mt-8 min-h-[44px]" data-astro-prefetch>
                <span>Conhecer VSS</span>
                <span aria-hidden="true">→</span>
              </a>
            </article>

            <!-- Advisory -->
            <article class="border border-[color:var(--jb-fire-border)] bg-[color:var(--jb-ink-2)] p-8">
              <div class="kicker mb-3" style="color: var(--jb-fire);">// 1:1 · EXCLUSIVO · CONVITE</div>
              <h3 class="heading-2 mb-2 text-[color:var(--jb-cream)]">ADVISORY</h3>
              <div class="font-display text-3xl text-fire mb-6">R$ 997-15.000/mês</div>
              <ul class="space-y-2 font-sans text-sm text-[color:var(--jb-fg-2)]">
                <li><span class="text-fire">●</span> Pra empresas R$ 200k+/mês</li>
                <li><span class="text-fire">●</span> Sessão (R$ 997 · 90 min)</li>
                <li><span class="text-fire">●</span> Sprint 30 dias (R$ 7.500)</li>
                <li><span class="text-fire">●</span> Conselho Executivo (R$ 15.000/mês)</li>
                <li><span class="text-fire">●</span> Vagas extremamente limitadas</li>
                <li><span class="text-fire">●</span> Acesso direto comigo</li>
              </ul>
              <a href="/advisory" class="btn-fire mt-8 min-h-[44px]" data-astro-prefetch>
                <span>Aplicar pra Advisory</span>
                <span aria-hidden="true">→</span>
              </a>
            </article>
          </div>
        </div>
      </section>

      <!-- CTA Final -->
      <section class="pb-16 md:pb-24">
        <div class="mx-auto max-w-5xl">
          <div class="border border-[color:var(--jb-hair)] bg-[color:var(--jb-ink-2)] p-8 md:p-12">
            <div class="kicker mb-4">// LEGADO · DA_QUEBRADA_AO_LEGADO</div>
            <h2 class="heading-1 mb-6 text-[color:var(--jb-cream)]">
              Meu filho Davi (10/10/2024) nunca vai saber o que é barraco sem geladeira.
            </h2>
            <p class="font-sans text-lg text-[color:var(--jb-fg-2)] leading-relaxed mb-6">
              Mas vai saber o que é dignidade do trabalho. Vai saber que sistema supera improviso. Vai saber que da quebrada pro bilhão tem um caminho — e esse caminho tem nome: <strong class="text-acid">metodologia</strong>.
            </p>
            <p class="font-sans text-[color:var(--jb-fg-2)] leading-relaxed">
              Meu legado é simples: ajudar empreendedor brasileiro — especialmente quem vem de baixo — a estruturar vendas sem precisar passar pelo sofrimento que eu passei.
            </p>

            <div class="mt-10 flex flex-wrap gap-4">
              <a href="/vendas-sem-segredos" class="btn-primary min-h-[48px]" data-astro-prefetch>
                <span>Conhecer VSS</span>
                <span aria-hidden="true">→</span>
              </a>
              <a href="/diagnostico" class="btn-secondary min-h-[48px]">Diagnóstico grátis</a>
            </div>

            <div class="mt-10 border-t border-[color:var(--jb-hair)] pt-6">
              <div class="font-display text-lg text-[color:var(--jb-cream)]">JOEL BURIGO</div>
              <div class="mt-1 font-mono text-[11px] uppercase tracking-[0.22em] text-[color:var(--jb-fg-muted)]">
                ESPECIALISTA EM VENDAS ESCALÁVEIS · CRIADOR DOS 6PS · RIBEIRÃO DA ILHA/SC
              </div>
              <div class="mt-4 font-mono text-[11px] uppercase tracking-[0.28em] text-[color:var(--jb-fg-muted)]">
                <span class="text-acid">★</span>&nbsp;&nbsp;SISTEMA <span class="text-fire">&gt;</span> IMPROVISO · BORA PRA CIMA · LET'S GROW
              </div>
            </div>
          </div>
        </div>
      </section>
    </Container>
  </main>

  <Footer />
</Layout>

<style>
  .sobre-display {
    font-family: var(--font-display);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: -0.045em;
    line-height: 0.92;
    font-size: clamp(2.75rem, 9vw, 6rem);
    color: var(--jb-cream);
    margin: 0;
  }
</style>
