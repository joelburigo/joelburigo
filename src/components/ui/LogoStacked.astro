---
interface Props {
  class?: string
  size?: 'sm' | 'md' | 'lg' | 'xl'
  variant?: 'fire' | 'acid'
}

const { class: className = '', size = 'md', variant = 'fire' } = Astro.props

const sizeClasses = {
  sm: 'w-20 h-20',
  md: 'w-28 h-28',
  lg: 'w-36 h-36',
  xl: 'w-48 h-48',
}

const textSizeClasses = {
  sm: 'text-xs',
  md: 'text-sm',
  lg: 'text-base',
  xl: 'text-xl',
}

const borderColor = variant === 'fire' ? 'var(--jb-fire)' : 'var(--jb-acid)'
---

<div
  class={`relative inline-flex items-center justify-center ${sizeClasses[size]} ${className}`}
  style={`background: var(--jb-ink-2); border: 1px solid ${borderColor}; box-shadow: 4px 4px 0 ${borderColor};`}
>
  <div class="relative z-10 flex flex-col items-center justify-center leading-[0.92]">
    <span class={`font-display text-[color:var(--jb-cream)] ${textSizeClasses[size]} tracking-[-0.04em]`}>
      JOEL
    </span>
    <span class={`font-display ${textSizeClasses[size]} tracking-[-0.04em]`} style={`color: ${borderColor};`}>
      BURIGO
    </span>
  </div>
</div>
