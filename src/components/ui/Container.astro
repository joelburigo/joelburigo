---
interface Props {
  class?: string
  width?: 'default' | 'narrow' | 'wide'
}

const { class: className, width = 'default' } = Astro.props

const widths = {
  narrow: 'max-w-5xl',          // 1024px — artigos, forms
  default: 'max-w-[1360px]',    // 1360px — Terminal Growth canonical
  wide: 'max-w-[1440px]',       // 1440px — hero bleed
}
---

<div class:list={['mx-auto w-full px-6 sm:px-8 lg:px-10', widths[width], className]}>
  <slot />
</div>
