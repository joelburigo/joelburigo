---
import Container from '../ui/Container.astro'

const pathways = [
  {
    tag: 'PRODUTO PRINCIPAL',
    title: 'VSS — Vendas Sem Segredos',
    subtitle: 'Quer implementar com método próprio?',
    description:
      'DIY perpétuo. Você recebe o Framework 6Ps completo, 15 módulos, 48 mentorias ao vivo com Joel no ano e Growth CRM incluso. Implementa com autonomia em 90 dias guiados.',
    price: '12× R$ 166,42',
    priceNote: 'ou R$ 1.997 à vista · acesso vitalício',
    bullets: [
      '15 módulos implementáveis (90 dias)',
      '48 mentorias ao vivo com Joel · 1/semana',
      'Growth CRM incluído (12 meses)',
      'Comunidade exclusiva',
    ],
    link: '/vendas-sem-segredos',
    cta: 'Ver VSS completo',
    ideal: 'MPE R$ 10–100k/mês · hands-on',
    feat: true,
  },
  {
    tag: 'EXCLUSIVO · POR CONVITE',
    title: 'Advisory — Acesso direto ao Joel',
    subtitle: 'Quer minha mente no seu negócio?',
    description:
      'Premium 1:1. Três formatos: Sessão avulsa, Sprint 30 dias ou Conselho Executivo. Acesso WhatsApp prioritário. Não faço por você — decido com você.',
    price: 'R$ 997–15.000/mês',
    priceNote: 'sessão, sprint ou conselho · avaliação prévia',
    bullets: [
      'Sessão Estratégica · R$ 997 · 90 min',
      'Sprint 30 dias · R$ 7.500 · 4 sessões',
      'Conselho Executivo · R$ 12.500–15k/mês',
      'Garantia: 1ª sessão ou reembolso',
    ],
    link: '/advisory',
    cta: 'Solicitar Advisory',
    ideal: 'R$ 200k+/mês · momento crítico',
    feat: false,
  },
]
---

<section class="pathways-section section bg-ink relative overflow-hidden">
  <div class="grid-overlay"></div>

  <Container class="relative z-10">
    <!-- Section head -->
    <div class="section-head">
      <div class="kicker">// 04_CAMINHOS</div>
      <div class="mono section-head-meta">2 FORMAS DE TRABALHAR COMIGO</div>
    </div>
    <div class="hair-divider"></div>

    <!-- Intro -->
    <div class="pw-intro">
      <h2 class="pw-title">
        DOIS <span class="stroke-text">CAMINHOS</span>.<br />
        <span class="text-acid">ZERO</span> MEIO-TERMO.
      </h2>
      <p class="pw-lede">
        Ou você pega o método e implementa com apoio em grupo (VSS). Ou você quer acesso direto pra decidir junto comigo (Advisory). Não existe terceirização — eu não faço POR você.
      </p>
    </div>

    <!-- Grid 2 caminhos -->
    <div class="pw-grid">
      {pathways.map((p) => (
        <article class={p.feat ? 'card-feat pw-card pw-card-feat' : 'card pw-card'}>
          {p.feat && <div class="pw-ribbon">★ PRINCIPAL</div>}

          <div class="pw-tag mono">{p.tag}</div>
          <h3 class="pw-card-title">{p.title}</h3>
          <p class="pw-subtitle">{p.subtitle}</p>
          <p class="pw-desc">{p.description}</p>

          <ul class="pw-bullets">
            {p.bullets.map((b) => (
              <li class="pw-bullet">
                <span class="pw-check" aria-hidden="true">▶</span>
                <span>{b}</span>
              </li>
            ))}
          </ul>

          <div class="pw-price-wrap">
            <div class={p.feat ? 'pw-price text-acid' : 'pw-price text-cream'}>{p.price}</div>
            <div class="pw-price-note mono">{p.priceNote}</div>
          </div>

          <a href={p.link} class={p.feat ? 'btn-primary pw-cta' : 'btn-secondary pw-cta'}>
            <span>{p.cta}</span>
            <span aria-hidden="true">→</span>
          </a>

          <div class="pw-ideal mono">Pra quem: <span class="text-cream">{p.ideal}</span></div>
        </article>
      ))}
    </div>
  </Container>
</section>

<style>
  .section-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    margin-bottom: 1rem;
    flex-wrap: wrap;
  }
  .section-head-meta { font-size: 11px; color: var(--jb-fg-muted); }

  .pw-intro {
    padding-top: clamp(2rem, 4vw, 3rem);
    padding-bottom: clamp(2rem, 4vw, 3rem);
    max-width: 960px;
  }
  .pw-title {
    font-family: var(--font-display);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: -0.04em;
    line-height: 0.92;
    font-size: clamp(2.25rem, 6vw, 4rem);
    color: var(--jb-cream);
    margin: 0 0 1.5rem 0;
  }
  .pw-lede {
    font-family: var(--font-sans);
    font-size: clamp(1rem, 1.5vw, 1.125rem);
    line-height: 1.6;
    color: var(--jb-cream);
    text-transform: none;
    margin: 0;
    max-width: 60ch;
  }

  .pw-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
  @media (min-width: 900px) { .pw-grid { grid-template-columns: 1fr 1fr; } }

  .pw-card {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: clamp(1.5rem, 3vw, 2.5rem);
    position: relative;
  }
  .pw-card-feat { position: relative; }
  .pw-ribbon {
    position: absolute;
    top: 0;
    right: 0;
    background: var(--jb-acid);
    color: var(--jb-ink);
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 11px;
    letter-spacing: 0.18em;
    padding: 6px 14px;
  }

  .pw-tag {
    font-size: 11px;
    color: var(--jb-acid);
    letter-spacing: 0.24em;
    margin-bottom: 0.25rem;
  }
  .pw-card-feat .pw-tag { color: var(--jb-acid); }

  .pw-card-title {
    font-family: var(--font-display);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: -0.03em;
    font-size: clamp(1.5rem, 3vw, 2.125rem);
    line-height: 1.05;
    color: var(--jb-cream);
    margin: 0;
  }

  .pw-subtitle {
    font-family: var(--font-display);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: -0.02em;
    font-size: 1rem;
    color: var(--jb-fire);
    margin: 0;
  }
  .pw-card-feat .pw-subtitle { color: var(--jb-acid); }

  .pw-desc {
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    line-height: 1.55;
    color: var(--jb-fg-2);
    margin: 0;
    text-transform: none;
  }

  .pw-bullets {
    list-style: none;
    padding: 0;
    margin: 0.5rem 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    border-top: 1px solid var(--jb-hair);
    border-bottom: 1px solid var(--jb-hair);
    padding-top: 1rem;
    padding-bottom: 1rem;
  }
  .pw-bullet {
    display: flex;
    gap: 0.75rem;
    align-items: flex-start;
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    color: var(--jb-cream);
    text-transform: none;
    line-height: 1.45;
  }
  .pw-check { color: var(--jb-acid); font-size: 12px; margin-top: 2px; flex-shrink: 0; }

  .pw-price-wrap { display: flex; flex-direction: column; gap: 0.25rem; padding-top: 0.5rem; }
  .pw-price {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    letter-spacing: -0.03em;
    line-height: 1;
  }
  .pw-price-note { font-size: 11px; color: var(--jb-fg-muted); letter-spacing: 0.16em; }

  .pw-cta { align-self: flex-start; margin-top: 0.5rem; }
  .pw-ideal {
    font-size: 11px;
    color: var(--jb-fg-muted);
    letter-spacing: 0.18em;
    padding-top: 0.5rem;
  }
  .pw-ideal .text-cream { letter-spacing: 0.1em; }
</style>
