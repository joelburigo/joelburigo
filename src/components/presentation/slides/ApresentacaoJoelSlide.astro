---
// Slide 0 · CAPA — Apresentação Joel
import SlideShell from '../SlideShell.astro'
---

<SlideShell
  variant="default"
  sbLeft="APRESENTAÇÃO · VENDAS ESCALÁVEIS"
  sbRight="// @joelburigo · EST. 2008 · FLORIANÓPOLIS/SC"
  navLeft="JOEL BURIGO · CRIADOR DO FRAMEWORK 6PS"
  navRight="01 / 19 · → PRÓXIMO"
>
  <div class="capa-wrap">
    <div class="capa-eyebrow">// FRAMEWORK 6PS · SESSÃO INTRODUTÓRIA</div>
    <h1 class="capa-h1">
      <span class="stroke-text">SISTEMA</span>
      <span class="fire">&gt;</span><br />
      <span class="acid">IMPROVISO</span>
    </h1>
    <p class="capa-sub">
      17+ anos estruturando vendas pra micro e pequena empresa.<br />
      <b>140+ clientes · ~R$ 1 bilhão</b> em vendas estruturadas.
    </p>
    <div class="capa-sign">★ SISTEMA &gt; IMPROVISO · BORA PRA CIMA</div>
  </div>
</SlideShell>

<style>
  .capa-wrap {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    height: 100%;
    text-align: center;
    padding: 0 40px;
  }
  .capa-eyebrow {
    font-family: var(--font-mono);
    font-size: clamp(12px, 1vw, 18px);
    letter-spacing: 0.32em;
    color: var(--jb-acid);
    text-transform: uppercase;
    margin-bottom: clamp(20px, 4vh, 48px);
  }
  .capa-h1 {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(68px, 12vw, 210px);
    line-height: 0.88;
    letter-spacing: -0.055em;
    text-transform: uppercase;
    color: var(--jb-cream);
  }
  .capa-h1 .fire { color: var(--jb-fire); }
  .capa-h1 .acid { color: var(--jb-acid); }
  .capa-sub {
    margin-top: clamp(24px, 5vh, 48px);
    font-size: clamp(15px, 1.5vw, 26px);
    line-height: 1.5;
    color: var(--jb-fg-3);
    max-width: 900px;
  }
  .capa-sub b { color: var(--jb-cream); }
  .capa-sign {
    margin-top: clamp(24px, 4vh, 40px);
    font-family: var(--font-mono);
    font-size: clamp(11px, 0.9vw, 13px);
    letter-spacing: 0.28em;
    color: var(--jb-fg-muted);
    text-transform: uppercase;
  }
</style>
