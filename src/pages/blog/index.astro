---
import { Image } from 'astro:assets'
import { getCollection } from 'astro:content'
import Layout from '../../layouts/Layout.astro'
import Header from '../../components/layout/Header.astro'
import Footer from '../../components/layout/Footer.astro'
import Container from '../../components/ui/Container.astro'
import SearchBar from '../../components/ui/SearchBar.astro'
import Icons from '../../components/ui/Icons.astro'
import Breadcrumbs from '../../components/seo/Breadcrumbs.astro'


const seo = {
  title: 'Blog | Vendas Escaláveis | Joel Burigo',
  description:
    'Artigos práticos sobre vendas, marketing e crescimento para MPEs.',
  keywords: 'blog vendas, vendas B2B, CRM, funis de vendas, estratégia comercial, Joel Burigo',
}

// Buscar todos os posts ordenados por data
const allPosts = await getCollection('blog')
const sortedPosts = allPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime())

// Post em destaque (mais recente com featured: true, ou o primeiro)
const featuredPost = sortedPosts.find((p) => p.data.featured) || sortedPosts[0]

// Posts regulares (excluindo o featured)
const posts = featuredPost ? sortedPosts.filter((p) => p.id !== featuredPost.id) : sortedPosts

// Contagem por categoria
const categoryCounts = allPosts.reduce((acc, post) => {
  acc[post.data.category] = (acc[post.data.category] || 0) + 1
  return acc
}, {} as Record<string, number>)

const categories = [
  { name: 'Todos', count: allPosts.length },
  { name: 'Framework 6Ps', count: categoryCounts['Framework 6Ps'] || 0 },
  { name: 'Vendas Escaláveis', count: categoryCounts['Vendas Escaláveis'] || 0 },
  { name: 'CRM e Tecnologia', count: categoryCounts['CRM e Tecnologia'] || 0 },
  { name: 'Processos', count: categoryCounts['Processos'] || 0 },
  { name: 'Casos de Sucesso', count: categoryCounts['Casos de Sucesso'] || 0 },
  { name: 'Mentalidade', count: categoryCounts['Mentalidade'] || 0 },
]
---

<Layout title={seo.title} description={seo.description} keywords={seo.keywords}>
  <Header />

  <main class="grow">
    <!-- Hero Section -->
    <section class="relative overflow-hidden bg-ink pt-12 pb-24 md:pt-16 md:pb-32">
      <div class="grid-overlay"></div>

      <Container class="relative z-10">
        <div class="mx-auto max-w-3xl">
          <Breadcrumbs items={[{ label: 'Home', href: '/' }, { label: 'Blog', href: '/blog' }]} class="mb-6" />
          <div class="kicker mb-6">// ARQUIVO · VENDAS ESCALÁVEIS</div>

          <h1 class="blog-hero-title">
            CONTEÚDO SOBRE<br />
            <span class="stroke-text">VENDAS</span> ESCALÁVEIS.
          </h1>

          <p class="blog-hero-lede">
            Estratégia, processo e cicatriz real. Sistema &gt; Improviso — aqui é onde você aprende a ligar a máquina.
          </p>

          <!-- Search Bar -->
          <div class="mt-8 max-w-2xl">
            <SearchBar placeholder="Buscar artigos sobre vendas, CRM, processos..." />
          </div>
        </div>
      </Container>
    </section>

    <!-- Featured Post -->
    {featuredPost && (
      <section class="bg-ink py-12 md:py-16">
        <Container>
          <div class="section-head mb-4">
            <div class="kicker">// EM DESTAQUE</div>
            <div class="mono section-head-meta">LEITURA RECOMENDADA</div>
          </div>
          <div class="hair-divider mb-8"></div>

          <a
            href={`/blog/${featuredPost.id.replace(/\.md$/, '')}`}
            class="featured-card group block"
          >
            <div class="grid grid-cols-1 gap-8 p-6 md:p-8 lg:grid-cols-2 lg:items-center">
              <div class="aspect-video overflow-hidden bg-ink lg:order-2">
                {featuredPost.data.heroImage ? (
                  <Image
                    src={featuredPost.data.heroImage}
                    alt={featuredPost.data.title}
                    loading="eager"
                    class="featured-img h-full w-full object-cover"
                  />
                ) : (
                  <div class="flex h-full items-center justify-center border border-[color:var(--jb-hair)]">
                    <Icons name="trending-up" class="h-16 w-16 text-acid/40" />
                  </div>
                )}
              </div>

              <div class="lg:order-1">
                <div class="kicker mb-4">// POST · {featuredPost.data.date.toLocaleDateString('pt-BR').replace(/\//g, '.')} · {featuredPost.data.category}</div>

                <h2 class="featured-title">
                  {featuredPost.data.title}
                </h2>

                <p class="featured-excerpt">
                  {featuredPost.data.excerpt}
                </p>

                <div class="featured-meta mono">
                  <span class="inline-flex items-center gap-2">
                    <Icons name="clock" class="h-3 w-3" />
                    <span>{featuredPost.data.readTime}</span>
                  </span>
                  <span aria-hidden="true">·</span>
                  <span class="featured-read">
                    Ler artigo <span aria-hidden="true">→</span>
                  </span>
                </div>
              </div>
            </div>
          </a>
        </Container>
      </section>
    )}

    <!-- Categories -->
    <section class="bg-ink py-8">
      <Container>
        <div class="section-head mb-4">
          <div class="kicker">// FILTRAR</div>
          <div class="mono section-head-meta">CATEGORIAS</div>
        </div>
        <div class="hair-divider mb-6"></div>

        <div class="flex flex-wrap gap-2">
          {categories.map((cat) => (
            <button
              data-category={cat.name}
              class="category-btn"
            >
              <span class="cat-name">{cat.name}</span>
              <span class="cat-count">({cat.count})</span>
            </button>
          ))}
        </div>
      </Container>
    </section>

    <!-- Posts Grid -->
    <section class="bg-ink py-12 md:py-16">
      <Container>
        <div class="section-head mb-4">
          <div class="kicker">// TODOS OS POSTS</div>
          <div class="mono section-head-meta">{posts.length} ARTIGOS · ARQUIVO COMPLETO</div>
        </div>
        <div class="hair-divider mb-8"></div>

        <div class="grid grid-cols-1 gap-4 md:grid-cols-2 lg:grid-cols-3 md:gap-5">
          {posts.map((post, index) => (
            <a
              href={`/blog/${post.id.replace(/\.md$/, '')}`}
              data-category={post.data.category}
              class="post-card group"
              style={`animation-delay: ${index * 0.06}s`}
            >
              {/* Image */}
              <div class="post-thumb">
                {post.data.heroImage ? (
                  <Image
                    src={post.data.heroImage}
                    alt={post.data.title}
                    loading="lazy"
                    class="post-thumb-img"
                  />
                ) : (
                  <div class="flex h-full items-center justify-center">
                    <Icons name="trending-up" class="h-12 w-12 text-acid/40" />
                  </div>
                )}
                <div class="post-category mono">// {post.data.category}</div>
              </div>

              {/* Content */}
              <div class="post-body">
                <time datetime={post.data.date.toISOString()} class="post-date mono">
                  {post.data.date.toLocaleDateString('pt-BR').replace(/\//g, '.')}
                  <span class="mx-1" aria-hidden="true">·</span>
                  {post.data.readTime}
                </time>

                <h3 class="post-title">
                  {post.data.title}
                </h3>

                <p class="post-excerpt">
                  {post.data.excerpt}
                </p>

                <div class="post-read">
                  <span>Ler artigo</span>
                  <span aria-hidden="true">→</span>
                </div>
              </div>
            </a>
          ))}
        </div>

        {/* Load More */}
        <div class="mt-12 text-center">
          <button
            id="load-more-btn"
            class="btn-secondary"
          >
            <span>Carregar mais artigos</span>
            <span aria-hidden="true">→</span>
          </button>
        </div>
      </Container>
    </section>

    <!-- Newsletter CTA -->
    <section class="relative overflow-hidden bg-ink py-20 md:py-24">
      <div class="grid-overlay"></div>

      <Container class="relative z-10">
        <div class="newsletter-card">
          <div class="kicker mb-4">// NEWSLETTER · SEM SPAM</div>

          <h2 class="newsletter-title">
            RECEBA CONTEÚDO<br />
            <span class="text-fire">EXCLUSIVO.</span>
          </h2>

          <p class="newsletter-lede">
            Estratégias de vendas direto no seu email. Zero filler, zero post bonito — só o que funciona na operação real.
          </p>

          <form class="newsletter-form">
            <input
              type="email"
              placeholder="seu@email.com"
              class="newsletter-input"
            />
            <button class="btn-primary">
              <span>Assinar</span>
              <span aria-hidden="true">→</span>
            </button>
          </form>
        </div>
      </Container>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  /* Hero */
  .blog-hero-title {
    font-family: var(--font-display);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: -0.045em;
    line-height: 0.92;
    font-size: clamp(2.25rem, 7vw, 5rem);
    color: var(--jb-cream);
    margin: 0 0 1.5rem 0;
  }
  .blog-hero-lede {
    font-family: var(--font-sans);
    font-size: clamp(1rem, 1.5vw, 1.125rem);
    line-height: 1.6;
    color: var(--jb-cream);
    text-transform: none;
    margin: 0;
    max-width: 60ch;
  }

  /* Section head helpers (reuse pattern from BlogPostsSection) */
  .section-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .section-head-meta { font-size: 11px; color: var(--jb-fg-muted); }
  .hair-divider { border-top: 1px solid var(--jb-hair); }

  /* Featured card */
  .featured-card {
    background: linear-gradient(180deg, rgba(198, 255, 0, 0.06), var(--jb-ink-2));
    border: 1px solid var(--jb-acid-border);
    border-radius: 0;
    text-decoration: none;
    color: inherit;
    transition: all var(--transition-base);
    display: block;
  }
  .featured-card:hover {
    border-color: var(--jb-acid);
    transform: translate(-2px, -2px);
    box-shadow: 6px 6px 0 var(--jb-acid);
  }
  :global(.featured-img) {
    transition: transform var(--transition-slow);
    filter: grayscale(40%) contrast(1.05);
  }
  .featured-card:hover :global(.featured-img) { transform: scale(1.03); filter: grayscale(0%); }

  .featured-title {
    font-family: var(--font-display);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: -0.03em;
    line-height: 1.0;
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    color: var(--jb-cream);
    margin: 0 0 1rem 0;
    transition: color var(--transition-base);
  }
  .featured-card:hover .featured-title { color: var(--jb-acid); }

  .featured-excerpt {
    font-family: var(--font-sans);
    font-size: 1.0625rem;
    line-height: 1.6;
    color: var(--jb-cream);
    text-transform: none;
    margin: 0 0 1.25rem 0;
    max-width: 52ch;
  }

  .featured-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.22em;
    color: var(--jb-fg-muted);
    text-transform: uppercase;
    flex-wrap: wrap;
  }
  .featured-read {
    color: var(--jb-acid);
    font-weight: 700;
  }

  /* Category buttons */
  .category-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: transparent;
    color: var(--jb-fg-2);
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    padding: 0.75rem 1rem;
    border: 1px solid var(--jb-hair);
    border-radius: 0;
    cursor: pointer;
    transition: all var(--transition-base);
    min-height: 44px;
  }
  .category-btn:hover {
    border-color: var(--jb-acid);
    color: var(--jb-acid);
  }
  .category-btn.active {
    background: var(--jb-acid);
    border-color: var(--jb-acid);
    color: var(--jb-ink);
  }
  .category-btn.active .cat-count { color: var(--jb-ink); opacity: 0.7; }
  .cat-count { color: var(--jb-fg-muted); }

  /* Post card (mirror BlogPostsSection) */
  .post-card {
    display: flex;
    flex-direction: column;
    background: var(--jb-ink-2);
    border: 1px solid var(--jb-hair);
    border-radius: 0;
    text-decoration: none;
    color: inherit;
    transition: all var(--transition-base);
    position: relative;
    animation: fadeInUp 0.5s ease-out backwards;
  }
  .post-card:hover {
    border-color: var(--jb-fire);
    transform: translate(-2px, -2px);
    box-shadow: 4px 4px 0 var(--jb-fire);
  }
  .post-card:hover .post-title { color: var(--jb-acid); }
  .post-card:hover :global(.post-thumb-img) { transform: scale(1.04); filter: grayscale(0%); }

  .post-card.hidden {
    display: none;
  }

  .post-thumb {
    position: relative;
    aspect-ratio: 16 / 10;
    overflow: hidden;
    background: var(--jb-ink);
    border-bottom: 1px solid var(--jb-hair);
  }
  :global(.post-thumb-img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(60%) contrast(1.05);
    transition: transform var(--transition-slow), filter var(--transition-slow);
  }

  .post-category {
    position: absolute;
    top: 0.75rem;
    left: 0.75rem;
    background: var(--jb-ink);
    color: var(--jb-acid);
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.22em;
    padding: 4px 8px;
    border: 1px solid var(--jb-acid-border);
    text-transform: uppercase;
  }

  .post-body {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    flex: 1;
  }

  .post-date {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--jb-fg-muted);
    letter-spacing: 0.22em;
    text-transform: uppercase;
  }

  .post-title {
    font-family: var(--font-display);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: -0.02em;
    font-size: 1.125rem;
    line-height: 1.15;
    color: var(--jb-cream);
    margin: 0;
    transition: color var(--transition-base);
  }

  .post-excerpt {
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    line-height: 1.5;
    color: var(--jb-fg-2);
    margin: 0;
    text-transform: none;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .post-read {
    margin-top: auto;
    padding-top: 0.5rem;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 0.75rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--jb-acid);
  }

  /* Newsletter card */
  .newsletter-card {
    max-width: 720px;
    margin: 0 auto;
    padding: clamp(2rem, 5vw, 3.5rem);
    background: var(--jb-ink-2);
    border: 1px solid var(--jb-hair-strong);
    text-align: left;
  }
  .newsletter-title {
    font-family: var(--font-display);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: -0.04em;
    line-height: 0.92;
    font-size: clamp(2rem, 5vw, 3.5rem);
    color: var(--jb-cream);
    margin: 0 0 1.25rem 0;
  }
  .newsletter-lede {
    font-family: var(--font-sans);
    font-size: 1.0625rem;
    line-height: 1.55;
    color: var(--jb-cream);
    text-transform: none;
    margin: 0 0 2rem 0;
    max-width: 52ch;
  }
  .newsletter-form {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  @media (min-width: 640px) {
    .newsletter-form { flex-direction: row; }
  }
  .newsletter-input {
    flex: 1;
    background: var(--jb-ink);
    border: 1px solid var(--jb-hair);
    color: var(--jb-cream);
    font-family: var(--font-mono);
    font-size: 14px;
    letter-spacing: 0.04em;
    padding: 0.875rem 1rem;
    border-radius: 0;
    min-height: 44px;
    transition: border-color var(--transition-base);
  }
  .newsletter-input::placeholder { color: var(--jb-fg-muted); }
  .newsletter-input:focus {
    outline: none;
    border-color: var(--jb-acid);
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(16px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>

<script>
  function initBlog() {
    const categoryButtons = document.querySelectorAll('.category-btn') as NodeListOf<HTMLButtonElement>
    const postCards = document.querySelectorAll('.post-card') as NodeListOf<HTMLElement>
    const loadMoreBtn = document.getElementById('load-more-btn') as HTMLButtonElement

    let postsPerPage = 6
    let currentlyVisible = postsPerPage

    // Marcar "Todos" como ativo inicialmente
    const todosBtn = Array.from(categoryButtons).find(btn => btn.getAttribute('data-category') === 'Todos')
    if (todosBtn) {
      todosBtn.classList.add('active')
    }

    // Função para mostrar/ocultar posts com base na categoria e limite
    function filterAndShowPosts(category: string | null) {
      let visibleCount = 0

      postCards.forEach((card) => {
        const postCategory = card.getAttribute('data-category')
        const matchesCategory = !category || category === 'Todos' || postCategory === category

        if (matchesCategory && visibleCount < currentlyVisible) {
          card.classList.remove('hidden')
          visibleCount++
        } else if (!matchesCategory) {
          card.classList.add('hidden')
        } else {
          card.classList.add('hidden')
        }
      })

      // Mostrar/ocultar botão "Carregar Mais"
      const totalMatchingPosts = Array.from(postCards).filter(card => {
        const postCategory = card.getAttribute('data-category')
        return !category || category === 'Todos' || postCategory === category
      }).length

      if (loadMoreBtn) {
        loadMoreBtn.style.display = visibleCount >= totalMatchingPosts ? 'none' : 'inline-flex'
      }
    }

    // Filtro de categorias
    categoryButtons.forEach(button => {
      button.addEventListener('click', () => {
        const selectedCategory = button.getAttribute('data-category')

        // Atualizar botão ativo
        categoryButtons.forEach(btn => btn.classList.remove('active'))
        button.classList.add('active')

        // Resetar contador ao mudar categoria
        currentlyVisible = postsPerPage
        filterAndShowPosts(selectedCategory)
      })
    })

    // Botão "Carregar Mais"
    if (loadMoreBtn) {
      loadMoreBtn.addEventListener('click', () => {
        currentlyVisible += postsPerPage
        const activeBtn = Array.from(categoryButtons).find(btn => btn.classList.contains('active'))
        const selectedCategory = activeBtn?.getAttribute('data-category') || null
        filterAndShowPosts(selectedCategory)
      })
    }

    // Inicializar mostrando apenas os primeiros posts
    filterAndShowPosts('Todos')
  }

  // Inicializar
  initBlog()

  // Reinicializar após navegação
  document.addEventListener('astro:page-load', initBlog)
</script>
