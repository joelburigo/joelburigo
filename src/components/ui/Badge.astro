---
interface Props {
  variant?: 'primary' | 'fire' | 'outline' | 'mute' | 'live'
  class?: string
}

const { variant = 'primary', class: className = '' } = Astro.props

// Terminal Growth badges — mono uppercase tracking wide.
const variants = {
  primary: 'bg-[color:var(--jb-acid-soft)] text-[color:var(--jb-acid)] border border-[color:var(--jb-acid-border)]',
  fire: 'bg-[color:var(--jb-fire-soft)] text-[color:var(--jb-fire)] border border-[color:var(--jb-fire-border)]',
  outline: 'border border-[color:var(--jb-hair-strong)] text-[color:var(--jb-cream)]',
  mute: 'text-[color:var(--jb-fg-muted)] border border-[color:var(--jb-hair)]',
  live: 'bg-[color:var(--jb-acid-soft)] text-[color:var(--jb-acid)] border border-[color:var(--jb-acid-border)]',
}
---

<span class={`inline-flex items-center gap-2 px-3 py-1.5 rounded-none font-mono text-[11px] uppercase tracking-[0.22em] font-bold ${variants[variant]} ${className}`}>
  {variant === 'live' && <span class="dot-live"></span>}
  <slot />
</span>
