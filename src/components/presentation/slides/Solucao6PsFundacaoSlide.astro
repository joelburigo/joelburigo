---
// Slide 4 · 6Ps FUNDAÇÃO (P1-P3): Posicionamento, Público, Produto
import SlideShell from '../SlideShell.astro'

const ps = [
  {
    n: 'P1',
    t: 'POSICIONAMENTO',
    q: 'POR QUÊ?',
    d: 'Por que você existe. Clareza de autoridade e diferenciação. Sem isso você vira commodity e briga por preço.',
  },
  {
    n: 'P2',
    t: 'PÚBLICO',
    q: 'PRA QUEM?',
    d: 'Pra quem você vende. ICP definido com nicho, dor, desejo e poder de compra. Quem tenta vender pra todo mundo não vende pra ninguém.',
  },
  {
    n: 'P3',
    t: 'PRODUTO',
    q: 'O QUÊ?',
    d: 'O que tu entrega, por qual preço e com qual margem — escrito, versionado, testado. Oferta irrecusável > promessa vazia.',
  },
]
---

<SlideShell
  variant="default"
  sbLeft="6PS · FUNDAÇÃO (P1-P3)"
  sbRight="// MÓDULO 01 / 02"
  navLeft="← P0 · OVERVIEW"
  navRight="05 / 19 · P4-P6 · OPERAÇÃO →"
>
  <div class="fund-wrap">
    <div class="fund-head">
      <div class="fund-kicker">// FUNDAÇÃO · ESTRATÉGIA</div>
      <h2 class="fund-h2">
        <span class="stroke-text">FUNDAÇÃO</span> · P1-P3
      </h2>
      <p class="fund-sub">
        Sem os 3 primeiros Ps, os outros três viram chute.<br />
        <b>Fundação = estratégia antes de execução.</b>
      </p>
    </div>

    <div class="fund-grid">
      {ps.map((p) => (
        <div class="fund-card">
          <div class="fund-n">{p.n}</div>
          <div class="fund-t">// {p.t}</div>
          <div class="fund-q">{p.q}</div>
          <div class="fund-d">{p.d}</div>
        </div>
      ))}
    </div>
  </div>
</SlideShell>

<style>
  .fund-wrap {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 40px;
    height: 100%;
  }
  .fund-kicker {
    font-family: var(--font-mono);
    font-size: clamp(12px, 1vw, 16px);
    letter-spacing: 0.32em;
    color: var(--jb-acid);
    text-transform: uppercase;
    margin-bottom: 14px;
  }
  .fund-h2 {
    font-family: var(--font-display);
    font-size: clamp(42px, 6vw, 100px);
    line-height: 0.92;
    letter-spacing: -0.04em;
    text-transform: uppercase;
    color: var(--jb-cream);
    margin: 0;
  }
  .fund-sub {
    margin-top: 18px;
    font-size: clamp(13px, 1.2vw, 20px);
    line-height: 1.5;
    color: var(--jb-fg-3);
    max-width: 900px;
  }
  .fund-sub b { color: var(--jb-cream); }

  .fund-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }
  .fund-card {
    background: var(--jb-ink-2);
    border: 1px solid var(--jb-hair);
    padding: 32px 28px;
    position: relative;
    overflow: hidden;
  }
  .fund-card::before {
    content: '';
    position: absolute;
    inset: 0 0 auto 0;
    height: 3px;
    background: var(--jb-acid);
  }
  .fund-n {
    font-family: var(--font-display);
    font-size: clamp(60px, 7vw, 140px);
    line-height: 0.85;
    letter-spacing: -0.05em;
    color: var(--jb-acid);
    text-shadow: 0 0 50px rgba(198, 255, 0, 0.2);
  }
  .fund-t {
    margin-top: 12px;
    font-family: var(--font-mono);
    font-size: clamp(11px, 0.9vw, 14px);
    letter-spacing: 0.28em;
    color: var(--jb-fire);
    text-transform: uppercase;
  }
  .fund-q {
    margin-top: 12px;
    font-family: var(--font-display);
    font-size: clamp(22px, 2.4vw, 42px);
    line-height: 0.95;
    letter-spacing: -0.03em;
    text-transform: uppercase;
    color: var(--jb-cream);
  }
  .fund-d {
    margin-top: 16px;
    font-size: clamp(12px, 1vw, 16px);
    line-height: 1.5;
    color: var(--jb-fg-3);
  }

  @media (max-width: 1024px) {
    .fund-grid { grid-template-columns: 1fr; }
  }
</style>
