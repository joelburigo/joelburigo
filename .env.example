# ============================================================================
# joelburigo-site — TEMPLATE DEV LOCAL
#
# Copia pra .env e preenche os valores locais.
# Schema fonte de verdade: src/env.ts
# Pra prod use .env.tpl (1Password CLI) — ver infra/compose.joelburigo-site.yml
#
# Convenção:
#   - Vars vazias = preencher
#   - Vars com valor placeholder = pode usar como está em dev
# ============================================================================

# ----------------------------------------------------------------------------
# Runtime
# ----------------------------------------------------------------------------
NODE_ENV=development
PORT=4321
PUBLIC_SITE_URL=http://localhost:4321

# ----------------------------------------------------------------------------
# Database — Postgres local (brew install postgresql + createdb joelburigo)
# Sprint 1 BLOQUEANTE
# ----------------------------------------------------------------------------
DATABASE_URL=postgres://localhost:5432/joelburigo

# ----------------------------------------------------------------------------
# Sessão / Auth — Sprint 1 BLOQUEANTE
# Gerar com: openssl rand -base64 32
# ----------------------------------------------------------------------------
JWT_SECRET=

# ----------------------------------------------------------------------------
# LLM — OpenAI default; Anthropic opcional
# ----------------------------------------------------------------------------
LLM_PROVIDER=openai
LLM_MODEL_CHAT=gpt-5.2
LLM_MODEL_PREMIUM=gpt-5.2
LLM_MODEL_IMAGE=gpt-image-2

OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ----------------------------------------------------------------------------
# Pagamentos — Mercado Pago BR (default · API de Pagamentos / Bricks)
# Sprint 1 BLOQUEANTE
# Painel: mercadopago.com.br/developers/panel → Suas integrações
# Webhook: https://dev.joelburigo.com.br/api/payments/mercado-pago/webhook
# ----------------------------------------------------------------------------
MP_ACCESS_TOKEN=
MP_PUBLIC_KEY=
MP_WEBHOOK_SECRET=

# Stripe US (fallback opcional pra cartão internacional)
STRIPE_SECRET_KEY=
STRIPE_PUBLIC_KEY=
STRIPE_WEBHOOK_SECRET=

# ----------------------------------------------------------------------------
# Email transacional — Brevo (free 300/dia em dev)
# ----------------------------------------------------------------------------
BREVO_API_KEY=
EMAIL_FROM_TRANSACTIONAL=nao-responda@joelburigo.com.br
EMAIL_FROM_PERSONAL=joel@joelburigo.com.br
EMAIL_FROM_NAME="Joel Burigo"

# ----------------------------------------------------------------------------
# Cloudflare — Turnstile (anti-bot nos forms · Sprint 1)
# Painel: dash.cloudflare.com → Turnstile → Add Site
# ----------------------------------------------------------------------------
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ----------------------------------------------------------------------------
# Cloudflare — R2 (artifacts do agente · Sprint 2)
# ----------------------------------------------------------------------------
CF_ACCOUNT_ID=
CF_API_TOKEN=
R2_BUCKET=joelburigo-artifacts
R2_PUBLIC_URL=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# ----------------------------------------------------------------------------
# Cloudflare — Stream Live Input (mentorias · Sprint 4)
# ----------------------------------------------------------------------------
CF_STREAM_CUSTOMER_CODE=

# ----------------------------------------------------------------------------
# n8n (forward de form_submissions · Sprint 1 — opcional, pode mockar)
# ----------------------------------------------------------------------------
N8N_WEBHOOK_URL=

# ----------------------------------------------------------------------------
# Analytics
# ----------------------------------------------------------------------------
PUBLIC_GTM_ID=
GA4_MEASUREMENT_ID=
GA4_API_SECRET=
PUBLIC_META_PIXEL_ID=
META_CAPI_ACCESS_TOKEN=

# ----------------------------------------------------------------------------
# Monitoring — Sentry (Sprint 4)
# ----------------------------------------------------------------------------
SENTRY_DSN=

# ----------------------------------------------------------------------------
# Legado — TTS dos posts blog (scripts/generate-audio-posts.mjs)
# ----------------------------------------------------------------------------
ELEVENLABS_API_KEY=
