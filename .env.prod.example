# ============================================================================
# joelburigo-site — PRODUÇÃO (override de .env)
#
# Template pra criar `.env.prod` (gitignored).
# O script `cf-secrets-from-env.mjs prod` MERGEIA:
#   1. base = .env (valores dev/compartilhados)
#   2. override = .env.prod (só o que MUDA em prod)
#
# Aqui só ficam vars 🔴 OBRIGATÓRIO separar dev/prod (segurança/cobrança).
# Tudo o mais herda de .env automaticamente.
# ============================================================================

# ----------------------------------------------------------------------------
# Sessão / Auth — gerar: openssl rand -base64 32
# ----------------------------------------------------------------------------
JWT_SECRET=COLOQUE_AQUI_UM_NOVO_SECRET_GERADO

# ----------------------------------------------------------------------------
# Pagamentos Mercado Pago — credenciais "Produção" (APP_USR-...)
# Painel: mercadopago.com.br/developers/panel → Suas integrações
# ----------------------------------------------------------------------------
MP_ACCESS_TOKEN=APP_USR-PROD_AQUI
MP_PUBLIC_KEY=APP_USR-PROD_AQUI
MP_WEBHOOK_SECRET=PROD_WEBHOOK_SECRET_AQUI

# ----------------------------------------------------------------------------
# Cloudflare R2 — bucket de produção
# Token novo: dash.cloudflare.com → R2 → Manage R2 API Tokens
# ----------------------------------------------------------------------------
R2_BUCKET=joelburigo-artifacts
R2_PUBLIC_URL=https://media.joelburigo.com.br
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
