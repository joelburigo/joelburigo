---
import Layout from '../layouts/Layout.astro'
import Header from '../components/layout/Header.astro'
import Footer from '../components/layout/Footer.astro'
import Container from '../components/ui/Container.astro'
import { getWhatsAppLink } from '../data/contact'
---

<Layout
  title="500 — Gargalo detectado | Joel Burigo"
  description="Erro no servidor. Gargalo detectado. Volta pra home enquanto a gente resolve."
  noIndex={true}
>
  <Header />

  <main class="relative overflow-hidden bg-ink pt-20">
    <div class="grid-overlay"></div>

    <Container class="relative z-10">
      <section class="flex min-h-[80vh] items-center py-16 md:py-24">
        <div class="mx-auto w-full max-w-3xl">
          <!-- Kicker mono -->
          <div class="kicker mb-6" style="color: var(--jb-fire);">// ERROR · 500 · GARGALO_DETECTADO</div>

          <!-- Display gigante -->
          <h1 class="err-display">
            <span class="stroke-text">500:</span>
            <span class="block text-fire">GARGALO DETECTADO.</span>
          </h1>

          <!-- Copy -->
          <p class="mt-8 max-w-2xl font-sans text-[color:var(--jb-cream)] text-lg leading-relaxed">
            Algo travou no servidor. Acontece — com pipeline também. A diferença é que aqui tem processo pra consertar.
          </p>
          <p class="mt-3 max-w-2xl font-sans text-[color:var(--jb-fg-3)] leading-relaxed">
            Volta pra home. Se persistir, manda mensagem que a gente resolve.
          </p>

          <!-- CTAs -->
          <div class="mt-10 flex flex-wrap gap-4">
            <a href="/" class="btn-primary min-h-[48px]" data-astro-prefetch>
              <span>Voltar pra home</span>
              <span aria-hidden="true">→</span>
            </a>
            <a
              href={getWhatsAppLink('Encontrei um erro 500 no site joelburigo.com.br. Pode ajudar?')}
              target="_blank"
              rel="noopener noreferrer"
              class="btn-secondary min-h-[48px]"
            >
              <span>Reportar no WhatsApp</span>
              <span aria-hidden="true">→</span>
            </a>
          </div>

          <!-- Diagnóstico terminal-like -->
          <div class="mt-12 border border-[color:var(--jb-hair)] bg-[color:var(--jb-ink-2)] p-6 font-mono text-[13px] leading-[1.8] text-[color:var(--jb-cream)]">
            <div><span class="text-acid">$</span> scanning_system --status</div>
            <div class="text-[color:var(--jb-fg-muted)]">&gt; running diagnostic...</div>
            <div><span class="text-fire">●</span> SERVER · 500 · TEMPORARY</div>
            <div><span class="text-acid">▶</span> RETRY · disponível</div>
            <div><span class="text-acid">▶</span> SUPPORT · online</div>
            <div class="text-[color:var(--jb-fg-muted)]">&gt; recomendação: voltar pra home</div>
          </div>

          <!-- Status line -->
          <div class="mt-8 border-t border-[color:var(--jb-hair)] pt-6 font-mono text-[11px] uppercase tracking-[0.22em] text-[color:var(--jb-fg-muted)]">
            <span class="text-fire">●</span>&nbsp; STATUS: 500 · INTERNAL_ERROR · SLA: ASAP
          </div>
        </div>
      </section>
    </Container>
  </main>

  <Footer />
</Layout>

<style>
  .err-display {
    font-family: var(--font-display);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: -0.045em;
    line-height: 0.9;
    font-size: clamp(2.5rem, 9vw, 6rem);
    color: var(--jb-cream);
    margin: 0;
  }
</style>
