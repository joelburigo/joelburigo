---
import Container from '../ui/Container.astro'
---

<section class="final-cta-section relative overflow-hidden">
  <!-- Fundo fire + grid sutil -->
  <div class="fcta-grid-overlay"></div>

  <Container class="relative z-10">
    <div class="fcta-wrap">
      <!-- Kicker -->
      <div class="fcta-kicker mono">
        // PRÓXIMO PASSO · DIAGNÓSTICO 10 MIN
      </div>

      <!-- Headline gigante -->
      <h2 class="fcta-title">
        LIGAR A<br />
        <span class="fcta-title-stroke">MÁQUINA?</span>
      </h2>

      <!-- Lede -->
      <p class="fcta-lede">
        Diagnóstico grátis dos 6Ps. 10 minutos. Descobre qual P tá travando o crescimento — e qual é a próxima ação prioritária. <strong>Sem enrolação.</strong>
      </p>

      <!-- CTAs -->
      <div class="fcta-ctas">
        <a href="/diagnostico" class="fcta-btn-primary" data-astro-prefetch>
          <span>Fazer diagnóstico agora</span>
          <span aria-hidden="true">→</span>
        </a>
        <a href="/vendas-sem-segredos" class="fcta-btn-secondary" data-astro-prefetch>
          <span>Ou ver o VSS</span>
          <span aria-hidden="true">→</span>
        </a>
      </div>

      <!-- Assinatura -->
      <div class="fcta-signature">
        <span>BORA PRA CIMA.</span>
        <span class="fcta-sep">·</span>
        <span>LET'S GROW.</span>
      </div>
    </div>
  </Container>
</section>

<style>
  .final-cta-section {
    background: var(--jb-fire);
    padding-top: clamp(4rem, 10vw, 7rem);
    padding-bottom: clamp(4rem, 10vw, 7rem);
    color: var(--jb-ink);
  }

  .fcta-grid-overlay {
    position: absolute;
    inset: 0;
    pointer-events: none;
    opacity: 0.15;
    background-image:
      linear-gradient(to right, rgba(5, 5, 5, 0.35) 1px, transparent 1px),
      linear-gradient(to bottom, rgba(5, 5, 5, 0.35) 1px, transparent 1px);
    background-size: 80px 80px;
  }

  .fcta-wrap {
    max-width: 1100px;
    margin: 0 auto;
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: clamp(1.25rem, 2.5vw, 2rem);
    align-items: center;
  }

  .fcta-kicker {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.3em;
    color: var(--jb-ink);
    text-transform: uppercase;
    display: inline-block;
    border: 1px solid rgba(5, 5, 5, 0.4);
    padding: 8px 16px;
  }

  .fcta-title {
    font-family: var(--font-display);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: -0.05em;
    line-height: 0.85;
    font-size: clamp(3.5rem, 14vw, 10rem);
    color: var(--jb-ink);
    margin: 0;
  }
  .fcta-title-stroke {
    -webkit-text-stroke: 3px var(--jb-ink);
    color: transparent;
    display: block;
  }

  .fcta-lede {
    font-family: var(--font-sans);
    font-size: clamp(1.125rem, 1.8vw, 1.375rem);
    line-height: 1.5;
    color: var(--jb-ink);
    text-transform: none;
    margin: 0;
    max-width: 55ch;
    font-weight: 500;
  }
  .fcta-lede strong { font-weight: 900; }

  .fcta-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    justify-content: center;
    padding-top: 0.5rem;
  }

  .fcta-btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: var(--jb-ink);
    color: var(--jb-acid);
    font-family: var(--font-display);
    font-size: 0.9375rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-weight: 900;
    padding: 1rem 2rem;
    min-height: 56px;
    border: 0;
    box-shadow: 4px 4px 0 var(--jb-acid);
    transition: all var(--transition-base);
  }
  .fcta-btn-primary:hover {
    transform: translate(-2px, -2px);
    box-shadow: 6px 6px 0 var(--jb-acid);
  }

  .fcta-btn-secondary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: transparent;
    color: var(--jb-ink);
    font-family: var(--font-display);
    font-size: 0.9375rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-weight: 900;
    padding: 1rem 2rem;
    min-height: 56px;
    border: 2px solid var(--jb-ink);
    transition: all var(--transition-base);
  }
  .fcta-btn-secondary:hover {
    background: var(--jb-ink);
    color: var(--jb-acid);
  }

  .fcta-signature {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.32em;
    color: var(--jb-ink);
    text-transform: uppercase;
    padding-top: 0.5rem;
    display: inline-flex;
    gap: 10px;
    flex-wrap: wrap;
    justify-content: center;
    font-weight: 700;
  }
  .fcta-sep { opacity: 0.6; }
</style>
