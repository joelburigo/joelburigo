---
// Slide 17 · Advisory Investimento — pricing e CTA "Solicitar Convite"
import SlideShell from '../../SlideShell.astro'
---

<SlideShell
  variant="default"
  sbLeft="ADVISORY · INVESTIMENTO"
  sbRight="// SOLICITAR CONVITE"
  navLeft="★ MÁXIMO 5-10 CLIENTES SIMULTÂNEOS"
  navRight="18 / 19 · → CTA FINAL"
>
  <div class="ai-wrap">
    <div class="ai-left">
      <div class="ai-kicker">// PRICING CLARO</div>
      <h2 class="ai-h2">
        <span class="stroke-text">INVESTIMENTO</span><br />
        SEM <span class="acid">ENROLAÇÃO.</span>
      </h2>

      <div class="ai-grid">
        <div class="ai-card">
          <div class="ai-tag">// SESSÃO AVULSA</div>
          <div class="ai-price">R$ 997</div>
          <div class="ai-unit">/ SESSÃO · 90 MIN</div>
          <div class="ai-note">Garantia: até 48h antes → reembolso total</div>
        </div>
        <div class="ai-card ai-card-hi">
          <div class="ai-tag ai-tag-acid">// SPRINT 30 DIAS</div>
          <div class="ai-price">R$ 7.500</div>
          <div class="ai-unit">PAGAMENTO ÚNICO</div>
          <div class="ai-note">Garantia 1ª sessão · 100% antecipado ou 50/50</div>
        </div>
        <div class="ai-card">
          <div class="ai-tag">// CONSELHO</div>
          <div class="ai-price">R$ 12.5–15k</div>
          <div class="ai-unit">/ MÊS · 3-6 MESES</div>
          <div class="ai-note">Garantia 1ª semana · renovação trimestral</div>
        </div>
      </div>
    </div>

    <div class="ai-right">
      <div class="ai-cta-card">
        <div class="ai-cta-kicker">// PRÓXIMO PASSO</div>
        <h3 class="ai-cta-h3">
          VAGA É <span class="acid">LIMITADA.</span>
        </h3>
        <p class="ai-cta-p">
          Máximo <b>5-10 clientes simultâneos.</b> Critério: fit real de momento e de experiência.
          Não vendo pra qualquer um — protejo o resultado de quem já tá dentro.
        </p>

        <a href="/advisory-aplicacao" class="ai-cta">
          SOLICITAR CONVITE →
        </a>

        <div class="ai-steps">
          <span><b>01</b> Aplicação via e-mail</span>
          <span><b>02</b> Pré-avaliação do caso</span>
          <span><b>03</b> Conversa de fit (30 min)</span>
          <span><b>04</b> Agendamento · pagamento</span>
        </div>

        <div class="ai-sign">★ SISTEMA &gt; IMPROVISO · LET'S GROW</div>
      </div>
    </div>
  </div>
</SlideShell>

<style>
  .ai-wrap {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 48px;
    align-items: center;
    height: 100%;
  }
  .ai-kicker {
    font-family: var(--font-mono);
    font-size: clamp(12px, 1vw, 16px);
    letter-spacing: 0.32em;
    color: var(--jb-acid);
    text-transform: uppercase;
    margin-bottom: 14px;
  }
  .ai-h2 {
    font-family: var(--font-display);
    font-size: clamp(40px, 5.5vw, 92px);
    line-height: 0.92;
    letter-spacing: -0.04em;
    text-transform: uppercase;
    color: var(--jb-cream);
    margin: 0 0 28px;
  }
  .ai-h2 .acid { color: var(--jb-acid); }

  .ai-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 14px;
  }
  .ai-card {
    background: var(--jb-ink-2);
    border: 1px solid var(--jb-hair);
    padding: 20px;
  }
  .ai-card-hi {
    border-color: var(--jb-acid);
    box-shadow: 5px 5px 0 var(--jb-fire);
  }
  .ai-tag {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.28em;
    color: var(--jb-fire);
    text-transform: uppercase;
  }
  .ai-tag-acid { color: var(--jb-acid); }
  .ai-price {
    margin-top: 10px;
    font-family: var(--font-display);
    font-size: clamp(28px, 2.8vw, 44px);
    color: var(--jb-cream);
    letter-spacing: -0.03em;
    line-height: 1;
  }
  .ai-unit {
    margin-top: 4px;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.22em;
    color: var(--jb-fg-muted);
    text-transform: uppercase;
  }
  .ai-note {
    margin-top: 14px;
    padding-top: 12px;
    border-top: 1px dashed var(--jb-hair);
    font-size: 11px;
    line-height: 1.4;
    color: var(--jb-fg-3);
  }

  .ai-cta-card {
    background: linear-gradient(180deg, rgba(198, 255, 0, 0.08), var(--jb-ink-2));
    border: 2px solid var(--jb-acid);
    padding: 32px 32px 28px;
    box-shadow: 8px 8px 0 var(--jb-fire);
  }
  .ai-cta-kicker {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.28em;
    color: var(--jb-acid);
    text-transform: uppercase;
  }
  .ai-cta-h3 {
    margin: 12px 0 14px;
    font-family: var(--font-display);
    font-size: clamp(30px, 3vw, 52px);
    letter-spacing: -0.035em;
    line-height: 0.95;
    text-transform: uppercase;
    color: var(--jb-cream);
  }
  .ai-cta-h3 .acid { color: var(--jb-acid); }
  .ai-cta-p {
    font-size: clamp(12px, 1vw, 15px);
    line-height: 1.5;
    color: var(--jb-fg-3);
  }
  .ai-cta-p b { color: var(--jb-cream); }
  .ai-cta {
    display: block;
    margin-top: 20px;
    background: var(--jb-fire);
    color: var(--jb-ink);
    font-family: var(--font-display);
    font-size: clamp(14px, 1.2vw, 18px);
    letter-spacing: 0.12em;
    padding: 18px 20px;
    text-align: center;
    text-transform: uppercase;
    box-shadow: 5px 5px 0 var(--jb-acid);
    transition: transform var(--jb-dur) var(--jb-ease), box-shadow var(--jb-dur) var(--jb-ease);
  }
  .ai-cta:hover {
    transform: translate(-2px, -2px);
    box-shadow: 7px 7px 0 var(--jb-acid);
  }
  .ai-steps {
    margin-top: 18px;
    display: flex;
    flex-direction: column;
    gap: 4px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.16em;
    color: var(--jb-fg-2);
    text-transform: uppercase;
  }
  .ai-steps b { color: var(--jb-acid); margin-right: 8px; }
  .ai-sign {
    margin-top: 16px;
    padding-top: 14px;
    border-top: 1px solid var(--jb-hair);
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.24em;
    color: var(--jb-fg-muted);
    text-transform: uppercase;
    text-align: center;
  }

  @media (max-width: 1024px) {
    .ai-wrap { grid-template-columns: 1fr; overflow-y: auto; }
    .ai-grid { grid-template-columns: 1fr; }
  }
</style>
