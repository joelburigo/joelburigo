---
// Slide 6 · CREDIBILIDADE — stats canônicos (17+ / 140+ / ~R$ 1bi / 20+)
import SlideShell from '../SlideShell.astro'

const stats = [
  { v: '17+', l: 'ANOS DE EXECUÇÃO', sub: 'EXP. DESDE 2004' },
  { v: '140+', l: 'CLIENTES ATENDIDOS', sub: 'PESSOALMENTE' },
  { v: '~R$ 1bi', l: 'EM VENDAS ESTRUTURADAS', sub: 'ESTIMATIVA AGREGADA' },
  { v: '20+', l: 'NICHOS VALIDADOS', sub: 'B2B · B2C · D2C' },
]
---

<SlideShell
  variant="default"
  sbLeft="CREDIBILIDADE · JOEL BURIGO"
  sbRight="// ▶ TRACK RECORD"
  navLeft="★ SISTEMA &gt; IMPROVISO"
  navRight="07 / 19 · → PRÓXIMO"
>
  <div class="cred-wrap">
    <div class="cred-head">
      <div class="cred-kicker">// NÚMEROS QUE TEM LASTRO</div>
      <h2 class="cred-h2">
        <span class="stroke-text">NÃO É</span> TEORIA.<br />
        É <span class="acid">CICATRIZ.</span>
      </h2>
      <p class="cred-sub">
        Joel não é consultor de terno nem guru de promessa vazia.<br />
        É executor que quebrou, reconstruiu, e sistematizou o que aprendeu.
      </p>
    </div>

    <div class="cred-grid">
      {stats.map((s) => (
        <div class="cred-card">
          <div class="cred-v">{s.v}</div>
          <div class="cred-l">// {s.l}</div>
          <div class="cred-sub-line">{s.sub}</div>
        </div>
      ))}
    </div>

    <div class="cred-foot">
      <span class="mono-tag">★ PALHOÇA/SC · 1987</span>
      <span class="mono-tag">★ QUEBROU EM MARÇO/2012</span>
      <span class="mono-tag">★ RECONSTRUIU 2× · 100+ PORTAS EM BH</span>
      <span class="mono-tag">★ CRIADOR DO FRAMEWORK 6PS</span>
    </div>
  </div>
</SlideShell>

<style>
  .cred-wrap {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 44px;
    height: 100%;
  }
  .cred-kicker {
    font-family: var(--font-mono);
    font-size: clamp(12px, 1vw, 16px);
    letter-spacing: 0.32em;
    color: var(--jb-acid);
    text-transform: uppercase;
    margin-bottom: 16px;
  }
  .cred-h2 {
    font-family: var(--font-display);
    font-size: clamp(44px, 6.5vw, 110px);
    line-height: 0.92;
    letter-spacing: -0.045em;
    text-transform: uppercase;
    color: var(--jb-cream);
    margin: 0;
  }
  .cred-h2 .acid { color: var(--jb-acid); }
  .cred-sub {
    margin-top: 18px;
    font-size: clamp(13px, 1.2vw, 20px);
    line-height: 1.5;
    color: var(--jb-fg-3);
    max-width: 900px;
  }

  .cred-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
  }
  .cred-card {
    background: var(--jb-ink-2);
    border: 1px solid var(--jb-hair);
    padding: 28px;
  }
  .cred-v {
    font-family: var(--font-display);
    font-size: clamp(44px, 5vw, 88px);
    letter-spacing: -0.04em;
    color: var(--jb-acid);
    line-height: 0.95;
  }
  .cred-l {
    margin-top: 12px;
    font-family: var(--font-mono);
    font-size: clamp(10px, 0.8vw, 13px);
    letter-spacing: 0.28em;
    color: var(--jb-cream);
    text-transform: uppercase;
  }
  .cred-sub-line {
    margin-top: 4px;
    font-family: var(--font-mono);
    font-size: clamp(9px, 0.7vw, 11px);
    letter-spacing: 0.28em;
    color: var(--jb-fg-muted);
    text-transform: uppercase;
  }

  .cred-foot {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
  }
  .mono-tag {
    font-family: var(--font-mono);
    font-size: clamp(9px, 0.75vw, 12px);
    letter-spacing: 0.24em;
    color: var(--jb-fg-muted);
    text-transform: uppercase;
    padding: 8px 12px;
    border: 1px solid var(--jb-hair);
  }

  @media (max-width: 1024px) {
    .cred-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 640px) {
    .cred-grid { grid-template-columns: 1fr; }
  }
</style>
