---
import { Image } from 'astro:assets'
import type { ImageMetadata } from 'astro'
import Icons from './Icons.astro'

interface Props {
  videoUrl: string
  thumbnail?: string | ImageMetadata
  title?: string
  class?: string
  aspectRatio?: 'portrait' | 'landscape'
  lazyLoad?: boolean
}

const {
  videoUrl,
  thumbnail,
  title = 'Assista ao vídeo',
  class: className = '',
  aspectRatio = 'landscape',
  lazyLoad = true,
} = Astro.props

const aspectStyle = aspectRatio === 'portrait' ? 'aspect-ratio: 9 / 16;' : 'aspect-ratio: 16 / 9;'
const isImageMetadata = thumbnail && typeof thumbnail !== 'string'
---

<div class={`video-player-container relative overflow-hidden rounded-none border border-[color:var(--jb-hair)] ${className}`}>
  <div class="video-thumbnail relative cursor-pointer overflow-hidden" data-video-url={videoUrl} data-aspect={aspectRatio}>
    <div class="relative w-full" style={aspectStyle}>
      {thumbnail ? (
        isImageMetadata ? (
          <Image
            src={thumbnail as ImageMetadata}
            alt={title}
            loading={lazyLoad ? 'lazy' : 'eager'}
            fetchpriority={lazyLoad ? 'auto' : 'high'}
            class={aspectRatio === 'portrait' ? 'h-full w-full object-cover transition-transform duration-300 hover:scale-105' : 'absolute inset-0 h-full w-full object-cover transition-transform duration-300 hover:scale-105'}
          />
        ) : (
          <img
            src={thumbnail as string}
            alt={title}
            class={aspectRatio === 'portrait' ? 'h-full w-full object-cover transition-transform duration-300 hover:scale-105' : 'absolute inset-0 h-full w-full object-cover transition-transform duration-300 hover:scale-105'}
          />
        )
      ) : (
        <div class={aspectRatio === 'portrait' ? 'flex min-h-[400px] items-center justify-center bg-[color:var(--jb-ink-2)]' : 'absolute inset-0 flex items-center justify-center bg-[color:var(--jb-ink-2)]'}>
          <div class="grid-overlay"></div>
          <div class="relative text-center">
            <Icons name="play" class="mx-auto mb-4 h-20 w-20 text-[color:var(--jb-acid)]" />
            <p class="font-display text-xl uppercase tracking-tight text-[color:var(--jb-cream)]">{title}</p>
          </div>
        </div>
      )}

      <!-- Play Button Overlay (brutalist) -->
      <div class="absolute inset-0 flex items-center justify-center bg-[color:var(--jb-ink)]/50 transition-all duration-[var(--jb-dur)] hover:bg-[color:var(--jb-ink)]/30">
        <button
          aria-label={`Reproduzir vídeo: ${title}`}
          class="play-button group flex h-20 w-20 items-center justify-center rounded-none bg-[color:var(--jb-acid)] transition-all duration-[var(--jb-dur)] hover:-translate-x-[2px] hover:-translate-y-[2px]"
          style="box-shadow: 4px 4px 0 var(--jb-fire);"
        >
          <Icons name="play" class="h-10 w-10 fill-[color:var(--jb-ink)] text-[color:var(--jb-ink)]" />
        </button>
      </div>

      <!-- Badge topo (mono) -->
      <div class="absolute left-4 top-4 bg-[color:var(--jb-ink)]/90 px-3 py-1.5 border border-[color:var(--jb-acid-border)]">
        <span class="font-mono text-[11px] uppercase tracking-[0.22em] text-[color:var(--jb-acid)]">▶ ASSISTA</span>
      </div>
    </div>
  </div>

  <!-- Video Embed Inline -->
  <div class="video-embed hidden relative w-full overflow-hidden" style={aspectStyle}>
    <iframe
      class={aspectRatio === 'portrait' ? 'h-full w-full' : 'absolute inset-0 h-full w-full'}
      src=""
      title={title}
      allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
      allowfullscreen
      style="border: 0;"
    ></iframe>
  </div>
</div>

<script>
  function initVideoPlayers() {
    const thumbnails = document.querySelectorAll('.video-thumbnail')
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const t = entry.target as HTMLElement
            t.setAttribute('data-visible', 'true')
            observer.unobserve(t)
          }
        })
      },
      { rootMargin: '50px' }
    )
    thumbnails.forEach((t) => observer.observe(t))

    thumbnails.forEach((thumbnail) => {
      const container = thumbnail.closest('.video-player-container')
      if (!container) return
      const videoEmbed = container.querySelector('.video-embed')
      const iframe = videoEmbed?.querySelector('iframe')
      const videoUrl = thumbnail.getAttribute('data-video-url')
      if (!videoEmbed || !iframe || !videoUrl) return

      thumbnail.addEventListener('click', () => {
        let embedUrl = ''
        if (videoUrl.includes('youtube.com') || videoUrl.includes('youtu.be')) {
          let videoId: string | undefined = ''
          if (videoUrl.includes('youtu.be')) {
            videoId = videoUrl.split('youtu.be/')[1]?.split('?')[0] ?? ''
          } else if (videoUrl.includes('/shorts/')) {
            videoId = videoUrl.split('/shorts/')[1]?.split('?')[0] ?? ''
          } else {
            videoId = new URLSearchParams(new URL(videoUrl).search).get('v') || ''
          }
          embedUrl = `https://www.youtube.com/embed/${videoId}?autoplay=1&rel=0&modestbranding=1&enablejsapi=1`
        } else if (videoUrl.includes('vimeo.com')) {
          const videoId = videoUrl.split('vimeo.com/')[1]?.split('?')[0] ?? ''
          embedUrl = `https://player.vimeo.com/video/${videoId}?autoplay=1`
        } else {
          embedUrl = videoUrl
        }

        iframe.src = embedUrl
        requestAnimationFrame(() => {
          thumbnail.classList.add('hidden')
          videoEmbed.classList.remove('hidden')
        })

        const onMessage = (event: MessageEvent) => {
          if (event.origin !== 'https://www.youtube.com') return
          try {
            let data = event.data
            if (typeof data === 'string') data = JSON.parse(data)
            if (data.event === 'onStateChange' && data.info === 0) {
              iframe.src = ''
              requestAnimationFrame(() => {
                thumbnail.classList.remove('hidden')
                videoEmbed.classList.add('hidden')
              })
              window.removeEventListener('message', onMessage)
            }
          } catch {}
        }
        window.addEventListener('message', onMessage)
      })
    })
  }

  initVideoPlayers()
  document.addEventListener('astro:page-load', initVideoPlayers)
</script>

<style>
  .play-button { animation: pulse-acid 2s ease-in-out infinite; }
  @keyframes pulse-acid {
    0%, 100% { box-shadow: 4px 4px 0 var(--jb-fire), 0 0 0 0 rgba(198, 255, 0, 0.45); }
    50% { box-shadow: 4px 4px 0 var(--jb-fire), 0 0 0 18px rgba(198, 255, 0, 0); }
  }
</style>
