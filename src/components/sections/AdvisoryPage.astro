---
import Container from '../ui/Container.astro'
import Breadcrumbs from '../seo/Breadcrumbs.astro'

interface BreadcrumbItem {
  label: string
  href: string
}

interface Props {
  breadcrumbItems?: BreadcrumbItem[]
}

const { breadcrumbItems } = Astro.props

// Fonte canônica: docs/conteudo/partes/02-oferta.md §02.3 Advisory
// Tom: premium, exclusivo, por convite. Provas só do ANTI_DRIFT §4.

const formatos = [
  {
    nome: 'Sessão Estratégica Avulsa',
    investimento: 'R$ 997',
    cadencia: '/sessão',
    duracao: '90 minutos',
    slots: 'Máximo 4 sessões/mês',
    paraQuem: 'Desafio específico que precisa de direcionamento',
    inclusos: [
      '90 min de consultoria direta (presencial ou remoto)',
      'Diagnóstico rápido dos 6Ps',
      'Plano de ação (3–5 ações prioritárias)',
      'Gravação da sessão',
      'Relatório executivo 2–3 páginas em 24h',
    ],
    usos: [
      'Como me diferenciar sem competir por preço?',
      'Devo investir em tráfego ou contratar vendedor?',
      'Minha narrativa de investidor está de pé?',
    ],
  },
  {
    nome: 'Sprint Estratégico 30 Dias',
    investimento: 'R$ 7.500',
    cadencia: 'pagamento único',
    duracao: '4 sessões · 30 dias',
    slots: 'Máximo 3 clientes simultâneos',
    paraQuem: 'Momento crítico que precisa de plano estruturado',
    inclusos: [
      '4 sessões de 90 min (1 por semana)',
      'Diagnóstico profundo dos 6Ps',
      'Plano estratégico 12 meses detalhado',
      'WhatsApp direto (resposta em 24h úteis)',
      'Documento estratégico final (20–40 páginas)',
    ],
    usos: [
      'Vou abrir filial — preciso de plano estruturado',
      'Migrando de consultoria pra SaaS, preciso reorganizar',
      'Faturamento caiu 40% — preciso reagir rápido',
    ],
    destaque: true,
  },
  {
    nome: 'Conselho Executivo',
    investimento: 'R$ 15.000',
    cadencia: '/mês · mín. 3 meses',
    duracao: '3–6 meses',
    slots: 'Máximo 2 clientes simultâneos',
    paraQuem: 'Empresa que precisa de conselheiro presente',
    inclusos: [
      '8 sessões/mês (2 por semana · 60 min)',
      'WhatsApp prioritário (resposta em 4h)',
      'Participação em até 2 reuniões críticas/mês',
      'Revisão ilimitada de materiais estratégicos',
      'Diagnóstico trimestral dos 6Ps',
    ],
    usos: [
      'R$ 300k/mês, meta R$ 1M/mês em 12 meses',
      'Cresceu desordenado, preciso arrumar a casa',
      'Preparar empresa pra exit em 18 meses',
    ],
    precoEspecial: 'R$ 12.500/mês no plano semestral',
  },
]

const eh = [
  'CEO/Founder em momento crítico real',
  'Quer minha cabeça, não execução',
  'Valoriza atalho de 17+ anos',
  'Entende que tempo > dinheiro',
]

const naoEh = [
  'Quer que eu faça por você — Advisory é pensar junto',
  'Busca preço acessível (vai para VSS)',
  'Não tem urgência real',
  'Não aceita feedback direto',
]
---

<!-- HERO -->
<section class="relative overflow-hidden bg-ink pb-24 pt-12 md:pt-16">
  <div class="grid-overlay"></div>
  <!-- Gradient acid no canto -->
  <div class="pointer-events-none absolute -right-40 top-20 h-[600px] w-[600px] rounded-full" style="background: radial-gradient(circle, rgba(198,255,0,0.08), transparent 70%);"></div>

  <Container>
    {breadcrumbItems && <Breadcrumbs items={breadcrumbItems} class="mb-5" />}
    <div class="grid items-center gap-[clamp(2rem,5vw,4rem)] lg:grid-cols-[1.2fr_0.8fr] lg:gap-x-[clamp(3rem,6vw,5rem)]">
      <!-- Hero copy -->
      <div class="flex flex-col gap-[clamp(1.25rem,2.5vw,2rem)]">
        <div class="kicker">// ADVISORY · 1:1 COM JOEL · EXCLUSIVO</div>
        <h1 class="font-display text-cream" style="font-size: clamp(2.25rem, 6.5vw, 5rem); line-height: 0.9; letter-spacing: -0.045em; text-transform: uppercase; margin: 0;">
          Se sua empresa fatura mais de <span class="text-acid">R$ 200k/mês</span> e ainda depende de você —
          <span class="stroke-text">ela não é empresa.</span> É <span class="text-fire">emprego</span>.
        </h1>
        <p class="font-sans text-cream/85" style="font-size: clamp(1.05rem, 2vw, 1.25rem); line-height: 1.5; max-width: 42ch; margin: 0;">
          Advisory é acesso direto à minha cabeça pra momentos críticos ou parceria estratégica de longo prazo. <strong class="text-cream">17+ anos</strong>, <strong class="text-cream">140+ empresas estruturadas</strong>, <strong class="text-cream">~R$ 1 bilhão</strong> em vendas estruturadas. Sem enrolação, sem PowerPoint de 200 slides, sem execução terceirizada. Eu penso junto. Você decide. Você executa.
        </p>

        <div class="flex flex-col gap-3 sm:flex-row sm:items-center">
          <a href="mailto:joel@joelburigo.com.br?subject=Solicitação%20Advisory" class="btn-primary" style="min-height: 48px;">
            Solicitar convite →
          </a>
          <span class="mono text-fg-muted">★ resposta em 48h</span>
        </div>
      </div>

      <!-- Terminal critérios -->
      <aside class="border border-white/10 bg-ink-2" style="box-shadow: var(--shadow-terminal);">
        <div class="flex items-center gap-2 border-b border-white/10" style="padding: 10px 14px;">
          <span class="inline-block rounded-full bg-fire" style="width: 11px; height: 11px;"></span>
          <span class="inline-block rounded-full" style="width: 11px; height: 11px; background: #FFB020;"></span>
          <span class="inline-block rounded-full bg-acid" style="width: 11px; height: 11px;"></span>
          <span class="mono ml-auto text-fg-muted" style="font-size: 11px; letter-spacing: 0.12em; text-transform: lowercase;">advisory_filter — criteria</span>
        </div>
        <div class="p-8">
          <div class="kicker mb-4" style="color: var(--jb-fire);">// critérios de seleção</div>
          <ul class="mb-6 space-y-3">
            <li class="flex items-start gap-3 font-sans text-cream/85" style="font-size: 0.95rem;">
              <span class="text-acid">▶</span>
              <span>Momento crítico real (expansão, pivot, crise, exit)</span>
            </li>
            <li class="flex items-start gap-3 font-sans text-cream/85" style="font-size: 0.95rem;">
              <span class="text-acid">▶</span>
              <span>Faturamento R$ 200k+/mês</span>
            </li>
            <li class="flex items-start gap-3 font-sans text-cream/85" style="font-size: 0.95rem;">
              <span class="text-acid">▶</span>
              <span>CEO/Founder comprometido com execução</span>
            </li>
            <li class="flex items-start gap-3 font-sans text-cream/85" style="font-size: 0.95rem;">
              <span class="text-acid">▶</span>
              <span>Fit com experiência e agenda disponível</span>
            </li>
          </ul>
          <div class="border-t border-white/10 pt-4">
            <div class="mono mb-1 text-fg-muted">// acesso</div>
            <p class="font-sans text-cream/80" style="font-size: 0.9rem; line-height: 1.5;">
              Convite direto, indicação de cliente atual ou solicitação via e-mail (sujeito a avaliação). Não divulgado publicamente.
            </p>
          </div>
        </div>
      </aside>
    </div>
  </Container>
</section>

<!-- MANIFESTO / FILTRO É × NÃO É -->
<section class="relative bg-ink-2 py-20">
  <Container>
    <div class="mx-auto max-w-5xl">
      <div class="mb-12">
        <div class="kicker mb-4">// FILTRO</div>
        <h2 class="font-display text-cream" style="font-size: clamp(1.75rem, 4vw, 2.75rem); line-height: 0.95; letter-spacing: -0.035em; text-transform: uppercase;">
          Advisory <span class="text-acid">é</span>. Advisory <span class="text-fire">não é</span>.
        </h2>
      </div>

      <div class="grid gap-0 border border-white/10 md:grid-cols-2">
        <div class="border-b border-white/10 p-8 md:border-b-0 md:border-r" style="background: linear-gradient(180deg, rgba(198,255,0,0.04), transparent);">
          <div class="mono mb-5 text-acid">▲ é para</div>
          <ul class="space-y-4">
            {eh.map((item) => (
              <li class="flex items-start gap-3 font-sans text-cream" style="font-size: 1rem; line-height: 1.45;">
                <span class="text-acid">✓</span>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>
        <div class="p-8" style="background: linear-gradient(180deg, rgba(255,59,15,0.04), transparent);">
          <div class="mono mb-5 text-fire">▼ NÃO é para</div>
          <ul class="space-y-4">
            {naoEh.map((item) => (
              <li class="flex items-start gap-3 font-sans text-cream/80" style="font-size: 1rem; line-height: 1.45;">
                <span class="text-fire">✗</span>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </Container>
</section>

<!-- 3 FORMATOS -->
<section class="relative overflow-hidden bg-ink py-24">
  <div class="grid-overlay"></div>

  <Container>
    <div class="mx-auto mb-16 max-w-3xl">
      <div class="kicker mb-4">// FORMATOS · 3 NÍVEIS DE PROFUNDIDADE</div>
      <h2 class="mb-6 font-display text-cream" style="font-size: clamp(2rem, 5vw, 3.5rem); line-height: 0.92; letter-spacing: -0.04em; text-transform: uppercase;">
        Escolhe o <span class="text-acid">formato</span> que cabe no teu momento.
      </h2>
      <p class="font-sans text-cream/70" style="font-size: 1.125rem; line-height: 1.55;">
        De sessão pontual a conselheiro executivo contínuo. Garantia incondicional em todos: se não agregar valor na primeira sessão, reembolso 100% em 48h. Sem perguntas.
      </p>
    </div>

    <div class="grid gap-0 border border-white/10 lg:grid-cols-3">
      {formatos.map((f, i) => (
        <article class={`p-8 md:p-10 ${i < formatos.length - 1 ? 'border-b border-white/10 lg:border-b-0 lg:border-r' : ''} ${f.destaque ? '' : ''}`} style={f.destaque ? 'background: linear-gradient(180deg, rgba(198,255,0,0.06), #0B0B0B); border-left: 1px solid var(--jb-acid-border); border-right: 1px solid var(--jb-acid-border);' : 'background: #0B0B0B;'}>
          {f.destaque && (
            <div class="mb-4 inline-flex items-center gap-2 bg-acid px-2 py-1" style="color: var(--jb-ink);">
              <span class="font-display" style="font-size: 0.65rem; letter-spacing: 0.15em;">★ MAIS PEDIDO</span>
            </div>
          )}
          <h3 class="mb-3 font-display text-cream" style="font-size: 1.35rem; letter-spacing: -0.02em; text-transform: uppercase; line-height: 1.1;">
            {f.nome}
          </h3>
          <div class="mb-6 flex items-baseline gap-2">
            <span class="font-display text-acid" style="font-size: clamp(1.75rem, 3vw, 2.25rem); letter-spacing: -0.035em; line-height: 1;">
              {f.investimento}
            </span>
            <span class="mono text-fg-muted">{f.cadencia}</span>
          </div>
          <div class="mb-6 space-y-1">
            <div class="mono text-fg-muted">// duração · {f.duracao}</div>
            <div class="mono text-fg-muted">// slots · {f.slots}</div>
          </div>
          <p class="mb-6 font-sans text-cream/85" style="font-size: 0.95rem; line-height: 1.5;">
            <strong class="text-cream">Para quem:</strong> {f.paraQuem}
          </p>
          <div class="mb-6 border-t border-white/10 pt-5">
            <div class="mono mb-3 text-acid">// inclui</div>
            <ul class="space-y-2">
              {f.inclusos.map((item) => (
                <li class="flex items-start gap-2 font-sans text-cream/85" style="font-size: 0.875rem; line-height: 1.4;">
                  <span class="text-acid">▶</span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>
          <div class="mb-6 border-t border-white/10 pt-5">
            <div class="mono mb-3 text-fire">// exemplos de uso</div>
            <ul class="space-y-2">
              {f.usos.map((u) => (
                <li class="font-sans text-cream/70" style="font-size: 0.85rem; line-height: 1.4; font-style: italic;">
                  "{u}"
                </li>
              ))}
            </ul>
          </div>
          {f.precoEspecial && (
            <div class="mb-6 border-l-2 border-acid pl-3">
              <div class="mono text-acid">★ {f.precoEspecial}</div>
            </div>
          )}
          <a href="mailto:joel@joelburigo.com.br?subject=Advisory%20·%20" class={f.destaque ? 'btn-primary' : 'btn-secondary'} style="width: 100%; justify-content: center;">
            Solicitar convite →
          </a>
        </article>
      ))}
    </div>
  </Container>
</section>

<!-- GARANTIA + PROVA SOCIAL -->
<section class="relative bg-ink-2 py-20">
  <Container>
    <div class="mx-auto grid max-w-5xl gap-12 lg:grid-cols-[1fr_1fr]">
      <!-- Garantia -->
      <div class="border-l-4 border-acid bg-ink p-8 md:p-10">
        <div class="kicker mb-4">// GARANTIA INCONDICIONAL</div>
        <p class="mb-4 font-display text-cream" style="font-size: clamp(1.5rem, 3vw, 2rem); line-height: 1.05; letter-spacing: -0.035em; text-transform: uppercase;">
          Se não agregar valor na <span class="text-acid">primeira sessão</span>, devolvemos 100%.
        </p>
        <p class="font-sans text-cream/80" style="font-size: 0.95rem; line-height: 1.55;">
          Avisa em 24h, reembolso em 48h. Sem perguntas. Sem justificativas. Válida pra Sessão Avulsa, primeira sessão do Sprint 30d e primeira semana do Conselho Executivo.
        </p>
      </div>

      <!-- Provas -->
      <div class="border-l-4 border-fire bg-ink p-8 md:p-10">
        <div class="kicker mb-4" style="color: var(--jb-fire);">// PROVAS</div>
        <div class="mb-5 grid grid-cols-3 gap-4 border-b border-white/10 pb-5">
          <div>
            <div class="font-display text-acid" style="font-size: 2rem; line-height: 1; letter-spacing: -0.035em;">17+</div>
            <div class="mono mt-1 text-fg-muted" style="font-size: 0.6rem;">anos</div>
          </div>
          <div>
            <div class="font-display text-acid" style="font-size: 2rem; line-height: 1; letter-spacing: -0.035em;">140+</div>
            <div class="mono mt-1 text-fg-muted" style="font-size: 0.6rem;">clientes</div>
          </div>
          <div>
            <div class="font-display text-acid" style="font-size: 1.5rem; line-height: 1; letter-spacing: -0.035em;">~R$ 1BI</div>
            <div class="mono mt-1 text-fg-muted" style="font-size: 0.6rem;">em vendas</div>
          </div>
        </div>
        <p class="font-sans text-cream/80" style="font-size: 0.95rem; line-height: 1.55;">
          <strong class="text-cream">Case emblemático:</strong> Encontre Sua Franquia — de R$ 160k/mês para R$ 1 milhão/mês (+433%), leads ×8,33, holding com 1.800+ franqueados. 2018–2020.
        </p>
      </div>
    </div>
  </Container>
</section>

<!-- CTA FINAL -->
<section class="relative overflow-hidden bg-ink py-24">
  <div class="grid-overlay"></div>
  <Container>
    <div class="mx-auto max-w-4xl border-2 border-fire p-10 md:p-16" style="background: linear-gradient(180deg, rgba(255,59,15,0.08), #050505);">
      <div class="kicker mb-5" style="color: var(--jb-fire);">// DECISÃO</div>
      <h2 class="mb-6 font-display text-cream" style="font-size: clamp(1.75rem, 4.5vw, 3rem); line-height: 0.95; letter-spacing: -0.04em; text-transform: uppercase;">
        Momento crítico não espera.
        <br />Advisory <span class="text-acid">também não.</span>
      </h2>
      <p class="mb-8 font-sans text-cream/85" style="font-size: 1.125rem; line-height: 1.55;">
        5–10 slots ativos por vez. Seleção por fit real, não por ordem de chegada. Se teu momento é agora, solicita o convite. Se não é, espera o momento certo.
      </p>
      <div class="flex flex-col gap-4 sm:flex-row sm:items-center">
        <a href="mailto:joel@joelburigo.com.br?subject=Solicitação%20Advisory" class="btn-fire">
          Solicitar convite →
        </a>
        <span class="mono text-fg-muted">★ SEM ENROLAÇÃO · RESPOSTA EM 48H</span>
      </div>
    </div>
  </Container>
</section>
