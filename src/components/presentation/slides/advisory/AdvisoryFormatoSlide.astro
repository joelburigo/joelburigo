---
// Slide 15 · Advisory Formato — 3 formatos (Sessão · Sprint 30d · Conselho)
import SlideShell from '../../SlideShell.astro'

const formatos = [
  {
    n: '01',
    t: 'SESSÃO AVULSA',
    price: 'R$ 997',
    unit: 'POR SESSÃO · 90 MIN',
    para: 'Desafio específico que precisa de direcionamento',
    itens: [
      '90 min de consultoria ao vivo',
      'Diagnóstico rápido dos 6Ps',
      'Plano de ação (3-5 ações)',
      'Relatório executivo pós-sessão',
    ],
  },
  {
    n: '02',
    t: 'SPRINT 30 DIAS',
    price: 'R$ 7.500',
    unit: 'PAGAMENTO ÚNICO',
    para: 'Momento crítico · transformação específica em 1 mês',
    itens: [
      '4 sessões de 90 min (1/semana)',
      'Diagnóstico profundo dos 6Ps',
      'WhatsApp direto · 30 dias',
      'Documento estratégico (20-40 pgs)',
    ],
    highlight: true,
  },
  {
    n: '03',
    t: 'CONSELHO EXECUTIVO',
    price: 'R$ 12.5–15k',
    unit: '/MÊS · 3-6 MESES',
    para: 'CEO que quer conselheiro dedicado · parceria contínua',
    itens: [
      '8 sessões/mês (2/semana, 60min)',
      'WhatsApp prioritário com o Joel',
      'Até 2 reuniões críticas/mês',
      'Revisão ilimitada de materiais',
    ],
  },
]
---

<SlideShell
  variant="default"
  sbLeft="ADVISORY · 3 FORMATOS"
  sbRight="// ESCOLHA O ENCAIXE"
  navLeft="★ VAGAS LIMITADAS · POR CONVITE"
  navRight="16 / 19 · → VALOR"
>
  <div class="af-wrap">
    <div class="af-head">
      <div class="af-kicker">// 3 FORMATOS · 1 ACESSO</div>
      <h2 class="af-h2">
        ESCOLHA O <span class="acid">ENCAIXE.</span>
      </h2>
      <p class="af-sub">Da dúvida pontual à parceria contínua.</p>
    </div>

    <div class="af-grid">
      {formatos.map((f) => (
        <div class:list={['af-card', { 'af-card-hi': f.highlight }]}>
          <div class="af-n">{f.n}</div>
          <div class="af-t">{f.t}</div>
          <div class="af-para">{f.para}</div>
          <div class="af-price">{f.price}</div>
          <div class="af-unit">{f.unit}</div>
          <ul class="af-itens">
            {f.itens.map((i) => <li>{i}</li>)}
          </ul>
          {f.highlight && <div class="af-tag">★ MAIS PROCURADO</div>}
        </div>
      ))}
    </div>
  </div>
</SlideShell>

<style>
  .af-wrap {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 32px;
    height: 100%;
  }
  .af-kicker {
    font-family: var(--font-mono);
    font-size: clamp(12px, 1vw, 16px);
    letter-spacing: 0.32em;
    color: var(--jb-acid);
    text-transform: uppercase;
    margin-bottom: 12px;
  }
  .af-h2 {
    font-family: var(--font-display);
    font-size: clamp(40px, 5.5vw, 96px);
    line-height: 0.92;
    letter-spacing: -0.04em;
    text-transform: uppercase;
    color: var(--jb-cream);
    margin: 0;
  }
  .af-h2 .acid { color: var(--jb-acid); }
  .af-sub {
    margin-top: 10px;
    font-size: clamp(13px, 1.1vw, 18px);
    color: var(--jb-fg-3);
  }

  .af-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }
  .af-card {
    background: var(--jb-ink-2);
    border: 1px solid var(--jb-hair);
    padding: 28px 26px;
    position: relative;
  }
  .af-card-hi {
    border-color: var(--jb-acid);
    box-shadow: 6px 6px 0 var(--jb-fire);
  }
  .af-n {
    font-family: var(--font-display);
    font-size: clamp(36px, 3.5vw, 64px);
    color: var(--jb-fire);
    letter-spacing: -0.04em;
    line-height: 0.9;
  }
  .af-t {
    margin-top: 10px;
    font-family: var(--font-display);
    font-size: clamp(20px, 1.8vw, 30px);
    text-transform: uppercase;
    letter-spacing: -0.02em;
    color: var(--jb-cream);
  }
  .af-para {
    margin-top: 8px;
    font-size: clamp(11px, 0.85vw, 13px);
    line-height: 1.4;
    color: var(--jb-fg-3);
    min-height: 36px;
  }
  .af-price {
    margin-top: 18px;
    font-family: var(--font-display);
    font-size: clamp(36px, 4vw, 64px);
    color: var(--jb-acid);
    letter-spacing: -0.04em;
    line-height: 0.95;
  }
  .af-unit {
    margin-top: 4px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.22em;
    color: var(--jb-fg-muted);
    text-transform: uppercase;
  }
  .af-itens {
    list-style: none;
    padding: 0;
    margin: 20px 0 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
    border-top: 1px solid var(--jb-hair);
    padding-top: 16px;
  }
  .af-itens li {
    font-size: clamp(11px, 0.9vw, 14px);
    line-height: 1.45;
    color: var(--jb-fg-2);
    padding-left: 16px;
    position: relative;
  }
  .af-itens li::before {
    content: '▶';
    position: absolute;
    left: 0;
    color: var(--jb-acid);
    font-size: 0.7em;
    top: 4px;
  }
  .af-tag {
    position: absolute;
    top: -14px;
    right: 20px;
    background: var(--jb-acid);
    color: var(--jb-ink);
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.24em;
    padding: 6px 10px;
    text-transform: uppercase;
    font-weight: 700;
  }

  @media (max-width: 1024px) {
    .af-grid { grid-template-columns: 1fr; }
  }
</style>
