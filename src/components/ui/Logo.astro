---
// Wordmark canônico Terminal Growth.
// Matches docs/conteudo/brand/assets/logo.svg:
//   JOEL — Archivo Black 900, cream (#F5F1E8), tracking -0.03em
//   BURIGO — Archivo 500, fire (#FF3B0F), tracking -0.03em
// Sem separador. Proporção ~215px JOEL : 305px BURIGO em 520×88.

interface Props {
  class?: string
  /** Tamanho. Default md (20px). sm=14px · md=20px · lg=28px · xl=40px */
  size?: 'sm' | 'md' | 'lg' | 'xl'
  /** Se true, usa SVG inline (pra print/export). Default false usa texto. */
  asSvg?: boolean
}

const { class: className = '', size = 'md', asSvg = false } = Astro.props

const sizeMap = {
  sm: 'text-sm',
  md: 'text-xl',
  lg: 'text-3xl',
  xl: 'text-5xl',
}
---

{asSvg ? (
  <img src="/logo.svg" alt="Joel Burigo" class={className} />
) : (
  <span class={`inline-flex items-baseline tracking-[-0.03em] leading-none ${sizeMap[size]} ${className}`} aria-label="Joel Burigo">
    <span class="font-display text-[color:var(--jb-cream)]">JOEL</span><span class="font-sans font-medium text-[color:var(--jb-fire)] ml-1.5">BURIGO</span>
  </span>
)}
