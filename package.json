    "@iconify-json/lucide": "^1.2.102",
    "@tailwindcss/postcss": "^4.2.3",
    "astro": "^6.1.8",
    "astro-icon": "^1.1.5",
    "clsx": "^2.1.0",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "pagefind": "^1.5.2",
    "path-to-regexp": "^8.4.2",
    "playwright": "^1.59.1",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
