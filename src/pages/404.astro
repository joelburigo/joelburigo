---
import Layout from '../layouts/Layout.astro'
import Header from '../components/layout/Header.astro'
import Footer from '../components/layout/Footer.astro'
import Container from '../components/ui/Container.astro'

const seo = {
  title: '404 — Sistema off | Joel Burigo',
  description: 'Página não encontrada. Volta pra home e liga a máquina.',
}
---

<Layout title={seo.title} description={seo.description} noIndex={true}>
  <Header />

  <main class="relative overflow-hidden bg-ink pt-20">
    <div class="grid-overlay"></div>

    <Container class="relative z-10">
      <section class="flex min-h-[80vh] items-center py-16 md:py-24">
        <div class="mx-auto w-full max-w-3xl">
          <!-- Kicker mono -->
          <div class="kicker mb-6">// ERROR · 404 · PAGE_NOT_FOUND</div>

          <!-- Display gigante -->
          <h1 class="err-display">
            <span class="stroke-text">404:</span>
            <span class="block text-fire">SISTEMA OFF.</span>
          </h1>

          <!-- Copy -->
          <p class="mt-8 max-w-2xl font-sans text-[color:var(--jb-cream)] text-lg leading-relaxed">
            Essa rota não existe. Nem todo clique converte — esse aqui é um deles.
          </p>
          <p class="mt-3 max-w-2xl font-sans text-[color:var(--jb-fg-3)] leading-relaxed">
            Volta pra home e segue o plano. Sistema <span class="text-fire">&gt;</span> improviso.
          </p>

          <!-- CTAs -->
          <div class="mt-10 flex flex-wrap gap-4">
            <a href="/" class="btn-primary min-h-[48px]" data-astro-prefetch>
              <span>Voltar pra home</span>
              <span aria-hidden="true">→</span>
            </a>
            <a href="/diagnostico" class="btn-secondary min-h-[48px]">
              <span>Diagnóstico 6Ps</span>
              <span aria-hidden="true">→</span>
            </a>
          </div>

          <!-- Status line -->
          <div class="mt-16 border-t border-[color:var(--jb-hair)] pt-6 font-mono text-[11px] uppercase tracking-[0.22em] text-[color:var(--jb-fg-muted)]">
            <span class="text-acid">●</span>&nbsp; STATUS: 404 · ROUTE_LOST · RETRY_FROM_HOME
          </div>
        </div>
      </section>
    </Container>
  </main>

  <Footer />
</Layout>

<style>
  .err-display {
    font-family: var(--font-display);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: -0.045em;
    line-height: 0.9;
    font-size: clamp(3rem, 11vw, 7rem);
    color: var(--jb-cream);
    margin: 0;
  }
</style>

