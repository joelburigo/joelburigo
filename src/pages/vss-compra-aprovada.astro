---
import Layout from '../layouts/Layout.astro'
import Header from '../components/layout/Header.astro'
import Footer from '../components/layout/Footer.astro'
import Container from '../components/ui/Container.astro'
import { getWhatsAppLink } from '../data/contact'
---

<Layout
  title="Compra aprovada — VSS | Joel Burigo"
  description="Sua compra foi aprovada. Hora de ligar a Máquina."
  noIndex={true}
>
  <Header />

  <main class="relative overflow-hidden bg-ink pt-20">
    <div class="grid-overlay"></div>

    <Container class="relative z-10">
      <section class="py-16 md:py-24">
        <div class="mx-auto max-w-4xl">
          <!-- Kicker -->
          <div class="kicker mb-6">// VSS · STATUS: APROVADO · ACESSO_LIBERADO</div>

          <!-- Stat hero -->
          <div class="grid gap-8 md:grid-cols-[auto_1fr] md:items-end">
            <div class="stat-mega text-acid">+90d</div>
            <div>
              <h1 class="stat-display">
                <span class="block">BEM-VINDO AO</span>
                <span class="block text-fire">VSS.</span>
              </h1>
              <p class="mt-4 font-sans text-lg text-[color:var(--jb-cream)]">
                Compra aprovada. Em até 5 minutos você recebe acesso por email. Agora é execução.
              </p>
            </div>
          </div>

          <!-- Próximos passos -->
          <div class="mt-12 border border-[color:var(--jb-acid-border)] bg-[color:var(--jb-ink-2)] p-8">
            <div class="kicker mb-6" style="color: var(--jb-acid);">// PRÓXIMOS PASSOS · 5_MIN</div>
            <ol class="space-y-6">
              {[
                { n: '01', title: 'Checa seu email', body: 'Credenciais de acesso chegam em até 5 minutos. Verifica também a pasta de spam.' },
                { n: '02', title: 'Entra no Growth CRM', body: 'Ativa o CRM profissional incluso (R$ 6.996 de valor, 12 meses inclusos no VSS).' },
                { n: '03', title: 'Entra na comunidade', body: 'Acesso ao grupo exclusivo de alunos. Conecta com quem já está implementando.' },
                { n: '04', title: 'Assiste o módulo 1', body: 'Fundação dos 6Ps. 90 dias começam aqui. Sem enrolação.' },
              ].map((step) => (
                <li class="flex items-start gap-5">
                  <div class="shrink-0 font-mono text-sm font-bold text-acid" style="letter-spacing: 0.1em;">{step.n}</div>
                  <div>
                    <h3 class="heading-4 mb-1 text-[color:var(--jb-cream)]">{step.title}</h3>
                    <p class="font-sans text-[color:var(--jb-fg-2)]">{step.body}</p>
                  </div>
                </li>
              ))}
            </ol>
          </div>

          <!-- Info -->
          <div class="mt-8 grid gap-6 sm:grid-cols-2">
            <div class="card">
              <div class="kicker mb-3">// GARANTIA · 15_DIAS</div>
              <p class="font-sans text-[color:var(--jb-fg-2)]">
                Se não gostar, devolvo 100% do valor. Sem perguntas. Sem drama.
              </p>
            </div>
            <div class="card">
              <div class="kicker mb-3">// ACESSO · VITALÍCIO</div>
              <p class="font-sans text-[color:var(--jb-fg-2)]">
                Conteúdo no seu ritmo. 48 mentorias ao vivo semanais em grupo com Joel.
              </p>
            </div>
          </div>

          <!-- CTA suporte -->
          <div class="mt-10 flex flex-wrap gap-4">
            <a
              href={getWhatsAppLink('Olá! Comprei o Vendas Sem Segredos e gostaria de confirmar meu acesso.')}
              target="_blank"
              rel="noopener noreferrer"
              class="btn-primary min-h-[48px]"
            >
              <span>Falar com suporte</span>
              <span aria-hidden="true">→</span>
            </a>
            <a href="/" class="btn-secondary min-h-[48px]">Voltar pra home</a>
          </div>

          <!-- Assinatura -->
          <div class="mt-12 border-t border-[color:var(--jb-hair)] pt-8 font-mono text-[11px] uppercase tracking-[0.28em] text-[color:var(--jb-fg-muted)]">
            <span class="text-acid">★</span>&nbsp;&nbsp;SISTEMA <span class="text-fire">&gt;</span> IMPROVISO · LET'S GROW
          </div>
        </div>
      </section>
    </Container>
  </main>

  <Footer />
</Layout>

<style>
  .stat-mega {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: clamp(3.5rem, 10vw, 7rem);
    letter-spacing: -0.045em;
    line-height: 1;
  }
  .stat-display {
    font-family: var(--font-display);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: -0.04em;
    line-height: 0.92;
    font-size: clamp(2rem, 5.5vw, 3.5rem);
    color: var(--jb-cream);
    margin: 0;
  }
</style>
