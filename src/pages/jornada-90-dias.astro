---
import Layout from '../layouts/Layout.astro'
import Header from '../components/layout/Header.astro'
import Footer from '../components/layout/Footer.astro'
import Container from '../components/ui/Container.astro'
import Button from '../components/ui/Button.astro'
import Icons from '../components/ui/Icons.astro'
import Breadcrumbs from '../components/seo/Breadcrumbs.astro'

const seo = {
  title: 'Jornada de 90 Dias - Transforme Suas Vendas | Joel Burigo',
  description:
    'Descubra em detalhes como funciona a jornada de 90 dias do programa Vendas Sem Segredos. Do caos à previsibilidade em 13 semanas.',
  keywords:
    'jornada 90 dias, transformação vendas, sistema vendas, framework 6Ps, vendas estruturadas',
}

const fases = [
  {
    semanas: 'Semanas 1-2',
    nome: 'Fundamentos',
    icon: 'file-text',
    cor: 'lime',
    horas: '6-8h/semana',
    atividades: [
      'Diagnóstico completo dos 6Ps',
      'Define posicionamento, público, produto',
      'Cria plano de ação 90 dias'
    ],
    resultados: [
      'Clareza absoluta de onde está e para onde vai',
      'Documentos estratégicos prontos',
      'Prioridades definidas',
      'Roadmap visual criado'
    ],
    vendas: 'Nenhuma venda esperada (fase de planejamento)'
  },
  {
    semanas: 'Semanas 3-4',
    nome: 'Infraestrutura',
    icon: 'settings',
    cor: 'lime',
    horas: '8-10h/semana',
    atividades: [
      'Configura CRM completo do zero',
      'Cria site ou landing page profissional',
      'Importa base de contatos existente',
      'Configura primeiras automações'
    ],
    resultados: [
      'CRM 100% operacional',
      'Presença digital profissional no ar',
      'Sistema pronto para capturar leads',
      'Automações básicas funcionando'
    ],
    vendas: 'Possíveis primeiras vendas se já tem base aquecida'
  },
  {
    semanas: 'Semanas 5-8',
    nome: 'Atração',
    icon: 'trending-up',
    cor: 'lime',
    horas: '6-10h/semana',
    atividades: [
      'ROTA A: Campanhas de tráfego pago (se tem budget)',
      'ROTA B: Prospecção ativa no LinkedIn (sem budget)',
      'ROTA C: Conteúdo orgânico (todos fazem)',
      'Primeiros leads chegando'
    ],
    resultados: [
      'Rota A: 30-100 leads via tráfego',
      'Rota B: 20-50 conversas via prospecção',
      'Rota C: Primeiros seguidores e engajamento',
      'Sistema de atração funcionando'
    ],
    vendas: 'Primeiras vendas começam a acontecer'
  },
  {
    semanas: 'Semanas 9-10',
    nome: 'Conversão',
    icon: 'zap',
    cor: 'lime',
    horas: '5-7h/semana',
    atividades: [
      'Otimiza funis de conversão',
      'Implementa scripts de vendas testados',
      'Configura automações de nutrição',
      'Integra WhatsApp para atendimento',
      'Documenta objeções e respostas'
    ],
    resultados: [
      'Taxa de conversão melhorando',
      'Processo de vendas documentado',
      'Follow-up automatizado ativo',
      'Tempo de resposta < 5 minutos'
    ],
    vendas: 'Fluxo de vendas mais consistente'
  },
  {
    semanas: 'Semanas 11-13',
    nome: 'Integração',
    icon: 'check-circle-2',
    cor: 'lime',
    horas: '4-6h/semana',
    atividades: [
      'Documenta todos os processos',
      'Analisa métricas dos 90 dias',
      'Identifica gargalos',
      'Cria plano para próximos 90 dias',
      'Implementa melhorias'
    ],
    resultados: [
      'Sistema completo integrado e funcionando',
      'Métricas claras (CPL, CAC, LTV, taxa conversão)',
      'Gargalos identificados',
      'Roadmap de escala definido',
      'Processos documentados'
    ],
    vendas: 'Sistema rodando de forma previsível'
  }
]

const resultadoConsolidado = [
  {
    titulo: 'Fundação Estratégica Sólida',
    icon: 'target',
    itens: [
      '6Ps definidos e documentados',
      'Posicionamento claro e diferenciado',
      'Público-alvo mapeado cirurgicamente',
      'Oferta irresistível estruturada'
    ]
  },
  {
    titulo: 'Infraestrutura Profissional',
    icon: 'settings',
    itens: [
      'CRM completo configurado e operacional',
      'Site/landing pages publicados',
      'Funis de vendas ativos',
      'Automações rodando 24/7'
    ]
  },
  {
    titulo: 'Sistema de Atração Funcionando',
    icon: 'trending-up',
    itens: [
      'Tráfego pago estruturado OU',
      'Prospecção ativa consistente OU',
      'Crescimento orgânico planejado',
      'Leads chegando todo mês'
    ]
  },
  {
    titulo: 'Processo de Conversão Otimizado',
    icon: 'zap',
    itens: [
      'Scripts de vendas testados e ajustados',
      'Objeções mapeadas e respondidas',
      'Taxa de conversão medida e melhorando',
      'Follow-up automatizado ativo'
    ]
  },
  {
    titulo: 'Sistema Validado com Vendas',
    icon: 'check-circle-2',
    itens: [
      'Primeiras vendas confirmadas provando que o sistema funciona',
      'Volume varia por nicho, ticket médio e ciclo de vendas',
      'Aprendizado: O que funciona e o que não funciona',
      'Previsibilidade: Você sabe quantos leads precisa para bater meta'
    ]
  },
  {
    titulo: 'Clareza Total Sobre Próximos Passos',
    icon: 'map',
    itens: [
      'Métricas documentadas e entendidas',
      'Pontos fortes e fracos identificados',
      'Plano de escala 90-180 dias pronto',
      'Confiança para continuar crescendo'
    ]
  }
]
---

<Layout title={seo.title} description={seo.description} keywords={seo.keywords}>
  <Header />
  <section class="bg-dark pt-20 pb-6">
    <Container>
      <Breadcrumbs
        items={[
          { label: 'Home', href: '/' },
          { label: 'Jornada de 90 Dias', href: '/jornada-90-dias' },
        ]}
      />
    </Container>
  </section>
  <main class="grow pt-16 md:pt-20">

    <!-- Hero -->
    <section class="relative overflow-hidden bg-dark py-16 md:py-24">
      <Container class="relative z-10">
        <div class="mx-auto max-w-4xl text-center">
          <span class="mb-6 inline-block rounded-full border border-lime/30 bg-lime/20 px-6 py-2 font-display text-sm font-bold text-lime backdrop-blur-sm">
            A TRANSFORMAÇÃO EM DETALHES
          </span>
          <h1 class="mb-6 font-display text-display-lg text-white md:text-6xl">
            A Jornada de <span class="text-lime">90 Dias</span>
          </h1>
          <p class="mb-8 font-sans text-h3 font-semibold text-white/90">
            Do Caos à Previsibilidade em 13 Semanas
          </p>
          <p class="mx-auto max-w-3xl font-sans text-body-lg text-blue-100">
            Descubra em detalhes o que acontece em cada semana do programa Vendas Sem Segredos.
            Sem promessas vazias. Sem fórmulas mágicas. Apenas um sistema estruturado que funciona.
          </p>
        </div>
      </Container>
    </section>

    <!-- Premissa Central -->
    <section class="bg-dark py-24">
      <Container>
        <div class="mx-auto max-w-7xl">
          <div class="mb-16 text-center">
            <h2 class="mb-4 font-display text-display-sm text-white">
              O Que Você Pode <span class="text-lime">Esperar</span>
            </h2>
          </div>

          <div class="grid grid-cols-1 gap-8 lg:grid-cols-2">
            <!-- O Que Prometemos -->
            <div class="rounded-2xl border-2 border-lime/20 bg-lime/10 p-8">
              <div class="mb-6 flex items-center gap-3">
                <div class="rounded-full bg-lime p-3">
                  <Icons name="check-circle-2" class="h-6 w-6 text-dark" />
                </div>
                <h3 class="font-display text-h2 text-white">O Que Prometemos</h3>
              </div>
              <div class="rounded-xl border border-lime/20 bg-lime/5 p-6">
                <p class="font-sans text-body-lg text-white">
                  Em 90 dias (13 semanas), você terá um <span class="font-bold text-lime">sistema de vendas estruturado e funcionando</span>,
                  com primeiras vendas confirmadas e clareza total sobre como escalar.
                </p>
              </div>
            </div>

            <!-- O Que NÃO Prometemos -->
            <div class="rounded-2xl border-2 border-red-500/20 bg-red-500/10 p-8">
              <div class="mb-6 flex items-center gap-3">
                <div class="rounded-full bg-red-500 p-3">
                  <Icons name="x" class="h-6 w-6 text-white" />
                </div>
                <h3 class="font-display text-h2 text-white">O Que NÃO Prometemos</h3>
              </div>
              <ul class="space-y-3">
                <li class="flex items-start gap-3">
                  <Icons name="x" class="h-5 w-5 shrink-0 text-red-400" />
                  <span class="font-sans text-body text-gray-200">Enriquecimento rápido</span>
                </li>
                <li class="flex items-start gap-3">
                  <Icons name="x" class="h-5 w-5 shrink-0 text-red-400" />
                  <span class="font-sans text-body text-gray-200">Sistema 100% automatizado e perfeito</span>
                </li>
                <li class="flex items-start gap-3">
                  <Icons name="x" class="h-5 w-5 shrink-0 text-red-400" />
                  <span class="font-sans text-body text-gray-200">Crescimento exponencial imediato</span>
                </li>
                <li class="flex items-start gap-3">
                  <Icons name="x" class="h-5 w-5 shrink-0 text-red-400" />
                  <span class="font-sans text-body text-gray-200">Fórmula mágica sem esforço</span>
                </li>
              </ul>
            </div>
          </div>

          <!-- Honestidade Brutal -->
          <div class="mt-12 rounded-2xl border-2 border-white/10 bg-white/5 p-8">
            <div class="flex items-start gap-4">
              <Icons name="alert-circle" class="h-8 w-8 shrink-0 text-lime" />
              <div>
                <h3 class="mb-3 font-display text-h3 text-white">💯 Honestidade Brutal</h3>
                <p class="font-sans text-body text-gray-200">
                  Nos primeiros 90 dias você <span class="font-bold text-white">constrói a fundação sólida</span>.
                  Dos 90 aos 180 dias você <span class="font-bold text-white">escala e otimiza</span>.
                  É uma jornada de construção, não mágica instantânea.
                </p>
              </div>
            </div>
          </div>
        </div>
      </Container>
    </section>

    <!-- Investimento de Tempo -->
    <section class="bg-dark py-24">
      <Container>
        <div class="mx-auto max-w-5xl">
          <div class="mb-16 text-center">
            <h2 class="mb-4 font-display text-display-sm text-white">
              Investimento de <span class="text-lime">Tempo Real</span>
            </h2>
            <p class="mx-auto max-w-2xl font-sans text-body-lg text-gray-200">
              Este programa exige dedicação real. Veja quanto tempo você precisa dedicar por semana.
            </p>
          </div>

          <!-- Tabela de Horas -->
          <div class="overflow-hidden rounded-2xl border-2 border-white/10">
            <div class="overflow-x-auto">
              <table class="w-full">
                <thead class="bg-lime/10">
                  <tr>
                    <th class="px-6 py-4 text-left font-display text-sm font-bold text-white">Semanas</th>
                    <th class="px-6 py-4 text-left font-display text-sm font-bold text-white">Fase</th>
                    <th class="px-6 py-4 text-left font-display text-sm font-bold text-white">Horas/Semana</th>
                    <th class="px-6 py-4 text-left font-display text-sm font-bold text-white">Atividades</th>
                  </tr>
                </thead>
                <tbody class="bg-white/5">
                  <tr class="border-t border-white/10">
                    <td class="px-6 py-4 font-sans text-body text-white">1-2</td>
                    <td class="px-6 py-4 font-sans text-body text-white">Fundamentos</td>
                    <td class="px-6 py-4 font-display text-body font-semibold text-lime">6-8h</td>
                    <td class="px-6 py-4 font-sans text-body-sm text-gray-200">Aulas + Diagnóstico + Planejamento</td>
                  </tr>
                  <tr class="border-t border-white/10">
                    <td class="px-6 py-4 font-sans text-body text-white">3-4</td>
                    <td class="px-6 py-4 font-sans text-body text-white">Infraestrutura</td>
                    <td class="px-6 py-4 font-display text-body font-semibold text-lime">8-10h</td>
                    <td class="px-6 py-4 font-sans text-body-sm text-gray-200">Aulas + Setup CRM + Site</td>
                  </tr>
                  <tr class="border-t border-white/10">
                    <td class="px-6 py-4 font-sans text-body text-white">5-8</td>
                    <td class="px-6 py-4 font-sans text-body text-white">Atração</td>
                    <td class="px-6 py-4 font-display text-body font-semibold text-lime">6-10h</td>
                    <td class="px-6 py-4 font-sans text-body-sm text-gray-200">Aulas + Conteúdo/Tráfego/Prospecção</td>
                  </tr>
                  <tr class="border-t border-white/10">
                    <td class="px-6 py-4 font-sans text-body text-white">9-10</td>
                    <td class="px-6 py-4 font-sans text-body text-white">Conversão</td>
                    <td class="px-6 py-4 font-display text-body font-semibold text-lime">5-7h</td>
                    <td class="px-6 py-4 font-sans text-body-sm text-gray-200">Aulas + Funis + Scripts</td>
                  </tr>
                  <tr class="border-t border-white/10">
                    <td class="px-6 py-4 font-sans text-body text-white">11-13</td>
                    <td class="px-6 py-4 font-sans text-body text-white">Integração</td>
                    <td class="px-6 py-4 font-display text-body font-semibold text-lime">4-6h</td>
                    <td class="px-6 py-4 font-sans text-body-sm text-gray-200">Aulas + Documentação + Análise</td>
                  </tr>
                </tbody>
              </table>
            </div>
          </div>

          <!-- Média e Opções -->
          <div class="mt-8 grid grid-cols-1 gap-6 md:grid-cols-3">
            <div class="rounded-xl border border-lime/20 bg-lime/10 p-6 text-center">
              <p class="mb-2 font-display text-3xl font-bold text-lime">6-9h</p>
              <p class="font-sans text-sm text-gray-200">Média por semana</p>
            </div>
            <div class="rounded-xl border border-white/10 bg-white/5 p-6 text-center">
              <p class="mb-2 font-display text-lg font-semibold text-white">1-2h/dia</p>
              <p class="font-sans text-sm text-gray-200">Durante a semana</p>
            </div>
            <div class="rounded-xl border border-white/10 bg-white/5 p-6 text-center">
              <p class="mb-2 font-display text-lg font-semibold text-white">Sábado ou Domingo</p>
              <p class="font-sans text-sm text-gray-200">6-9h de manhã/tarde</p>
            </div>
          </div>

          <!-- Mensagem -->
          <div class="mt-8 rounded-2xl border-2 border-lime/30 bg-lime/10 p-6">
            <p class="text-center font-sans text-body text-gray-200">
              <span class="font-bold text-white">Se você não tem 6-9h/semana</span> para investir no futuro do seu negócio,
              espere ter esse tempo antes de se inscrever. <span class="font-bold text-white">Mas se você tem, os resultados compensam.</span>
            </p>
          </div>
        </div>
      </Container>
    </section>

    <!-- As 5 Fases -->
    <section class="bg-dark py-24">
      <Container>
        <div class="mx-auto max-w-7xl">
          <div class="mb-16 text-center">
            <h2 class="mb-4 font-display text-display-sm text-white">
              As <span class="text-lime">5 Fases</span> da Jornada
            </h2>
            <p class="mx-auto max-w-2xl font-sans text-body-lg text-gray-200">
              Cada fase tem objetivos claros, atividades específicas e resultados mensuráveis
            </p>
          </div>

          <!-- Timeline Visual -->
          <div class="relative space-y-12">
            <!-- Linha vertical conectando as fases -->
            <div class="absolute left-8 top-8 bottom-8 w-1 bg-linear-to-b from-lime via-lime/50 to-lime hidden md:block"></div>
            {fases.map((fase) => (
              <div class="relative md:pl-24">
                <!-- Círculo timeline -->
                <div class="absolute left-4 top-8 hidden h-8 w-8 items-center justify-center rounded-full border-4 border-dark bg-lime md:flex">
                  <div class="h-3 w-3 rounded-full bg-dark"></div>
                </div>

                <div class="group rounded-2xl border-2 border-white/10 bg-linear-to-br from-white/5 to-white/2 p-8 transition-all hover:border-lime/50 hover:shadow-2xl hover:shadow-lime/10">
                  <!-- Badge de semanas -->
                  <div class="mb-4 inline-flex items-center gap-2 rounded-full border border-lime/30 bg-lime/10 px-4 py-2">
                    <Icons name="calendar" class="h-4 w-4 text-lime" />
                    <span class="font-display text-sm font-bold text-lime">{fase.semanas}</span>
                  </div>

                  <!-- Header da Fase -->
                  <div class="mb-6 flex flex-col gap-4 md:flex-row md:items-start md:justify-between">
                    <div class="flex items-start gap-4">
                      <div class="flex h-16 w-16 shrink-0 items-center justify-center rounded-2xl bg-lime/20 ring-4 ring-lime/10 transition-all group-hover:scale-110 group-hover:ring-lime/30">
                        {fase.icon === 'file-text' && <Icons name="file-text" class="h-8 w-8 text-lime" />}
                        {fase.icon === 'settings' && <Icons name="settings" class="h-8 w-8 text-lime" />}
                        {fase.icon === 'trending-up' && <Icons name="trending-up" class="h-8 w-8 text-lime" />}
                        {fase.icon === 'zap' && <Icons name="zap" class="h-8 w-8 text-lime" />}
                        {fase.icon === 'check-circle-2' && <Icons name="check-circle-2" class="h-8 w-8 text-lime" />}
                      </div>
                      <div>
                        <h3 class="mb-2 font-display text-h2 text-white">{fase.nome}</h3>
                        <div class="flex items-center gap-2 text-gray-400">
                          <Icons name="clock" class="h-4 w-4" />
                          <p class="font-sans text-sm">{fase.horas}</p>
                        </div>
                      </div>
                    </div>
                  </div>

                <div class="grid grid-cols-1 gap-6 lg:grid-cols-2">
                  <!-- O Que Você Faz -->
                  <div>
                    <h4 class="mb-4 font-display text-lg font-semibold text-white">O Que Você Faz:</h4>
                    <ul class="space-y-2">
                      {fase.atividades.map((atividade) => (
                        <li class="flex items-start gap-2">
                          <Icons name="arrow-right" class="h-5 w-5 shrink-0 text-lime" />
                          <span class="font-sans text-body-sm text-gray-200">{atividade}</span>
                        </li>
                      ))}
                    </ul>
                  </div>

                  <!-- Resultado Esperado -->
                  <div>
                    <h4 class="mb-4 font-display text-lg font-semibold text-white">Resultado Esperado:</h4>
                    <ul class="space-y-2">
                      {fase.resultados.map((resultado) => (
                        <li class="flex items-start gap-2">
                          <Icons name="check-circle-2" class="h-5 w-5 shrink-0 text-lime" />
                          <span class="font-sans text-body-sm text-gray-200">{resultado}</span>
                        </li>
                      ))}
                    </ul>
                  </div>
                </div>

                <!-- Vendas -->
                <div class="mt-6 rounded-xl border border-lime/20 bg-lime/10 p-4">
                  <p class="font-display text-sm font-semibold text-lime">
                    💰 Vendas nesta fase: {fase.vendas}
                  </p>
                </div>
                </div>
              </div>
            ))}
          </div>
        </div>
      </Container>
    </section>

    <!-- Resultado Consolidado -->
    <section class="bg-dark py-24">
      <Container>
        <div class="mx-auto max-w-7xl">
          <div class="mb-16 text-center">
            <h2 class="mb-4 font-display text-display-sm text-white">
              Ao Final dos <span class="text-lime">90 Dias</span>
            </h2>
            <p class="mx-auto max-w-2xl font-sans text-body-lg text-gray-200">
              O que você terá construído no seu negócio
            </p>
          </div>

          <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3">
            {resultadoConsolidado.map((item) => (
              <div class="rounded-2xl border-2 border-white/10 bg-white/5 p-8 transition-all hover:border-lime/30">
                <div class="mb-4 flex items-center gap-3">
                  {item.icon === 'target' && <Icons name="target" class="h-8 w-8 text-lime" />}
                  {item.icon === 'settings' && <Icons name="settings" class="h-8 w-8 text-lime" />}
                  {item.icon === 'trending-up' && <Icons name="trending-up" class="h-8 w-8 text-lime" />}
                  {item.icon === 'zap' && <Icons name="zap" class="h-8 w-8 text-lime" />}
                  {item.icon === 'check-circle-2' && <Icons name="check-circle-2" class="h-8 w-8 text-lime" />}
                  {item.icon === 'map' && <Icons name="map" class="h-8 w-8 text-lime" />}
                </div>
                <h3 class="mb-4 font-display text-h3 text-white">{item.titulo}</h3>
                <ul class="space-y-2">
                  {item.itens.map((subitem) => (
                    <li class="flex items-start gap-2">
                      <Icons name="check-circle-2" class="h-4 w-4 shrink-0 text-lime" />
                      <span class="font-sans text-body-sm text-gray-200">{subitem}</span>
                    </li>
                  ))}
                </ul>
              </div>
            ))}
          </div>

          <!-- Expectativas Realistas -->
          <div class="mt-12 rounded-2xl border-2 border-lime/30 bg-lime/10 p-8">
            <div class="text-center">
              <h3 class="mb-4 font-display text-h2 text-white">📊 O Que Você Terá ao Final</h3>
              <div class="mx-auto max-w-3xl space-y-4">
                <div class="rounded-xl border border-lime/20 bg-lime/5 p-6">
                  <p class="mb-2 font-display text-2xl font-bold text-lime">Sistema Validado</p>
                  <p class="font-sans text-body text-gray-200">Primeiras vendas confirmadas provando que funciona</p>
                </div>
                <div class="rounded-xl border border-lime/20 bg-lime/5 p-6">
                  <p class="mb-2 font-display text-2xl font-bold text-lime">Pipeline Previsível</p>
                  <p class="font-sans text-body text-gray-200">Você sabe quantos leads precisa para bater sua meta</p>
                </div>
                <div class="rounded-xl border border-lime/20 bg-lime/5 p-6">
                  <p class="mb-2 font-display text-2xl font-bold text-lime">Autonomia</p>
                  <p class="font-sans text-body text-gray-200">Processos documentados e sistema replicável</p>
