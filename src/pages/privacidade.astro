---
import Layout from '../layouts/Layout.astro'
import Header from '../components/layout/Header.astro'
import Footer from '../components/layout/Footer.astro'
import Container from '../components/ui/Container.astro'
import Breadcrumbs from '../components/seo/Breadcrumbs.astro'

const seo = {
  title: 'Política de Privacidade | Joel Burigo',
  description: 'Política de privacidade e proteção de dados pessoais em conformidade com a LGPD.',
  keywords: 'política privacidade, LGPD, proteção dados, Joel Burigo',
}

const sections = [
  {
    id: 1,
    title: 'Informações Gerais',
    body: `<p>A <strong>Growth Master Ltda</strong>, operadora da marca JOEL BURIGO, está comprometida em proteger a privacidade e os dados pessoais dos usuários, em conformidade com a Lei Geral de Proteção de Dados (LGPD — Lei nº 13.709/2018).</p>`,
  },
  {
    id: 2,
    title: 'Dados Coletados',
    body: `<p>Coletamos as seguintes informações quando você:</p>
    <ul>
      <li>Preenche formulários de contato: nome, email, telefone, empresa</li>
      <li>Inscreve-se no VSS ou outros programas: dados cadastrais e informações de pagamento</li>
      <li>Faz o diagnóstico 6Ps: respostas do questionário e dados de contato</li>
      <li>Navega no site: cookies, IP, páginas visitadas, tempo de sessão</li>
    </ul>`,
  },
  {
    id: 3,
    title: 'Uso dos Dados',
    body: `<p>Utilizamos seus dados pessoais para:</p>
    <ul>
      <li>Responder solicitações de contato</li>
      <li>Processar inscrições em programas e serviços</li>
      <li>Enviar conteúdo educacional e newsletters (com consentimento)</li>
      <li>Melhorar a experiência de navegação</li>
      <li>Realizar análises estatísticas e de performance</li>
      <li>Cumprir obrigações legais e fiscais</li>
    </ul>`,
  },
  {
    id: 4,
    title: 'Compartilhamento de Dados',
    body: `<p>Seus dados podem ser compartilhados com:</p>
    <ul>
      <li><strong>Processadores de pagamento</strong> — transações financeiras</li>
      <li><strong>Ferramentas de CRM</strong> — gestão de relacionamento</li>
      <li><strong>Plataformas de email</strong> — envio de comunicações (só com consentimento)</li>
      <li><strong>Autoridades legais</strong> — quando exigido por lei</li>
    </ul>
    <p><strong>Nunca vendemos ou compartilhamos seus dados com terceiros para fins comerciais não relacionados aos serviços prestados.</strong></p>`,
  },
  {
    id: 5,
    title: 'Seus Direitos (LGPD)',
    body: `<p>Você tem direito a:</p>
    <ul>
      <li>Confirmar existência de tratamento dos seus dados</li>
      <li>Acessar seus dados pessoais</li>
      <li>Corrigir dados incompletos, inexatos ou desatualizados</li>
      <li>Solicitar anonimização, bloqueio ou eliminação de dados desnecessários</li>
      <li>Solicitar portabilidade dos dados</li>
      <li>Revogar o consentimento a qualquer momento</li>
      <li>Opor-se ao tratamento baseado em hipótese de dispensa de consentimento</li>
    </ul>
    <p>Pra exercer seus direitos, envie email pra <strong>contato@joelburigo.com.br</strong>.</p>`,
  },
  {
    id: 6,
    title: 'Cookies',
    body: `<p>Utilizamos cookies pra melhorar a experiência de navegação, analisar tráfego e personalizar conteúdo. Você pode desativar cookies nas configurações do navegador — isso pode afetar a funcionalidade do site.</p>`,
  },
  {
    id: 7,
    title: 'Segurança',
    body: `<p>Implementamos medidas técnicas e organizacionais adequadas pra proteger seus dados contra acesso não autorizado, alteração, divulgação ou destruição. Nenhuma transmissão pela internet é 100% segura, mas o esforço é contínuo.</p>`,
  },
  {
    id: 8,
    title: 'Retenção de Dados',
    body: `<p>Mantemos dados pessoais apenas pelo tempo necessário pra cumprir as finalidades descritas nesta política, salvo se período de retenção maior for exigido ou permitido por lei.</p>`,
  },
  {
    id: 9,
    title: 'Alterações nesta Política',
    body: `<p>Podemos atualizar esta Política de Privacidade periodicamente. Mudanças significativas serão notificadas por email ou aviso no site.</p>`,
  },
  {
    id: 10,
    title: 'Contato',
    body: `<ul>
      <li><strong>Razão Social:</strong> Growth Master Ltda</li>
      <li><strong>Email:</strong> contato@joelburigo.com.br</li>
      <li><strong>Website:</strong> joelburigo.com.br</li>
    </ul>`,
  },
]
---

<Layout title={seo.title} description={seo.description} keywords={seo.keywords}>
  <Header />

  <section class="bg-ink pt-6 pb-0">
    <Container>
      <Breadcrumbs items={[{ label: 'Home', href: '/' }, { label: 'Privacidade', href: '/privacidade' }]} />
    </Container>
  </section>

  <main class="relative overflow-hidden bg-ink pb-20">
    <div class="grid-overlay"></div>

    <Container class="relative z-10">
      <article class="mx-auto max-w-3xl py-12 md:py-16">
        <!-- Hero -->
        <header class="mb-12 border-b border-[color:var(--jb-hair)] pb-8">
          <div class="kicker mb-4">// LEGAL · LGPD · PRIVACIDADE</div>
          <h1 class="legal-h1">Política de Privacidade</h1>
          <p class="mt-4 font-mono text-[12px] uppercase tracking-[0.22em] text-[color:var(--jb-fg-muted)]">
            Última atualização: Abril/2026
          </p>
        </header>

        <!-- Sections -->
        <div class="space-y-10 font-sans text-[color:var(--jb-cream)] leading-relaxed prose-legal">
          {sections.map((s) => (
            <section>
              <h2 class="legal-h2">
                <span class="legal-num">{String(s.id).padStart(2, '0')}</span> {s.title}
              </h2>
              <div set:html={s.body} />
            </section>
          ))}
        </div>

        <!-- Assinatura -->
        <div class="mt-16 border-t border-[color:var(--jb-hair)] pt-8 font-mono text-[11px] uppercase tracking-[0.22em] text-[color:var(--jb-fg-muted)]">
          <span class="text-acid">●</span>&nbsp; GROWTH MASTER LTDA · CONTATO@JOELBURIGO.COM.BR
        </div>
      </article>
    </Container>
  </main>

  <Footer />
</Layout>

<style>
  .legal-h1 {
    font-family: var(--font-display);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: -0.035em;
    line-height: 1.0;
    font-size: clamp(2rem, 5vw, 3rem);
    color: var(--jb-cream);
    margin: 0;
  }
  .legal-h2 {
    font-family: var(--font-display);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: -0.02em;
    font-size: 1.5rem;
    color: var(--jb-cream);
    margin: 0 0 1rem 0;
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
  }
  .legal-num {
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 0.875rem;
    color: var(--jb-acid);
    letter-spacing: 0.1em;
  }
  .prose-legal :global(p) { margin: 0 0 1rem 0; color: var(--jb-fg-2); }
  .prose-legal :global(ul) { margin: 0 0 1rem 0; padding-left: 1.5rem; color: var(--jb-fg-2); list-style: none; }
  .prose-legal :global(ul li) { position: relative; padding-left: 0; margin-bottom: 0.5rem; }
  .prose-legal :global(ul li::before) {
    content: '▶';
    color: var(--jb-acid);
    margin-right: 0.75rem;
    font-size: 0.75em;
  }
  .prose-legal :global(strong) { color: var(--jb-cream); font-weight: 700; }
</style>
