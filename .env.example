# ========================================
# GTM FIRST - Site Configuration
# ========================================
# O site roda no Node via Docker (Hetzner). GA4/Meta/Ads ficam configurados no GTM.

# Google Tag Manager (OBRIGATÓRIO)
PUBLIC_GTM_ID=GTM-XXXXXXX

# Site URL (OBRIGATÓRIO)
PUBLIC_SITE_URL=https://joelburigo.com.br

# Meta Pixel ID (OPCIONAL — client-side, usado pelo componente MetaConversionsAPI)
PUBLIC_META_PIXEL_ID=

# ========================================
# Server-side APIs (OPCIONAL)
# ========================================
# Só precisa se for usar /api/track ou /api/meta-conversion.
# NUNCA commitar valores reais neste arquivo.

# GA4 Measurement Protocol
# GA4 Admin → Data Streams → Measurement Protocol API secrets
GA4_MEASUREMENT_ID=
GA4_API_SECRET=

# Meta Conversions API
# Meta Events Manager → Conversions API → Generate Access Token
META_CAPI_ACCESS_TOKEN=

# Environment
NODE_ENV=production
