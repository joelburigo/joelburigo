---
interface Props {
  variant?: 'primary' | 'fire' | 'secondary' | 'outline' | 'ghost'
  size?: 'sm' | 'md' | 'lg'
  class?: string
  type?: 'button' | 'submit' | 'reset'
  href?: string
  disabled?: boolean
  [key: string]: any
}

const {
  variant = 'primary',
  size = 'md',
  class: className = '',
  type = 'button',
  href,
  disabled = false,
  ...props
} = Astro.props

// Terminal Growth — brutalist buttons.
// primary  = acid bg + fire shadow (CTA principal)
// fire     = fire bg + acid shadow (CTA alto-impacto)
// secondary= outline cream, hover acid
// outline  = hair border, hover bg rgba cream
// ghost    = text only, underline acid on hover
const baseStyles =
  'inline-flex items-center justify-center gap-2 font-display uppercase tracking-[0.08em] font-black rounded-none transition-all duration-[var(--jb-dur)] focus:outline-none focus:ring-2 focus:ring-[color:var(--jb-acid)] focus:ring-offset-2 focus:ring-offset-[color:var(--jb-ink)] disabled:opacity-50 disabled:cursor-not-allowed'

const variants = {
  primary:
    'bg-[color:var(--jb-acid)] text-[color:var(--jb-ink)] shadow-[4px_4px_0_var(--jb-fire)] hover:-translate-x-[2px] hover:-translate-y-[2px] hover:shadow-[6px_6px_0_var(--jb-fire)] active:translate-x-0 active:translate-y-0 active:shadow-[2px_2px_0_var(--jb-fire)]',
  fire:
    'bg-[color:var(--jb-fire)] text-[color:var(--jb-ink)] shadow-[4px_4px_0_var(--jb-acid)] hover:-translate-x-[2px] hover:-translate-y-[2px] hover:shadow-[6px_6px_0_var(--jb-acid)] active:translate-x-0 active:translate-y-0 active:shadow-[2px_2px_0_var(--jb-acid)]',
  secondary:
    'bg-transparent text-[color:var(--jb-cream)] border border-[color:var(--jb-cream)] hover:bg-[color:var(--jb-cream)]/6 hover:border-[color:var(--jb-acid)] hover:text-[color:var(--jb-acid)]',
  outline:
    'bg-transparent text-[color:var(--jb-cream)] border border-[color:var(--jb-hair-strong)] hover:border-[color:var(--jb-cream)]',
  ghost:
    'bg-transparent text-[color:var(--jb-cream)] hover:text-[color:var(--jb-acid)] hover:underline underline-offset-4',
}

const sizes = {
  sm: 'min-h-9 py-2 px-4 text-xs',
  md: 'min-h-11 py-3 px-7 text-sm',
  lg: 'min-h-14 py-4 px-9 text-base',
}

const classes = `${baseStyles} ${variants[variant]} ${sizes[size]} ${className}`.trim()
---

{href ? (
  <a href={href} class={classes} {...props}>
    <slot />
  </a>
) : (
  <button type={type} class={classes} disabled={disabled} {...props}>
    <slot />
  </button>
)}
