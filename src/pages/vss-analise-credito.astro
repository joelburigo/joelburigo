---
import Layout from '../layouts/Layout.astro'
import Header from '../components/layout/Header.astro'
import Footer from '../components/layout/Footer.astro'
import Container from '../components/ui/Container.astro'
import { contactInfo, getWhatsAppLink } from '../data/contact'
---

<Layout
  title="Análise de crédito — VSS | Joel Burigo"
  description="Pagamento em análise pela operadora do cartão."
  noIndex={true}
>
  <Header />

  <main class="relative overflow-hidden bg-ink pt-20">
    <div class="grid-overlay"></div>

    <Container class="relative z-10">
      <section class="py-16 md:py-24">
        <div class="mx-auto max-w-4xl">
          <!-- Kicker -->
          <div class="kicker mb-6" style="color: var(--jb-fire);">// VSS · STATUS: UNDER_REVIEW · ANÁLISE_CRÉDITO</div>

          <h1 class="status-display">
            <span class="stroke-text">PAGAMENTO</span>
            <span class="block text-fire">EM ANÁLISE.</span>
          </h1>

          <p class="mt-8 max-w-2xl font-sans text-lg text-[color:var(--jb-cream)]">
            A operadora do cartão está verificando a transação. Procedimento padrão de segurança — protege você e nós contra fraude.
          </p>

          <!-- Timeline -->
          <div class="mt-12 space-y-6">
            {[
              { n: '01', title: 'Análise antifraude', body: 'Operadora verifica se a transação é legítima. Normal e esperado.', icon: '●' },
              { n: '02', title: 'Tempo de análise', body: 'Minutos a 24 horas na maioria dos casos. Raro ultrapassar 3 dias úteis.', icon: '▶' },
              { n: '03', title: 'Notificação por email', body: 'Você recebe email quando aprovar ou recusar. Olha também o spam.', icon: '▶' },
            ].map((item) => (
              <div class="flex items-start gap-5 border-l-2 border-[color:var(--jb-acid)] bg-[color:var(--jb-ink-2)] p-5">
                <div class="shrink-0 font-mono text-sm font-bold text-acid" style="letter-spacing: 0.1em;">{item.n}</div>
                <div class="flex-1">
                  <h3 class="heading-4 mb-1 text-[color:var(--jb-cream)]">
                    <span class="text-acid">{item.icon}</span>&nbsp; {item.title}
                  </h3>
                  <p class="font-sans text-[color:var(--jb-fg-2)]">{item.body}</p>
                </div>
              </div>
            ))}
          </div>

          <!-- Se recusado -->
          <div class="mt-12 border border-[color:var(--jb-fire-border)] bg-[color:var(--jb-ink-2)] p-6">
            <div class="kicker mb-4" style="color: var(--jb-fire);">// CASO_RECUSADO · PLANOS_B</div>
            <ul class="space-y-2 font-sans text-[color:var(--jb-fg-2)]">
              <li><span class="text-acid">▶</span> Tentar com outro cartão</li>
              <li><span class="text-acid">▶</span> Pagar via PIX (confirmação instantânea)</li>
              <li><span class="text-acid">▶</span> Pagar via boleto (1-3 dias úteis)</li>
              <li><span class="text-acid">▶</span> Falar com a gente que a gente resolve</li>
            </ul>
          </div>

          <!-- CTAs -->
          <div class="mt-10 flex flex-wrap gap-4">
            <a
              href={getWhatsAppLink('Olá! Meu pagamento do Vendas Sem Segredos está em análise de crédito. Gostaria de saber o status.')}
              target="_blank"
              rel="noopener noreferrer"
              class="btn-primary min-h-[48px]"
            >
              <span>Falar com suporte</span>
              <span aria-hidden="true">→</span>
            </a>
            <a href="/vendas-sem-segredos#investimento" class="btn-secondary min-h-[48px]">Tentar outro pagamento</a>
          </div>

          <!-- Rodapé contato -->
          <div class="mt-12 border-t border-[color:var(--jb-hair)] pt-6 font-mono text-[11px] uppercase tracking-[0.22em] text-[color:var(--jb-fg-muted)]">
            WHATSAPP: {contactInfo.phone.display} &nbsp;·&nbsp; EMAIL: {contactInfo.email.main}
          </div>
        </div>
      </section>
    </Container>
  </main>

  <Footer />
</Layout>

<style>
  .status-display {
    font-family: var(--font-display);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: -0.045em;
    line-height: 0.92;
    font-size: clamp(2.5rem, 8vw, 5rem);
    color: var(--jb-cream);
    margin: 0;
  }
</style>
