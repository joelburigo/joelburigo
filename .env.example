# Copia pra .env.local e preenche só o que você precisa testar.
# Pra produção, use .env.tpl com 1Password CLI (ver infra/compose.joelburigo-site.yml).
# ===========================================================================

NODE_ENV=development
PORT=4321
PUBLIC_SITE_URL=http://localhost:4321

# Postgres local (via docker run):
#   docker run -d --name jb-pg -p 5432:5432 \
#     -e POSTGRES_PASSWORD=joelburigo -e POSTGRES_USER=joelburigo -e POSTGRES_DB=joelburigo \
#     pgvector/pgvector:pg16
DATABASE_URL=postgres://joelburigo:joelburigo@localhost:5432/joelburigo

# ---- LLM — começa só com OPENAI_API_KEY
LLM_PROVIDER=openai
LLM_MODEL_CHAT=gpt-5.2
LLM_MODEL_PREMIUM=gpt-5.2
LLM_MODEL_IMAGE=gpt-image-2
OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=

# ---- Pagamentos (opcionais em dev)
# MP_ACCESS_TOKEN=
# MP_PUBLIC_KEY=
# MP_WEBHOOK_SECRET=
# STRIPE_SECRET_KEY=
# STRIPE_PUBLIC_KEY=
# STRIPE_WEBHOOK_SECRET=

# ---- Cloudflare (R2 + Stream + Turnstile)
# CF_ACCOUNT_ID=
# CF_API_TOKEN=
# R2_BUCKET=joelburigo-artifacts
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_PUBLIC_URL=
# TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET_KEY=

# ---- Email (Brevo)
# BREVO_API_KEY=
EMAIL_FROM_TRANSACTIONAL=nao-responda@joelburigo.com.br
EMAIL_FROM_PERSONAL=joel@joelburigo.com.br
EMAIL_FROM_NAME="Joel Burigo"

# ---- n8n
# N8N_WEBHOOK_URL=

# ---- Sessão
# JWT_SECRET=dev-only-me-change-in-prod

# ---- Analytics (migrados do Astro)
PUBLIC_GTM_ID=
PUBLIC_META_PIXEL_ID=
GA4_MEASUREMENT_ID=
GA4_API_SECRET=
META_CAPI_ACCESS_TOKEN=
