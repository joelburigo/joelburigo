---
import Container from '../ui/Container.astro'
import { cases } from '../../data/cases'

// Filtrar 3 cases com badge "Destaque" (dados reais do repo)
const miniCases = cases
  .filter(c => c.badge === 'Destaque')
  .slice(0, 3)
  .map(c => ({
    empresa: c.empresa,
    nicho: c.nicho,
    antes: c.antes,
    depois: c.depois,
    tempo: c.tempo,
    destaque: c.crescimento,
  }))
---

<section class="proof-section section bg-ink relative overflow-hidden">
  <div class="grid-overlay"></div>

  <Container class="relative z-10">
    <!-- Section head -->
    <div class="section-head">
      <div class="kicker">// 03_PROVA</div>
      <div class="mono section-head-meta">RESULTADOS EM 20+ NICHOS VALIDADOS</div>
    </div>
    <div class="hair-divider"></div>

    <!-- Intro -->
    <div class="proof-intro">
      <h2 class="proof-title">
        NÚMERO NÃO <span class="text-fire">MENTE.</span><br />
        <span class="stroke-text">MARKETING</span> BONITO, SIM.
      </h2>
      <p class="proof-lede">
        17+ anos. 140+ clientes atendidos pessoalmente. <strong class="text-cream">~R$ 1 bilhão</strong> em vendas estruturadas como estimativa agregada. Base dos 6Ps aplicada — não é teoria, é cicatriz.
      </p>
    </div>

    <!-- Stats (brutalist grid) -->
    <div class="proof-stats">
      <div class="proof-stat">
        <div class="proof-stat-num text-acid">17+</div>
        <div class="proof-stat-label">Anos estruturando vendas</div>
      </div>
      <div class="proof-stat">
        <div class="proof-stat-num text-acid">140+</div>
        <div class="proof-stat-label">Clientes atendidos</div>
      </div>
      <div class="proof-stat">
        <div class="proof-stat-num text-acid">~R$ 1BI</div>
        <div class="proof-stat-label">Em vendas estruturadas</div>
      </div>
      <div class="proof-stat">
        <div class="proof-stat-num text-acid">20+</div>
        <div class="proof-stat-label">Nichos validados</div>
      </div>
    </div>

    <!-- Mini Cases -->
    <div class="proof-cases-head">
      <h3 class="proof-cases-title">TRANSFORMAÇÕES <span class="text-acid">REAIS</span></h3>
      <div class="mono proof-cases-meta">DADOS · SEM RETOQUE</div>
    </div>

    <div class="proof-cases-grid">
      {miniCases.map((c) => (
        <article class="proof-case">
          <div class="proof-case-nicho mono">// {c.nicho}</div>
          <h4 class="proof-case-empresa">{c.empresa}</h4>

          <div class="proof-case-flow">
            <div class="proof-case-row">
              <span class="mono proof-case-rowlabel">Antes</span>
              <span class="proof-case-val">{c.antes}</span>
            </div>
            <div class="proof-case-arrow" aria-hidden="true">▼</div>
            <div class="proof-case-row proof-case-row-after">
              <span class="mono proof-case-rowlabel">Depois</span>
              <span class="proof-case-val">{c.depois}</span>
            </div>
          </div>

          <div class="proof-case-foot">
            <span class="proof-case-delta text-acid">{c.destaque}</span>
            <span class="proof-case-tempo mono">em {c.tempo}</span>
          </div>
        </article>
      ))}
    </div>

    <div class="proof-footer">
      <a href="/cases" class="btn-secondary">
        <span>Ver todos os cases</span>
        <span aria-hidden="true">→</span>
      </a>
    </div>
  </Container>
</section>

<style>
  .section-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    margin-bottom: 1rem;
    flex-wrap: wrap;
  }
  .section-head-meta { font-size: 11px; color: var(--jb-fg-muted); }

  .proof-intro {
    padding-top: clamp(2rem, 4vw, 3rem);
    padding-bottom: clamp(2rem, 4vw, 3rem);
    max-width: 960px;
  }
  .proof-title {
    font-family: var(--font-display);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: -0.04em;
    line-height: 0.92;
    font-size: clamp(2.25rem, 6vw, 4rem);
    color: var(--jb-cream);
    margin: 0 0 1.5rem 0;
  }
  .proof-lede {
    font-family: var(--font-sans);
    font-size: clamp(1rem, 1.5vw, 1.125rem);
    line-height: 1.6;
    color: var(--jb-cream);
    text-transform: none;
    margin: 0;
    max-width: 60ch;
  }
  .proof-lede strong { font-weight: 700; }

  .proof-stats {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1px;
    background: var(--jb-hair);
    border: 1px solid var(--jb-hair);
    margin-bottom: clamp(3rem, 5vw, 4rem);
  }
  @media (min-width: 768px) { .proof-stats { grid-template-columns: repeat(4, 1fr); } }

  .proof-stat {
    background: var(--jb-ink-2);
    padding: 2rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    align-items: center;
    text-align: center;
  }
  .proof-stat-num {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: clamp(2.5rem, 5vw, 4rem);
    letter-spacing: -0.04em;
    line-height: 0.9;
  }
  .proof-stat-label {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--jb-fg-muted);
  }

  .proof-cases-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 1.5rem;
  }
  .proof-cases-title {
    font-family: var(--font-display);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: -0.03em;
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    color: var(--jb-cream);
    margin: 0;
  }
  .proof-cases-meta { font-size: 11px; color: var(--jb-fg-muted); }

  .proof-cases-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1px;
    background: var(--jb-hair);
    border: 1px solid var(--jb-hair);
    margin-bottom: clamp(2rem, 4vw, 3rem);
  }
  @media (min-width: 768px) { .proof-cases-grid { grid-template-columns: repeat(3, 1fr); } }

  .proof-case {
    background: var(--jb-ink-2);
    padding: 1.75rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    transition: background var(--transition-base);
  }
  .proof-case:hover { background: var(--jb-ink-3); }

  .proof-case-nicho {
    font-size: 11px;
    color: var(--jb-acid);
    letter-spacing: 0.22em;
  }
  .proof-case-empresa {
    font-family: var(--font-display);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: -0.02em;
    font-size: 1.125rem;
    line-height: 1.15;
    color: var(--jb-cream);
    margin: 0;
  }

  .proof-case-flow { display: flex; flex-direction: column; gap: 0.5rem; }
  .proof-case-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    padding: 0.75rem 0.875rem;
    border: 1px solid var(--jb-hair);
  }
  .proof-case-row-after {
    border-color: var(--jb-acid-border);
    background: var(--jb-acid-soft);
  }
  .proof-case-rowlabel {
    font-size: 10px;
    color: var(--jb-fg-muted);
    letter-spacing: 0.22em;
  }
  .proof-case-val {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 1rem;
    color: var(--jb-cream);
    text-transform: none;
  }
  .proof-case-row-after .proof-case-val { color: var(--jb-acid); }
  .proof-case-arrow {
    color: var(--jb-fire);
    font-size: 14px;
    text-align: center;
  }

  .proof-case-foot {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 0.5rem;
    padding-top: 0.75rem;
    border-top: 1px solid var(--jb-hair);
  }
  .proof-case-delta {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 1.125rem;
    letter-spacing: -0.02em;
  }
  .proof-case-tempo { font-size: 11px; color: var(--jb-fg-muted); }

  .proof-footer {
    display: flex;
    justify-content: center;
    padding-top: 1rem;
  }
</style>
