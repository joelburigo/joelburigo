---
// Slide 10 · VSS Overview — Hero do produto principal
import SlideShell from '../../SlideShell.astro'
---

<SlideShell
  variant="default"
  sbLeft="VSS · VENDAS SEM SEGREDOS"
  sbRight="// ★ PRINCIPAL · DIY PERPÉTUO"
  navLeft="★ 6PS EM 90 DIAS · GROWTH CRM INCLUÍDO"
  navRight="11 / 19 · → CONTEÚDO"
>
  <div class="vo-wrap">
    <div class="vo-left">
      <div class="vo-badge">★ PRINCIPAL</div>
      <div class="vo-kicker">// R$ 1.997 · À VISTA</div>
      <h1 class="vo-h1">
        <span class="stroke-text">VENDAS</span><br />
        <span class="acid">SEM</span> <span class="fire">SEGREDOS</span>
      </h1>
      <p class="vo-tag">DIY · 90 DIAS · GROWTH CRM INCLUÍDO</p>
      <p class="vo-sub">
        Programa perpétuo que implementa os <b>6Ps das Vendas Escaláveis</b>
        na tua empresa em 90 dias guiados.<br />
        Não é curso pra maratonar — é sistema pra ligar.
      </p>

      <div class="vo-stack">
        <span>▶ Playbook 6Ps (acesso vitalício)</span>
        <span>▶ 48 mentorias ao vivo com Joel</span>
        <span>▶ Growth CRM incluído (12 meses)</span>
        <span>▶ Templates, scripts e comunidade</span>
      </div>
    </div>

    <div class="vo-right">
      <div class="vo-price-card">
        <div class="vo-price-tag">// INVESTIMENTO</div>
        <div class="vo-price">R$ 1.997</div>
        <div class="vo-price-alt">ou 12× R$ 166,42</div>
        <hr class="vo-div" />
        <div class="vo-value-row">
          <span>Stack empilhada</span>
          <b>R$ 17.287</b>
        </div>
        <div class="vo-value-row vo-value-row-hi">
          <span>Você paga</span>
          <b class="acid">R$ 1.997</b>
        </div>
        <div class="vo-warranty">★ 7 DIAS · GARANTIA INCONDICIONAL</div>
      </div>
    </div>
  </div>
</SlideShell>

<style>
  .vo-wrap {
    display: grid;
    grid-template-columns: 1.3fr 1fr;
    gap: 60px;
    align-items: center;
    height: 100%;
  }
  .vo-badge {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.28em;
    color: var(--jb-acid);
    border: 1px solid var(--jb-acid);
    padding: 6px 10px;
    margin-bottom: 16px;
    text-transform: uppercase;
  }
  .vo-kicker {
    font-family: var(--font-mono);
    font-size: clamp(12px, 1vw, 16px);
    letter-spacing: 0.32em;
    color: var(--jb-acid);
    text-transform: uppercase;
    margin-bottom: 14px;
  }
  .vo-h1 {
    font-family: var(--font-display);
    font-size: clamp(56px, 8vw, 150px);
    line-height: 0.9;
    letter-spacing: -0.05em;
    text-transform: uppercase;
    color: var(--jb-cream);
    margin: 0;
  }
  .vo-h1 .fire { color: var(--jb-fire); }
  .vo-h1 .acid { color: var(--jb-acid); }

  .vo-tag {
    margin-top: 18px;
    font-family: var(--font-mono);
    font-size: clamp(12px, 1vw, 16px);
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--jb-cream);
  }
  .vo-sub {
    margin-top: 20px;
    font-size: clamp(13px, 1.1vw, 19px);
    line-height: 1.55;
    color: var(--jb-fg-3);
    max-width: 680px;
  }
  .vo-sub b { color: var(--jb-cream); }

  .vo-stack {
    margin-top: 24px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px 20px;
    font-family: var(--font-mono);
    font-size: clamp(11px, 0.85vw, 13px);
    letter-spacing: 0.14em;
    color: var(--jb-fg-2);
    text-transform: uppercase;
  }

  .vo-price-card {
    background: linear-gradient(180deg, rgba(198, 255, 0, 0.08), var(--jb-ink-2));
    border: 2px solid var(--jb-acid);
    padding: 36px 32px;
    box-shadow: 8px 8px 0 var(--jb-fire);
  }
  .vo-price-tag {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.28em;
    color: var(--jb-acid);
    text-transform: uppercase;
  }
  .vo-price {
    margin-top: 8px;
    font-family: var(--font-display);
    font-size: clamp(54px, 5.5vw, 96px);
    letter-spacing: -0.04em;
    color: var(--jb-cream);
    line-height: 0.95;
  }
  .vo-price-alt {
    margin-top: 6px;
    font-family: var(--font-mono);
    font-size: 14px;
    letter-spacing: 0.18em;
    color: var(--jb-fg-3);
    text-transform: uppercase;
  }
  .vo-div {
    border: 0;
    border-top: 1px solid var(--jb-hair);
    margin: 20px 0;
  }
  .vo-value-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    font-family: var(--font-mono);
    font-size: 13px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--jb-fg-3);
    margin-bottom: 10px;
  }
  .vo-value-row b { color: var(--jb-cream); font-family: var(--font-display); font-size: 18px; }
  .vo-value-row .acid { color: var(--jb-acid); }
  .vo-value-row-hi b { font-size: 22px; }
  .vo-warranty {
    margin-top: 18px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.22em;
    color: var(--jb-fg-muted);
    text-transform: uppercase;
    padding-top: 14px;
    border-top: 1px dashed var(--jb-hair);
  }

  @media (max-width: 1024px) {
    .vo-wrap { grid-template-columns: 1fr; gap: 32px; align-content: start; overflow-y: auto; }
    .vo-stack { grid-template-columns: 1fr; }
  }
</style>
