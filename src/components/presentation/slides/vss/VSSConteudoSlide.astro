---
// Slide 11 · VSS Conteúdo — 15 módulos / 7 fases / 66 destravamentos
import SlideShell from '../../SlideShell.astro'

const fases = [
  { n: 'F1', t: 'FUNDAÇÃO', d: 'Posicionamento e público · P1-P2' },
  { n: 'F2', t: 'OFERTA', d: 'Produto e pricing · P3' },
  { n: 'F3', t: 'MARKETING', d: 'Geração de demanda · P4' },
  { n: 'F4', t: 'VENDAS', d: 'Conversão e funil · P4' },
  { n: 'F5', t: 'OPERAÇÃO', d: 'SOPs e processos · P5' },
  { n: 'F6', t: 'TIME', d: 'Pessoas e cultura · P6' },
  { n: 'F7', t: 'ESCALA', d: 'Crescimento previsível' },
]
---

<SlideShell
  variant="default"
  sbLeft="VSS · ARQUITETURA DO PROGRAMA"
  sbRight="// 15 · 7 · 66"
  navLeft="★ CADA DESTRAVAMENTO = UMA ENGRENAGEM"
  navRight="12 / 19 · → TRANSFORMAÇÃO"
>
  <div class="vc-wrap">
    <div class="vc-head">
      <div class="vc-kicker">// O QUE ESTÁ DENTRO</div>
      <h2 class="vc-h2">
        <span class="stroke-text">15</span> MÓDULOS ·
        <span class="acid">7</span> FASES ·<br />
        <span class="fire">66</span> DESTRAVAMENTOS
      </h2>
      <p class="vc-sub">
        Playbook sequenciado. Cada fase destrava a próxima.<br />
        <b>Não é curso pra assistir. É sistema pra implementar.</b>
      </p>
    </div>

    <div class="vc-grid">
      {fases.map((f) => (
        <div class="vc-card">
          <div class="vc-n">{f.n}</div>
          <div class="vc-t">{f.t}</div>
          <div class="vc-d">{f.d}</div>
        </div>
      ))}
    </div>

    <div class="vc-stats">
      <div class="vc-stat">
        <div class="vc-sv">90<span>dias</span></div>
        <div class="vc-sl">// PRAZO GUIADO</div>
      </div>
      <div class="vc-stat">
        <div class="vc-sv">48<span>/ano</span></div>
        <div class="vc-sl">// MENTORIAS AO VIVO</div>
      </div>
      <div class="vc-stat">
        <div class="vc-sv">12<span>meses</span></div>
        <div class="vc-sl">// GROWTH CRM INCLUÍDO</div>
      </div>
    </div>
  </div>
</SlideShell>

<style>
  .vc-wrap {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 32px;
    height: 100%;
  }
  .vc-kicker {
    font-family: var(--font-mono);
    font-size: clamp(12px, 1vw, 16px);
    letter-spacing: 0.32em;
    color: var(--jb-acid);
    text-transform: uppercase;
    margin-bottom: 12px;
  }
  .vc-h2 {
    font-family: var(--font-display);
    font-size: clamp(36px, 5vw, 82px);
    line-height: 0.95;
    letter-spacing: -0.035em;
    text-transform: uppercase;
    color: var(--jb-cream);
    margin: 0;
  }
  .vc-h2 .acid { color: var(--jb-acid); }
  .vc-h2 .fire { color: var(--jb-fire); }
  .vc-sub {
    margin-top: 14px;
    font-size: clamp(13px, 1.1vw, 18px);
    line-height: 1.5;
    color: var(--jb-fg-3);
    max-width: 800px;
  }
  .vc-sub b { color: var(--jb-cream); }

  .vc-grid {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 12px;
  }
  .vc-card {
    background: var(--jb-ink-2);
    border: 1px solid var(--jb-hair);
    padding: 20px 16px;
    text-align: center;
  }
  .vc-n {
    font-family: var(--font-display);
    font-size: clamp(28px, 2.4vw, 42px);
    color: var(--jb-acid);
    letter-spacing: -0.04em;
    line-height: 0.9;
  }
  .vc-t {
    margin-top: 10px;
    font-family: var(--font-display);
    font-size: clamp(13px, 1vw, 16px);
    text-transform: uppercase;
    letter-spacing: -0.01em;
    color: var(--jb-cream);
  }
  .vc-d {
    margin-top: 8px;
    font-family: var(--font-mono);
    font-size: clamp(9px, 0.7vw, 11px);
    letter-spacing: 0.16em;
    color: var(--jb-fg-muted);
    text-transform: uppercase;
    line-height: 1.4;
  }

  .vc-stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    margin-top: 8px;
  }
  .vc-stat {
    border-left: 3px solid var(--jb-acid);
    padding: 14px 20px;
    background: var(--jb-ink-2);
  }
  .vc-sv {
    font-family: var(--font-display);
    font-size: clamp(32px, 3.5vw, 58px);
    color: var(--jb-cream);
    letter-spacing: -0.04em;
    line-height: 0.95;
  }
  .vc-sv span {
    font-family: var(--font-mono);
    font-size: clamp(11px, 0.9vw, 14px);
    letter-spacing: 0.22em;
    color: var(--jb-fg-muted);
    margin-left: 6px;
    vertical-align: baseline;
  }
  .vc-sl {
    margin-top: 4px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.22em;
    color: var(--jb-fg-muted);
    text-transform: uppercase;
  }

  @media (max-width: 1024px) {
    .vc-grid { grid-template-columns: repeat(3, 1fr); }
    .vc-stats { grid-template-columns: 1fr; }
  }
  @media (max-width: 640px) {
    .vc-grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>
