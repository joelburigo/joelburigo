---
import Container from '../ui/Container.astro'

const ps = [
  {
    id: 'P1',
    name: 'Posicionamento',
    subtitle: 'Por quê?',
    desc: 'Como você se diferencia. Base estratégica que define por que você existe.',
  },
  {
    id: 'P2',
    name: 'Público',
    subtitle: 'Pra quem?',
    desc: 'ICP definido = comunicação certeira. Leads qualificados e quantificados.',
  },
  {
    id: 'P3',
    name: 'Produto',
    subtitle: 'O quê?',
    desc: 'Oferta irresistível. Produto bem embalado se vende sozinho.',
  },
  {
    id: 'P4',
    name: 'Programas',
    subtitle: 'Como vender?',
    desc: 'CRM, funis e automação. Sistema pra atrair e converter com previsibilidade.',
  },
  {
    id: 'P5',
    name: 'Processos',
    subtitle: 'Como operar?',
    desc: 'Documentado e escalável. Funciona sem depender de uma pessoa.',
  },
  {
    id: 'P6',
    name: 'Pessoas',
    subtitle: 'Quem executa?',
    desc: 'Time alinhado que entrega. Dono sai da operação.',
  },
]
---

<section class="framework-section section bg-ink relative overflow-hidden">
  <div class="grid-overlay"></div>

  <Container class="relative z-10">
    <!-- Section head -->
    <div class="section-head">
      <div class="kicker">// 02_FRAMEWORK</div>
      <div class="mono section-head-meta">OS 6PS DAS VENDAS ESCALÁVEIS</div>
    </div>
    <div class="hair-divider"></div>

    <!-- Intro -->
    <div class="fw-intro">
      <h2 class="fw-title">
        FRAMEWORK <span class="text-acid">6PS</span><br />
        DAS <span class="stroke-text">VENDAS</span> ESCALÁVEIS.
      </h2>
      <p class="fw-lede">
        Seis engrenagens. Uma Máquina de Crescimento. Testada em 140+ empresas em 20+ nichos. Pula um P e trava o crescimento — é assim que funciona.
      </p>
    </div>

    <!-- Grid 6Ps (brutalist: sem gap, borda externa + divisores) -->
    <div class="ps-grid">
      {ps.map((p) => (
        <article class="p-card">
          <div class="p-num">{p.id}</div>
          <div class="p-body">
            <div class="p-subtitle mono">{p.subtitle}</div>
            <h3 class="p-name">{p.name}</h3>
            <p class="p-desc">{p.desc}</p>
          </div>
          <div class="p-scanline"></div>
        </article>
      ))}
    </div>

    <!-- Footer CTA -->
    <div class="fw-footer">
      <p class="fw-assinatura mono">
        <span class="text-acid">★</span>&nbsp;&nbsp;SISTEMA <span class="text-fire">&gt;</span> IMPROVISO
      </p>
      <a href="/framework-6ps" class="btn-primary">
        <span>Ver framework completo</span>
        <span aria-hidden="true">→</span>
      </a>
    </div>
  </Container>
</section>

<style>
  .section-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    margin-bottom: 1rem;
    flex-wrap: wrap;
  }
  .section-head-meta { font-size: 11px; color: var(--jb-fg-muted); }

  .fw-intro {
    padding-top: clamp(2rem, 4vw, 3rem);
    padding-bottom: clamp(2rem, 4vw, 3rem);
    max-width: 960px;
  }
  .fw-title {
    font-family: var(--font-display);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: -0.04em;
    line-height: 0.92;
    font-size: clamp(2.25rem, 6.5vw, 4.5rem);
    color: var(--jb-cream);
    margin: 0 0 1.5rem 0;
  }
  .fw-lede {
    font-family: var(--font-sans);
    font-size: clamp(1rem, 1.5vw, 1.125rem);
    line-height: 1.6;
    color: var(--jb-cream);
    text-transform: none;
    margin: 0;
    max-width: 60ch;
  }

  /* 6Ps grid brutalist */
  .ps-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1px;
    background: var(--jb-hair);
    border: 1px solid var(--jb-hair);
    margin-bottom: clamp(3rem, 5vw, 4rem);
  }
  @media (min-width: 768px) { .ps-grid { grid-template-columns: repeat(3, 1fr); } }
  @media (min-width: 1280px) { .ps-grid { grid-template-columns: repeat(6, 1fr); } }

  .p-card {
    background: var(--jb-ink-2);
    padding: 1.75rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    position: relative;
    overflow: hidden;
    transition: background var(--transition-base);
    min-height: 280px;
  }
  .p-card:hover { background: rgba(198, 255, 0, 0.03); }
  .p-card:hover .p-num { color: var(--jb-acid); text-shadow: 0 0 20px var(--jb-acid-glow); }
  .p-card:hover .p-scanline { transform: scaleX(1); }

  .p-num {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: clamp(3.5rem, 6vw, 5rem);
    letter-spacing: -0.04em;
    line-height: 0.85;
    color: rgba(245, 241, 232, 0.14);
    transition: color var(--transition-base), text-shadow var(--transition-base);
  }

  .p-body { display: flex; flex-direction: column; gap: 0.5rem; flex: 1; }

  .p-subtitle {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.24em;
    color: var(--jb-acid);
    text-transform: uppercase;
  }

  .p-name {
    font-family: var(--font-display);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: -0.02em;
    font-size: 1.0625rem;
    line-height: 1.15;
    color: var(--jb-cream);
    margin: 0;
  }

  .p-desc {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    line-height: 1.5;
    color: var(--jb-fg-2);
    margin: 0;
    text-transform: none;
  }

  .p-scanline {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: var(--jb-acid);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform var(--transition-base);
  }

  .fw-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    flex-wrap: wrap;
    padding-top: 1rem;
  }
  .fw-assinatura {
    font-size: 12px;
    letter-spacing: 0.28em;
    color: var(--jb-fg-muted);
  }
</style>
