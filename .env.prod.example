# ============================================================================
# joelburigo-site — PRODUÇÃO
#
# Template pra criar `.env.prod` (gitignored) com valores prod-específicos.
# Usado por: node scripts/cf-secrets-from-env.mjs prod
#
# Convenção:
# - 🔴 OBRIGATÓRIO separado de dev (segurança/cobrança)
# - 🟡 Opcional separado (recomendado pra rastreio de custo/qualidade)
# - 🟢 Pode compartilhar com dev (mesmo asset/ID em ambos)
# ============================================================================

# ----------------------------------------------------------------------------
# Sessão / Auth — 🔴 OBRIGATÓRIO ROTACIONAR pra prod
# Gerar: openssl rand -base64 32
# ----------------------------------------------------------------------------
JWT_SECRET=COLOQUE_AQUI_UM_NOVO_SECRET_GERADO

# ----------------------------------------------------------------------------
# LLM — 🟡 ideal separar pra rastreio de custo
# OpenAI dashboard: criar nova API key dedicada pra produção
# ----------------------------------------------------------------------------
OPENAI_API_KEY=sk-proj-PROD_KEY_AQUI
ANTHROPIC_API_KEY=

LLM_PROVIDER=openai
LLM_MODEL_CHAT=gpt-5.2
LLM_MODEL_PREMIUM=gpt-5.2
LLM_MODEL_IMAGE=gpt-image-2

# ----------------------------------------------------------------------------
# Pagamentos — 🔴 OBRIGATÓRIO usar tokens REAIS de produção
# Mercado Pago painel: pegar credenciais "Produção" (APP_USR-...)
# ----------------------------------------------------------------------------
MP_ACCESS_TOKEN=APP_USR-PROD_AQUI
MP_PUBLIC_KEY=APP_USR-PROD_AQUI
MP_WEBHOOK_SECRET=PROD_WEBHOOK_SECRET_AQUI

# Stripe — 🔴 sk_live se usar internacional
STRIPE_SECRET_KEY=
STRIPE_PUBLIC_KEY=
STRIPE_WEBHOOK_SECRET=

# ----------------------------------------------------------------------------
# Email — 🟡 pode separar API key (rastreio de remetente prod)
# Brevo dashboard: criar API key separada pra prod
# ----------------------------------------------------------------------------
BREVO_API_KEY=xkeysib-PROD_KEY_AQUI
EMAIL_FROM_TRANSACTIONAL=nao-responda@joelburigo.com.br
EMAIL_FROM_PERSONAL=joel@joelburigo.com.br
EMAIL_FROM_NAME=Joel Burigo

# ----------------------------------------------------------------------------
# Cloudflare Turnstile — 🟢 pode compartilhar dev=prod se o site cadastrado
# tem ambos os hostnames (joelburigo.com.br + dev.joelburigo.com.br ou wildcard)
# Se ainda não, registrar dev.joelburigo.com.br no mesmo site no painel.
# ----------------------------------------------------------------------------
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ----------------------------------------------------------------------------
# Cloudflare R2 — 🔴 OBRIGATÓRIO bucket diferente em prod
# ----------------------------------------------------------------------------
R2_BUCKET=joelburigo-artifacts
R2_PUBLIC_URL=https://media.joelburigo.com.br
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
CF_ACCOUNT_ID=
CF_API_TOKEN=

# ----------------------------------------------------------------------------
# Cloudflare Stream — 🟢 mesmo customer code (conta única)
# ----------------------------------------------------------------------------
CF_STREAM_CUSTOMER_CODE=

# ----------------------------------------------------------------------------
# WhatsApp Evolution — 🟢 pode compartilhar (mesma instância)
# ----------------------------------------------------------------------------
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=joelburigo

# ----------------------------------------------------------------------------
# n8n — 🟢 mesma instância
# ----------------------------------------------------------------------------
N8N_WEBHOOK_URL=

# ----------------------------------------------------------------------------
# Analytics — 🟢 mesma propriedade GA/Meta (rastreia tudo no mesmo lugar)
# ----------------------------------------------------------------------------
PUBLIC_GTM_ID=GTM-TWP4J6N8
GA4_MEASUREMENT_ID=G-Z2XMZ448VV
GA4_API_SECRET=PSUsjCRHSD6CFuTDqn-pIA
PUBLIC_META_PIXEL_ID=693646216957142
META_CAPI_ACCESS_TOKEN=

# ----------------------------------------------------------------------------
# Sentry — 🟡 ideal projeto separado pra prod
# ----------------------------------------------------------------------------
SENTRY_DSN=

# ----------------------------------------------------------------------------
# Áudio TTS — 🟢 só pro script local, nem vai pro Worker
# ----------------------------------------------------------------------------
ELEVENLABS_API_KEY=
