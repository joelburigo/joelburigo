---
import Container from '../ui/Container.astro'

const stats = [
  { value: '17+', label: 'Anos estruturando vendas', accent: 'acid' },
  { value: '140+', label: 'Clientes atendidos', accent: 'fire' },
  { value: '~R$ 1BI', label: 'Em vendas estruturadas', accent: 'acid' },
  { value: '20+', label: 'Nichos validados', accent: 'fire' },
]
---

<section class="stats-section relative overflow-hidden bg-ink">
  <div class="grid-overlay"></div>

  <Container class="relative z-10">
    <!-- Ticker de assinatura no topo -->
    <div class="stats-head">
      <div class="kicker">// 05_NÚMEROS</div>
      <div class="mono stats-head-meta">
        <span class="dot-live"></span>&nbsp;&nbsp;DADOS AGREGADOS · 2008→2026
      </div>
    </div>
    <div class="hair-divider"></div>

    <!-- Stats gigantes -->
    <div class="stats-grid">
      {stats.map((s) => (
        <div class="stat-block">
          <div class={`stat-value ${s.accent === 'acid' ? 'text-acid' : 'text-fire'}`}>
            {s.value}
          </div>
          <div class="stat-label mono">{s.label}</div>
        </div>
      ))}
    </div>

    <!-- Assinatura -->
    <div class="stats-signature">
      <span class="mono">
        <span class="text-acid">★</span>&nbsp;&nbsp;DA QUEBRADA AO BILHÃO · SEM ENROLAÇÃO
      </span>
    </div>
  </Container>
</section>

<style>
  .stats-section {
    padding-top: clamp(3rem, 6vw, 5rem);
    padding-bottom: clamp(3rem, 6vw, 5rem);
    border-top: 1px solid var(--jb-hair);
    border-bottom: 1px solid var(--jb-hair);
  }

  .stats-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1rem;
    flex-wrap: wrap;
  }
  .stats-head-meta {
    font-size: 11px;
    color: var(--jb-fg-muted);
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1px;
    background: var(--jb-hair);
    border: 1px solid var(--jb-hair);
    margin: clamp(2rem, 4vw, 3rem) 0;
  }
  @media (min-width: 768px) { .stats-grid { grid-template-columns: repeat(4, 1fr); } }

  .stat-block {
    background: var(--jb-ink);
    padding: clamp(1.75rem, 4vw, 3rem) clamp(1rem, 2vw, 1.5rem);
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.75rem;
    min-height: 180px;
    justify-content: center;
    transition: background var(--transition-base);
  }
  .stat-block:hover { background: var(--jb-ink-2); }

  .stat-value {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: clamp(3rem, 8vw, 6rem);
    letter-spacing: -0.05em;
    line-height: 0.85;
    word-break: break-word;
  }

  .stat-label {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--jb-fg-muted);
    line-height: 1.3;
  }

  .stats-signature {
    text-align: center;
    font-size: 11px;
    letter-spacing: 0.28em;
  }
</style>
