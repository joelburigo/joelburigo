---
interface Props {
  for: string
  required?: boolean
  class?: string
}

const {
  for: htmlFor,
  required = false,
  class: className = '',
} = Astro.props
---

<label
  for={htmlFor}
  class={`block font-mono text-[11px] uppercase tracking-[0.22em] font-bold text-[color:var(--jb-fg-muted)] mb-2 ${className}`}
>
  <slot />
  {required && <span class="text-[color:var(--jb-fire)]">*</span>}
</label>
