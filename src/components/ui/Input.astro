---
interface Props {
  type?: 'text' | 'email' | 'tel' | 'number' | 'url'
  placeholder?: string
  name: string
  id?: string
  required?: boolean
  class?: string
}

const {
  type = 'text',
  placeholder,
  name,
  id,
  required = false,
  class: className = '',
} = Astro.props
---

<input
  type={type}
  name={name}
  id={id || name}
  placeholder={placeholder}
  required={required}
  class={`w-full px-4 py-3 rounded-none bg-[color:var(--jb-ink-2)] border border-[color:var(--jb-hair)] text-[color:var(--jb-cream)] placeholder:text-[color:var(--jb-fg-muted)] focus:border-[color:var(--jb-acid)] focus:outline-none focus:ring-1 focus:ring-[color:var(--jb-acid)] transition-colors duration-[var(--jb-dur)] text-base ${className}`}
/>
