---
import Layout from '../layouts/Layout.astro'
import Header from '../components/layout/Header.astro'
import Footer from '../components/layout/Footer.astro'
import Container from '../components/ui/Container.astro'

const seo = {
  title: 'Agendar Sessão Estratégica — Advisory | Joel Burigo',
  description: 'Sessão estratégica 1:1 de 90 min. Diagnóstico 6Ps + plano de ação com 3-5 prioridades. R$ 997.',
  keywords: 'sessão estratégica, advisory, Joel Burigo, agendamento',
}
---

<Layout title={seo.title} description={seo.description} keywords={seo.keywords} noIndex={true}>
  <Header />

  <main class="relative overflow-hidden bg-ink pt-20">
    <div class="grid-overlay"></div>

    <Container class="relative z-10">
      <section class="py-16 md:py-24">
        <div class="mx-auto max-w-5xl">
          <!-- Hero -->
          <div class="mb-12">
            <div class="kicker mb-6">// ADVISORY · SESSÃO · 90_MIN · R$ 997</div>
            <h1 class="tg-display">
              Agendar <span class="text-acid">Sessão.</span>
            </h1>
            <p class="mt-6 max-w-2xl font-sans text-lg text-[color:var(--jb-cream)]">
              Escolhe o melhor horário pra tua sessão estratégica de 90 minutos. Máximo 4 sessões/mês na agenda.
            </p>
          </div>

          <!-- Info cards -->
          <div class="mb-10 grid gap-6 md:grid-cols-3">
            <div class="card">
              <div class="kicker mb-3">// DURAÇÃO</div>
              <div class="font-display text-3xl text-[color:var(--jb-cream)]">90 min</div>
            </div>
            <div class="card">
              <div class="kicker mb-3">// DISPONIBILIDADE</div>
              <div class="font-display text-3xl text-[color:var(--jb-cream)]">4/mês</div>
            </div>
            <div class="card" style="border-color: var(--jb-acid-border);">
              <div class="kicker mb-3" style="color: var(--jb-acid);">// INVESTIMENTO</div>
              <div class="font-display text-3xl text-acid">R$ 997</div>
            </div>
          </div>

          <!-- Incluído -->
          <div class="mb-10 border border-[color:var(--jb-acid-border)] bg-[color:var(--jb-ink-2)] p-8">
            <div class="kicker mb-4" style="color: var(--jb-acid);">// INCLUÍDO</div>
            <ul class="grid gap-3 md:grid-cols-2">
              {[
                '90 minutos de consultoria ao vivo 1:1',
                'Análise profunda do desafio atual',
                'Diagnóstico rápido dos 6Ps',
                'Plano de ação (3-5 ações prioritárias)',
                'Gravação da sessão',
                'Relatório executivo 2–3 páginas',
              ].map((item) => (
                <li class="flex items-start gap-3 font-sans text-[color:var(--jb-fg-2)]">
                  <span class="mt-[3px] shrink-0 text-acid">▶</span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>

          <!-- Booking widget -->
          <div class="border border-[color:var(--jb-hair)] bg-[color:var(--jb-ink-2)] p-4">
            <div class="kicker mb-4 px-2 pt-2">// CALENDÁRIO · ESCOLHA_HORÁRIO</div>
            <div id="booking-container" class="min-h-[600px]">
              <div id="booking-loading" class="flex min-h-[600px] items-center justify-center">
                <div class="text-center">
                  <div class="mb-4 inline-block h-10 w-10 animate-spin border-2 border-[color:var(--jb-hair)] border-t-[color:var(--jb-acid)]"></div>
                  <p class="font-mono text-[11px] uppercase tracking-[0.22em] text-[color:var(--jb-fg-muted)]">
                    Carregando calendário...
                  </p>
                </div>
              </div>
              <div id="booking-iframe-wrapper" class="hidden"></div>
            </div>
          </div>

          <!-- Voltar -->
          <div class="mt-10">
            <a href="/advisory" class="font-mono text-[12px] uppercase tracking-[0.22em] text-[color:var(--jb-fg-3)] hover:text-acid">
              ← Voltar pra Advisory
            </a>
          </div>
        </div>
      </section>
    </Container>
  </main>

  <Footer />
</Layout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const container = document.getElementById('booking-iframe-wrapper')
    const loading = document.getElementById('booking-loading')
    if (!container || !loading) return

    const iframe = document.createElement('iframe')
    iframe.src = 'https://api.gsh.digital/widget/booking/IxxmHsXDAkSzsx3C6SyE'
    iframe.style.cssText = 'width: 100%; border: none; overflow: hidden; min-height: 600px;'
    iframe.id = 'IxxmHsXDAkSzsx3C6SyE_' + Date.now()
    iframe.onload = () => {
      loading.classList.add('hidden')
      container.classList.remove('hidden')
    }
    container.appendChild(iframe)

    const script = document.createElement('script')
    script.src = 'https://api.gsh.digital/js/form_embed.js'
    script.type = 'text/javascript'
    document.body.appendChild(script)
  })
</script>

<style>
  .tg-display {
    font-family: var(--font-display);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: -0.045em;
    line-height: 0.92;
    font-size: clamp(2.5rem, 7vw, 4.5rem);
    color: var(--jb-cream);
    margin: 0;
  }
</style>
