---
import HighLevelForm from '../ui/HighLevelForm.astro'
import Container from '../ui/Container.astro'
import Breadcrumbs from '../seo/Breadcrumbs.astro'

interface BreadcrumbItem {
  label: string
  href: string
}

interface Props {
  breadcrumbItems?: BreadcrumbItem[]
}

const { breadcrumbItems } = Astro.props

// Diagnóstico 6Ps — tom direto, provocador. Base: copy-bank §1.2 + 01-marca §01.9 (7 inimigos)
// Form HighLevel intocado — só wrapper visual Terminal Growth
---

<section class="relative min-h-screen overflow-hidden bg-ink pb-20 pt-32">
  <div class="grid-overlay"></div>

  <Container width="narrow">
    {breadcrumbItems && <Breadcrumbs items={breadcrumbItems} class="mb-5" />}
    <!-- Status bar -->
    <div class="mb-10 border border-white/10 bg-ink-2">
      <div class="flex flex-wrap items-center justify-between gap-3 px-4 py-3 md:px-6">
        <div class="flex items-center gap-3">
          <span class="dot-live"></span>
          <span class="mono text-acid">SYS ONLINE · DIAGNÓSTICO 6PS</span>
        </div>
        <div class="mono text-fg-muted">10 MIN · GRÁTIS · SEM ENROLAÇÃO</div>
      </div>
    </div>

    <!-- Hero -->
    <div class="mb-12">
      <div class="kicker mb-4">// DIAGNÓSTICO · 24 PERGUNTAS · 6 PILARES</div>
      <h1 class="mb-6 font-display text-cream" style="font-size: clamp(2.25rem, 6vw, 4.5rem); line-height: 0.9; letter-spacing: -0.045em; text-transform: uppercase;">
        Tua empresa é <span class="text-fire">empresa</span>
        <br />ou é <span class="stroke-text">emprego</span>?
      </h1>
      <p class="mb-6 font-sans text-cream/85" style="font-size: clamp(1.05rem, 2vw, 1.25rem); line-height: 1.5;">
        Diagnóstico baseado numa prática aplicada em <strong class="text-cream">140+ empresas</strong> em <strong class="text-cream">17+ anos</strong>. 24 perguntas, raio-x dos <span class="text-acid">6Ps das Vendas Escaláveis</span>, score de 0–30 — identifica em minutos qual P está travando a Máquina.
      </p>

      <!-- Bloco de honestidade -->
      <div class="mb-8 border-l-4 border-fire bg-fire/5 p-5">
        <div class="mono mb-2 text-fire">// na moral</div>
        <p class="font-sans text-cream" style="font-size: 1rem; line-height: 1.55;">
          Não é teste de certo ou errado. É <strong class="text-cream">radiografia real</strong> do que impede tua empresa de escalar. <strong class="text-cream">Responde com sinceridade</strong> — maquiar diagnóstico é improvisar cura. E improviso mata mais empresa que crise.
        </p>
      </div>

      <!-- Prova social em tira -->
      <div class="grid gap-3 border border-white/10 bg-ink-2 md:grid-cols-3">
        <div class="p-5" style="border-right: 1px solid var(--jb-hair);">
          <div class="font-display text-acid" style="font-size: 2rem; line-height: 1; letter-spacing: -0.035em;">140+</div>
          <div class="mono mt-2 text-fg-muted">clientes atendidos</div>
        </div>
        <div class="p-5" style="border-right: 1px solid var(--jb-hair);">
          <div class="font-display text-acid" style="font-size: 2rem; line-height: 1; letter-spacing: -0.035em;">17+</div>
          <div class="mono mt-2 text-fg-muted">anos de experiência</div>
        </div>
        <div class="p-5">
          <div class="font-display text-acid" style="font-size: 2rem; line-height: 1; letter-spacing: -0.035em;">~R$ 1BI</div>
          <div class="mono mt-2 text-fg-muted">em vendas estruturadas</div>
        </div>
      </div>
    </div>

    <!-- Form wrapper terminal -->
    <div class="border border-white/10 bg-ink-2">
      <!-- Chrome tipo terminal -->
      <div class="flex items-center gap-2 border-b border-white/10 px-4 py-3">
        <span class="inline-block h-3 w-3 bg-fire"></span>
        <span class="inline-block h-3 w-3" style="background: #FFB020;"></span>
        <span class="inline-block h-3 w-3 bg-acid"></span>
        <span class="mono ml-3 text-fg-muted">&gt; diagnostico_6ps.run</span>
      </div>
      <!-- Form -->
      <div class="p-4 md:p-6">
        <HighLevelForm
          formId="LiMgJuffsmbXgFNyyil9"
          height="1726px"
        />
      </div>
    </div>

    <!-- Rodapé manifesto -->
    <div class="mt-10 text-center">
      <p class="mono text-fg-muted">
        ★ SISTEMA &gt; IMPROVISO · @joelburigo · FLORIANÓPOLIS/SC
      </p>
    </div>
  </Container>
</section>
