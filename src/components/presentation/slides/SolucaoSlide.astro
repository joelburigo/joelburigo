---
// Slide 3 · SOLUÇÃO — Apresentação dos 6Ps como framework
import SlideShell from '../SlideShell.astro'
---

<SlideShell
  variant="default"
  sbLeft="FRAMEWORK · 6PS DAS VENDAS ESCALÁVEIS"
  sbRight="// ▶ SOLUÇÃO"
  navLeft="★ TESTADO EM 140+ CLIENTES · ~R$ 1 BILHÃO"
  navRight="04 / 19 · → PRÓXIMO"
>
  <div class="sol-wrap">
    <div class="sol-kicker">// METODOLOGIA PROPRIETÁRIA</div>
    <h1 class="sol-h1">
      <span class="stroke-text">6PS</span><br />
      <span class="fire">DAS VENDAS</span><br />
      <span class="acid">ESCALÁVEIS</span>
    </h1>
    <p class="sol-sub">
      Marketing + Vendas + Growth integrados em <b>sistema replicável</b>.<br />
      Cada P nasceu de cicatriz real — erro ou acerto, nunca teoria.
    </p>

    <div class="sol-pills">
      <div class="pill"><b>P1</b> Posicionamento</div>
      <div class="pill"><b>P2</b> Público</div>
      <div class="pill"><b>P3</b> Produto</div>
      <div class="pill pill-op"><b>P4</b> Programas</div>
      <div class="pill pill-op"><b>P5</b> Processos</div>
      <div class="pill pill-op"><b>P6</b> Pessoas</div>
    </div>

    <div class="sol-legend">
      <span class="lg lg-fd">▲ P1-P3 · FUNDAÇÃO</span>
      <span class="lg lg-op">▼ P4-P6 · OPERAÇÃO &amp; ESCALA</span>
    </div>
  </div>
</SlideShell>

<style>
  .sol-wrap {
    display: flex;
    flex-direction: column;
    justify-content: center;
    height: 100%;
    max-width: 1400px;
    margin: 0 auto;
  }
  .sol-kicker {
    font-family: var(--font-mono);
    font-size: clamp(12px, 1vw, 18px);
    letter-spacing: 0.32em;
    color: var(--jb-acid);
    text-transform: uppercase;
    margin-bottom: 24px;
  }
  .sol-h1 {
    font-family: var(--font-display);
    font-size: clamp(52px, 9vw, 170px);
    line-height: 0.9;
    letter-spacing: -0.05em;
    text-transform: uppercase;
    color: var(--jb-cream);
    margin: 0;
  }
  .sol-h1 .fire { color: var(--jb-fire); }
  .sol-h1 .acid { color: var(--jb-acid); }
  .sol-sub {
    margin-top: 32px;
    font-size: clamp(14px, 1.4vw, 24px);
    line-height: 1.5;
    color: var(--jb-fg-3);
    max-width: 900px;
  }
  .sol-sub b { color: var(--jb-cream); }

  .sol-pills {
    margin-top: 40px;
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 12px;
  }
  .pill {
    background: var(--jb-ink-2);
    border: 1px solid var(--jb-acid-border);
    padding: 16px 18px;
    font-family: var(--font-display);
    font-size: clamp(12px, 1vw, 18px);
    text-transform: uppercase;
    color: var(--jb-cream);
    letter-spacing: -0.01em;
  }
  .pill b {
    color: var(--jb-acid);
    font-family: var(--font-display);
    margin-right: 10px;
  }
  .pill-op { border-color: var(--jb-fire-border); }
  .pill-op b { color: var(--jb-fire); }

  .sol-legend {
    margin-top: 24px;
    display: flex;
    gap: 32px;
    font-family: var(--font-mono);
    font-size: clamp(10px, 0.8vw, 13px);
    letter-spacing: 0.28em;
    color: var(--jb-fg-muted);
    text-transform: uppercase;
  }
  .lg-fd { color: var(--jb-acid); }
  .lg-op { color: var(--jb-fire); }

  @media (max-width: 1024px) {
    .sol-pills { grid-template-columns: repeat(3, 1fr); }
  }
  @media (max-width: 640px) {
    .sol-pills { grid-template-columns: repeat(2, 1fr); }
  }
</style>
