---
import Container from '../ui/Container.astro'
---

<section class="hero-section relative overflow-hidden bg-ink">
  <!-- Grid overlay assinatura -->
  <div class="grid-overlay"></div>

  <!-- Radial glow sutil (hero only) -->
  <div class="hero-glow" aria-hidden="true"></div>

  <Container class="relative z-10">
    <div class="hero-grid">
      <!-- Left Content -->
      <div class="hero-content">
        <!-- Kicker mono -->
        <div class="kicker hero-kicker">
          // FRAMEWORK 6PS · 17+ ANOS · 140+ MPES
        </div>

        <!-- H1 brutalist em 3 linhas -->
        <h1 class="hero-h1">
          <span class="line-1">VENDAS</span>
          <span class="line-2"><span class="stroke-text">PREVISÍVEIS</span> PRA QUEM</span>
          <span class="line-3">CANSOU DE <span class="text-fire">IMPROVISO</span>.</span>
        </h1>

        <!-- Lede -->
        <p class="hero-lede">
          17+ anos estruturando vendas escaláveis pra MPE. <strong class="text-cream">140+ clientes</strong>. <strong class="text-cream">~R$ 1 bilhão</strong> em vendas estruturadas como estimativa agregada. Framework 6Ps. Zero fórmula mágica.
        </p>

        <!-- CTAs -->
        <div class="hero-ctas">
          <a href="/vendas-sem-segredos" class="btn-primary" data-astro-prefetch>
            <span>Ver VSS completo</span>
            <span aria-hidden="true">→</span>
          </a>
          <a href="/contato" class="btn-secondary">
            <span>Falar com Joel (Advisory)</span>
            <span aria-hidden="true">→</span>
          </a>
        </div>

        <!-- Assinatura -->
        <div class="hero-signature mono">
          <span class="text-acid">★</span>&nbsp;&nbsp;SISTEMA <span class="text-fire">&gt;</span> IMPROVISO
        </div>

        <!-- Stats rápidos -->
        <div class="hero-stats">
          <div class="hero-stat">
            <div class="hero-stat-num text-acid">~R$ 1BI</div>
            <div class="hero-stat-label">Estruturado</div>
          </div>
          <div class="hero-stat">
            <div class="hero-stat-num text-acid">140+</div>
            <div class="hero-stat-label">Clientes</div>
          </div>
          <div class="hero-stat">
            <div class="hero-stat-num text-acid">17+</div>
            <div class="hero-stat-label">Anos</div>
          </div>
        </div>
      </div>

      <!-- Right: Terminal mock -->
      <aside class="hero-terminal" aria-hidden="true">
        <div class="term-chrome">
          <span class="term-dot" style="background: var(--jb-fire);"></span>
          <span class="term-dot" style="background: #FFB800;"></span>
          <span class="term-dot" style="background: var(--jb-acid);"></span>
          <span class="term-title">jb_core — diagnóstico.exe</span>
        </div>
        <div class="term-body">
          <div class="term-line"><span class="term-prompt">$</span> ./executar_diagnostico --6ps</div>
          <div class="term-line term-dim">&gt; scanning P1 posicionamento...</div>
          <div class="term-line"><span class="text-acid">▶</span> P1 · OK</div>
          <div class="term-line"><span class="text-acid">▶</span> P2 · OK</div>
          <div class="term-line"><span class="text-fire">●</span> P3 · GARGALO DETECTADO</div>
          <div class="term-line"><span class="text-fire">●</span> P4 · GARGALO DETECTADO</div>
          <div class="term-line"><span class="text-acid">▶</span> P5 · OK</div>
          <div class="term-line"><span class="text-acid">▶</span> P6 · OK</div>
          <div class="term-line term-dim">&gt; score: 18/30</div>
          <div class="term-line"><span class="term-prompt">$</span> ligar_maquina<span class="term-cursor">_</span></div>
        </div>
      </aside>
    </div>
  </Container>
</section>

<style>
  .hero-section {
    position: relative;
    min-height: 92vh;
    display: flex;
    align-items: center;
    padding-top: clamp(3rem, 8vh, 6rem);
    padding-bottom: clamp(3rem, 8vh, 6rem);
  }

  .hero-glow {
    position: absolute;
    top: -15%;
    right: -10%;
    width: 60vw;
    height: 60vw;
    max-width: 700px;
    max-height: 700px;
    background: radial-gradient(circle, rgba(255, 59, 15, 0.12), transparent 60%);
    pointer-events: none;
    z-index: 0;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: center;
  }
  @media (min-width: 1024px) {
    .hero-grid { grid-template-columns: 1.3fr 1fr; }
  }

  .hero-content { display: flex; flex-direction: column; gap: clamp(1.25rem, 2.5vw, 2rem); }

  .hero-kicker {
    color: var(--jb-acid);
    display: inline-block;
    font-size: clamp(10px, 1.4vw, 12px);
  }

  .hero-h1 {
    font-family: var(--font-display);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: -0.045em;
    line-height: 0.92;
    font-size: clamp(2.75rem, 8vw, 5.5rem);
    color: var(--jb-cream);
    margin: 0;
  }
  .hero-h1 .line-1, .hero-h1 .line-2, .hero-h1 .line-3 { display: block; }

  .hero-lede {
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: clamp(1rem, 1.6vw, 1.125rem);
    line-height: 1.55;
    color: var(--jb-cream);
    max-width: 40ch;
    text-transform: none;
  }
  .hero-lede strong { font-weight: 700; }

  .hero-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    padding-top: 0.5rem;
  }
  .hero-ctas a { min-height: 48px; }

  .hero-signature {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.28em;
    color: var(--jb-fg-muted);
    text-transform: uppercase;
    padding-top: 0.5rem;
  }

  .hero-stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--jb-hair);
    border: 1px solid var(--jb-hair);
    margin-top: 0.5rem;
  }
  .hero-stat {
    background: var(--jb-ink);
    padding: 1rem 0.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .hero-stat-num {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: clamp(1.5rem, 3vw, 2rem);
    letter-spacing: -0.02em;
    line-height: 1;
  }
  .hero-stat-label {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--jb-fg-muted);
  }

  /* Terminal window */
  .hero-terminal {
    background: var(--jb-ink-2);
    border: 1px solid var(--jb-hair);
    box-shadow: 0 40px 80px rgba(0,0,0,0.6);
    display: none;
  }
  @media (min-width: 1024px) {
    .hero-terminal { display: block; }
  }

  .term-chrome {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 10px 14px;
    border-bottom: 1px solid var(--jb-hair);
  }
  .term-dot {
    width: 11px;
    height: 11px;
    border-radius: 50%;
    display: inline-block;
  }
  .term-title {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--jb-fg-muted);
    letter-spacing: 0.12em;
    margin-left: auto;
    text-transform: lowercase;
  }
  .term-body {
    padding: 20px 18px;
    font-family: var(--font-mono);
    font-size: 13px;
    line-height: 1.7;
    color: var(--jb-cream);
  }
  .term-line { white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .term-dim { color: var(--jb-fg-muted); }
  .term-prompt { color: var(--jb-acid); font-weight: 700; }
  .term-cursor {
    display: inline-block;
    color: var(--jb-acid);
    animation: blink 1s infinite;
  }

  .hide-sm { display: none; }
  @media (min-width: 640px) {
    .hide-sm { display: inline; }
  }
</style>
