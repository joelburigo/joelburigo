---
import Container from '../../ui/Container.astro'
import { Icon } from 'astro-icon/components'
---

<div class="h-screen bg-dark flex items-center justify-center overflow-hidden">
  <Container>
    <div class="max-w-6xl mx-auto px-4">
      
      <div class="text-center mb-12">
        <h2 class="font-display text-5xl font-bold text-white mb-4">
          Qual <span class="text-lime">Caminho</span> Faz Sentido?
        </h2>
        <p class="text-xl text-gray-400">
          Duas formas de implementar os 6Ps na sua empresa
        </p>
      </div>

      <!-- Forquilha de Caminhos -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-5xl mx-auto">

        <!-- Caminho DIY - VSS -->
        <button
          @click="goTo(10)"
          class="group rounded-xl border-2 border-lime/30 bg-lime/5 p-8 text-left hover:border-lime/60 hover:bg-lime/10 transition-all cursor-pointer relative"
        >
          <div class="absolute -top-3 right-4 rounded-full bg-lime px-3 py-1">
            <span class="text-xs font-bold text-dark uppercase tracking-wider">Mais Vendido</span>
          </div>

          <div class="mb-6">
            <Icon name="lucide:graduation-cap" class="h-16 w-16 text-lime group-hover:scale-110 transition-transform" />
          </div>

          <h3 class="text-3xl font-bold text-white mb-4 leading-tight">Quer fazer <span class="text-lime">sozinho?</span></h3>

          <p class="text-lg text-white font-semibold mb-2">Vendas Sem Segredos</p>

          <p class="text-gray-300 mb-4 leading-relaxed">
            Playbook + mentorias + CRM para você implementar os 6Ps com autonomia
          </p>

          <p class="text-sm text-gray-400 mb-6 leading-relaxed">
            <strong class="text-gray-300">Ideal para:</strong> Empreendedor hands-on (R$ 10-100k/mês) que tem 2-3h/semana para executar
          </p>

          <div class="flex items-center gap-2 text-lime font-semibold">
            <span>Ver Programa</span>
            <Icon name="lucide:arrow-right" class="h-5 w-5 group-hover:translate-x-1 transition-transform" />
          </div>
        </button>

        <!-- Caminho Advisory -->
        <button
          @click="goTo(14)"
          class="group rounded-xl border-2 border-purple-500/30 bg-purple-500/5 p-8 text-left hover:border-purple-500/60 hover:bg-purple-500/10 transition-all cursor-pointer"
        >
          <div class="mb-6">
            <Icon name="lucide:compass" class="h-16 w-16 text-purple-400 group-hover:scale-110 transition-transform" />
          </div>
          
          <h3 class="text-3xl font-bold text-white mb-4 leading-tight">Quer minha mente no seu <span class="text-purple-400">negócio?</span></h3>
          
          <p class="text-lg text-white font-semibold mb-2">Advisory</p>
          
          <p class="text-gray-300 mb-4 leading-relaxed">
            Sessões estratégicas comigo para decisões-chave, crescimento e escala.
          </p>
          
          <p class="text-sm text-gray-400 mb-6 leading-relaxed">
            <strong class="text-gray-300">Ideal para:</strong> Empresa estruturada (R$ 500k+/mês) que já tem time e precisa de direcionamento
          </p>
          
          <div class="flex items-center gap-2 text-purple-400 font-semibold">
            <span>Ver Formatos</span>
            <Icon name="lucide:arrow-right" class="h-5 w-5 group-hover:translate-x-1 transition-transform" />
          </div>
        </button>

      </div>

    </div>
  </Container>
</div>
