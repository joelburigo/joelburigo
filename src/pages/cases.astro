---
import Layout from '../layouts/Layout.astro'
import Header from '../components/layout/Header.astro'
import Footer from '../components/layout/Footer.astro'
import Container from '../components/ui/Container.astro'
import Breadcrumbs from '../components/seo/Breadcrumbs.astro'
import { cases } from '../data/cases'

const seo = {
  title: 'Cases | Joel Burigo',
  description: 'Resultados reais de clientes que estruturaram vendas com o Framework 6Ps.',
  keywords: 'cases sucesso, resultados clientes, framework 6Ps, Joel Burigo',
}
---

<Layout title={seo.title} description={seo.description} keywords={seo.keywords}>
  <Header />

  <section class="bg-ink pt-20 pb-6">
    <Container>
      <Breadcrumbs items={[{ label: 'Home', href: '/' }, { label: 'Cases', href: '/cases' }]} />
    </Container>
  </section>

  <main class="relative overflow-hidden bg-ink">
    <div class="grid-overlay"></div>

    <Container class="relative z-10">
      <!-- Hero -->
      <section class="py-16 md:py-24">
        <div class="mx-auto max-w-5xl">
          <div class="kicker mb-6">// CASES · RESULTADOS_REAIS · 140+_MPES</div>
          <h1 class="tg-display">
            Resultados <span class="text-acid">reais.</span>
          </h1>
          <p class="mt-6 max-w-2xl font-sans text-lg text-[color:var(--jb-cream)]">
            Alguns dos clientes que implementaram os 6Ps e transformaram vendas aleatórias em previsíveis.
          </p>
          <p class="mt-3 max-w-2xl font-mono text-[11px] uppercase tracking-[0.22em] text-[color:var(--jb-fg-muted)]">
            <span class="text-fire">●</span>&nbsp; DISCLAIMER · RESULTADOS VARIAM POR NICHO, TICKET E EXECUÇÃO · MÉTODO &gt; MILAGRE
          </p>
        </div>
      </section>

      <!-- Stats canônicos -->
      <section class="pb-16">
        <div class="mx-auto max-w-5xl">
          <div class="grid gap-px border border-[color:var(--jb-hair)] bg-[color:var(--jb-hair)] md:grid-cols-4">
            <div class="bg-[color:var(--jb-ink-2)] p-6">
              <div class="kicker mb-2">// EXPERIÊNCIA</div>
              <div class="font-display text-3xl text-acid">17+</div>
              <div class="font-mono text-[11px] uppercase tracking-[0.2em] text-[color:var(--jb-fg-muted)]">anos</div>
            </div>
            <div class="bg-[color:var(--jb-ink-2)] p-6">
              <div class="kicker mb-2">// CLIENTES</div>
              <div class="font-display text-3xl text-acid">140+</div>
              <div class="font-mono text-[11px] uppercase tracking-[0.2em] text-[color:var(--jb-fg-muted)]">atendidos</div>
            </div>
            <div class="bg-[color:var(--jb-ink-2)] p-6">
              <div class="kicker mb-2">// VOLUME</div>
              <div class="font-display text-3xl text-acid">~R$1BI</div>
              <div class="font-mono text-[11px] uppercase tracking-[0.2em] text-[color:var(--jb-fg-muted)]">estruturado</div>
            </div>
            <div class="bg-[color:var(--jb-ink-2)] p-6">
              <div class="kicker mb-2">// NICHOS</div>
              <div class="font-display text-3xl text-acid">20+</div>
              <div class="font-mono text-[11px] uppercase tracking-[0.2em] text-[color:var(--jb-fg-muted)]">validados</div>
            </div>
          </div>
        </div>
      </section>

      <!-- Filtros -->
      <section class="pb-10">
        <div class="mx-auto max-w-5xl">
          <div class="kicker mb-4">// FILTRAR_POR_PRODUTO</div>
          <div class="flex flex-wrap gap-2">
            <button class="filter-btn btn-primary min-h-[40px] px-5 py-2 text-xs" data-filter="all">
              Todos
            </button>
            <button class="filter-btn btn-secondary min-h-[40px] px-5 py-2 text-xs" data-filter="Vendas Sem Segredos">
              VSS
            </button>
            <button class="filter-btn btn-secondary min-h-[40px] px-5 py-2 text-xs" data-filter="Advisory">
              Advisory
            </button>
          </div>
        </div>
      </section>

      <!-- Cases Grid -->
      <section class="pb-16">
        <div class="mx-auto max-w-6xl">
          <div class="grid gap-6 md:grid-cols-2" id="cases-grid">
            {cases.map((caso: any) => (
              <article
                class="case-card border border-[color:var(--jb-hair)] bg-[color:var(--jb-ink-2)] p-6 md:p-8 transition-all duration-[var(--jb-dur)] hover:border-[color:var(--jb-acid)] hover:-translate-x-[2px] hover:-translate-y-[2px] hover:shadow-[6px_6px_0_var(--jb-acid)]"
                data-produto={caso.produto}
              >
                <!-- Header -->
                <div class="mb-5 flex flex-wrap items-start justify-between gap-3 border-b border-[color:var(--jb-hair)] pb-5">
                  <div class={`kicker ${caso.produto.includes('Advisory') ? 'text-fire' : ''}`} style={caso.produto.includes('Advisory') ? 'color: var(--jb-fire);' : ''}>
                    // {caso.produto.toUpperCase()}
                  </div>
                  {caso.badge && (
                    <div class="border border-[color:var(--jb-acid-border)] bg-[color:var(--jb-acid-soft)] px-3 py-1 font-mono text-[10px] uppercase tracking-[0.2em] text-acid">
                      ★ {caso.badge}
                    </div>
                  )}
                </div>

                <!-- Nome + nicho -->
                <div class="mb-6">
                  <h3 class="heading-3 mb-1 text-[color:var(--jb-cream)]">{caso.empresa}</h3>
                  <p class="font-mono text-[11px] uppercase tracking-[0.22em] text-[color:var(--jb-fg-muted)]">{caso.nicho}</p>
                </div>

                <!-- Antes / Depois / Tempo -->
                <div class="mb-5 grid grid-cols-3 gap-px border border-[color:var(--jb-hair)] bg-[color:var(--jb-hair)]">
                  <div class="bg-[color:var(--jb-ink)] p-4">
                    <div class="kicker mb-1">// ANTES</div>
                    <div class="font-display text-base text-[color:var(--jb-cream)]">{caso.antes}</div>
                  </div>
                  <div class="bg-[color:var(--jb-ink)] p-4">
                    <div class="kicker mb-1" style="color: var(--jb-acid);">// DEPOIS</div>
                    <div class="font-display text-base text-acid">{caso.depois}</div>
                  </div>
                  <div class="bg-[color:var(--jb-ink)] p-4">
                    <div class="kicker mb-1">// TEMPO</div>
                    <div class="font-display text-base text-[color:var(--jb-cream)]">{caso.tempo}</div>
                  </div>
                </div>

                <!-- Crescimento -->
                <div class="mb-6 flex items-baseline gap-3 border-l-2 border-acid bg-[color:var(--jb-ink)] p-4">
                  <span class="text-acid font-mono">▲</span>
                  <span class="font-display text-3xl text-acid">{caso.crescimento}</span>
                  <span class="font-mono text-[11px] uppercase tracking-[0.22em] text-[color:var(--jb-fg-muted)]">crescimento</span>
                </div>

                <!-- Situação antes -->
                <div class="mb-4">
                  <div class="kicker mb-2" style="color: var(--jb-fire);">// SITUAÇÃO_ANTES</div>
                  <p class="font-sans text-sm text-[color:var(--jb-fg-2)] leading-relaxed">{caso.situacaoAntes}</p>
                </div>

                <!-- O que fizemos -->
                <div>
                  <div class="kicker mb-2" style="color: var(--jb-acid);">// O_QUE_FIZEMOS</div>
                  <p class="font-sans text-sm text-[color:var(--jb-fg-2)] leading-relaxed">{caso.solucao}</p>
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>

      <!-- CTA final -->
      <section class="pb-16 md:pb-24">
        <div class="mx-auto max-w-4xl">
          <div class="border border-[color:var(--jb-acid-border)] bg-[color:var(--jb-ink-2)] p-8 md:p-12" style="background: linear-gradient(180deg, rgba(198,255,0,0.06), var(--jb-ink-2));">
            <div class="kicker mb-4" style="color: var(--jb-acid);">// QUER_RESULTADO_SIMILAR?</div>
            <h2 class="heading-2 mb-4 text-[color:var(--jb-cream)]">
              Escolhe o caminho que faz sentido pro teu momento.
            </h2>
            <p class="mb-8 font-sans text-[color:var(--jb-fg-2)]">
              VSS (DIY perpétuo) pra quem quer autonomia. Advisory (1:1) pra quem precisa de conselheiro presente.
            </p>
            <div class="flex flex-wrap gap-4">
              <a href="/vendas-sem-segredos" class="btn-primary min-h-[48px]">
                <span>Conhecer VSS</span>
                <span aria-hidden="true">→</span>
              </a>
              <a href="/advisory" class="btn-fire min-h-[48px]">
                <span>Aplicar pra Advisory</span>
                <span aria-hidden="true">→</span>
              </a>
              <a href="/contato" class="btn-secondary min-h-[48px]">Falar comigo</a>
            </div>
            <div class="mt-8 border-t border-[color:var(--jb-hair)] pt-6 font-mono text-[11px] uppercase tracking-[0.28em] text-[color:var(--jb-fg-muted)]">
              <span class="text-acid">★</span>&nbsp;&nbsp;SISTEMA <span class="text-fire">&gt;</span> IMPROVISO
            </div>
          </div>
        </div>
      </section>
    </Container>
  </main>

  <Footer />
</Layout>

<script>
  const filterButtons = document.querySelectorAll<HTMLButtonElement>('.filter-btn')
  const caseCards = document.querySelectorAll<HTMLElement>('.case-card')

  filterButtons.forEach((button) => {
    button.addEventListener('click', () => {
      const filter = button.getAttribute('data-filter')

      filterButtons.forEach((btn) => {
        if (btn === button) {
          btn.classList.remove('btn-secondary')
          btn.classList.add('btn-primary')
        } else {
          btn.classList.remove('btn-primary')
          btn.classList.add('btn-secondary')
        }
      })

      caseCards.forEach((card) => {
        const produto = card.getAttribute('data-produto')
        if (filter === 'all') {
          card.style.display = 'block'
        } else if (produto && produto.includes(filter as string)) {
          card.style.display = 'block'
        } else {
          card.style.display = 'none'
        }
      })
    })
  })
</script>

<style>
  .tg-display {
    font-family: var(--font-display);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: -0.045em;
    line-height: 0.92;
    font-size: clamp(2.5rem, 8vw, 5rem);
    color: var(--jb-cream);
    margin: 0;
  }
</style>
