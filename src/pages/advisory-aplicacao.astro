---
import Layout from '../layouts/Layout.astro'
import Header from '../components/layout/Header.astro'
import Footer from '../components/layout/Footer.astro'
import Container from '../components/ui/Container.astro'
import HighLevelForm from '../components/ui/HighLevelForm.astro'

const seo = {
  title: 'Aplicar pra Advisory — Sprint + Conselho | Joel Burigo',
  description: 'Análise de fit pra Sprint Estratégico 30 Dias ou Conselho Executivo. Vagas limitadas.',
  keywords: 'advisory, sprint estratégico, conselho executivo, consultoria, Joel Burigo',
}
---

<Layout title={seo.title} description={seo.description} keywords={seo.keywords} noIndex={true}>
  <Header />

  <main class="relative overflow-hidden bg-ink pt-20">
    <div class="grid-overlay"></div>

    <Container class="relative z-10">
      <section class="py-16 md:py-24">
        <div class="mx-auto max-w-5xl">
          <!-- Hero -->
          <div class="mb-12">
            <div class="kicker mb-6">// ADVISORY · APLICAÇÃO · ANÁLISE_DE_FIT</div>
            <h1 class="tg-display">
              Aplicar pra <span class="text-acid">Advisory.</span>
            </h1>
            <p class="mt-6 max-w-2xl font-sans text-lg text-[color:var(--jb-cream)]">
              Preenche o formulário detalhando teu momento. Analiso pessoalmente · <strong class="text-acid">resposta direta do Joel</strong>, sem fila.
            </p>
          </div>

          <!-- Info cards -->
          <div class="mb-10 grid gap-6 md:grid-cols-2">
            <div class="card" style="border-color: var(--jb-acid-border);">
              <div class="kicker mb-3" style="color: var(--jb-acid);">// SPRINT · 30_DIAS</div>
              <h3 class="heading-3 mb-4 text-[color:var(--jb-cream)]">Sprint Estratégico 30 Dias</h3>
              <ul class="space-y-2 font-mono text-[13px] text-[color:var(--jb-fg-2)]">
                <li><span class="text-acid">▶</span> 30 dias intensivos</li>
                <li><span class="text-acid">▶</span> 4 sessões de 90 min</li>
                <li><span class="text-acid">▶</span> Plano estratégico 12 meses</li>
                <li><span class="text-acid">▶</span> R$ 7.500</li>
              </ul>
              <p class="mt-4 font-sans text-[color:var(--jb-fg-2)]">
                Pra momentos de virada que exigem plano estruturado em 30 dias.
              </p>
            </div>

            <div class="card" style="border-color: var(--jb-fire-border);">
              <div class="kicker mb-3" style="color: var(--jb-fire);">// CONSELHO · EXECUTIVO</div>
              <h3 class="heading-3 mb-4 text-[color:var(--jb-cream)]">Conselho Executivo</h3>
              <ul class="space-y-2 font-mono text-[13px] text-[color:var(--jb-fg-2)]">
                <li><span class="text-fire">●</span> 3-6 meses</li>
                <li><span class="text-fire">●</span> 8 sessões/mês</li>
                <li><span class="text-fire">●</span> WhatsApp direto</li>
                <li><span class="text-fire">●</span> R$ 15.000/mês</li>
              </ul>
              <p class="mt-4 font-sans text-[color:var(--jb-fg-2)]">
                Pra empresas que precisam de conselheiro presente e acompanhamento contínuo.
              </p>
            </div>
          </div>

          <!-- Processo -->
          <div class="mb-10 border border-[color:var(--jb-hair)] bg-[color:var(--jb-ink-2)] p-8">
            <div class="kicker mb-6">// COMO_FUNCIONA</div>
            <div class="grid gap-6 md:grid-cols-3">
              {[
                { n: '01', title: 'Você aplica', body: 'Preenche o formulário detalhando desafio e momento atual.' },
                { n: '02', title: 'Análise de fit', body: 'Analiso pessoalmente se faz sentido — sem fila, sem intermediários.' },
                { n: '03', title: 'Conversa inicial', body: 'Se houver fit, agendamos 30 min pra alinhar expectativa.' },
              ].map((step) => (
                <div>
                  <div class="mb-3 font-mono text-sm font-bold text-acid" style="letter-spacing: 0.1em;">{step.n}</div>
                  <h3 class="heading-4 mb-2 text-[color:var(--jb-cream)]">{step.title}</h3>
                  <p class="font-sans text-sm text-[color:var(--jb-fg-2)]">{step.body}</p>
                </div>
              ))}
            </div>
          </div>

          <!-- Formulário -->
          <div class="mb-10 border border-[color:var(--jb-acid-border)] bg-[color:var(--jb-ink-2)] p-4 sm:p-6">
            <div class="kicker mb-4" style="color: var(--jb-acid);">// FORMULÁRIO · APLICAÇÃO</div>
            <HighLevelForm formId="GwMlk5A2LFPxqbNJC1j2" height="2042px" />
          </div>

          <!-- Disclaimer -->
          <div class="border-l-2 border-fire bg-[color:var(--jb-ink-2)] p-6">
            <div class="kicker mb-2" style="color: var(--jb-fire);">// VAGAS · EXTREMAMENTE_LIMITADAS</div>
            <p class="font-sans text-[color:var(--jb-cream)]">
              Vagas limitadas conforme capacidade do momento — tanto no Sprint quanto no Conselho Executivo. Só aceito quem tá em momento crítico real e vai executar.
            </p>
          </div>

          <!-- Voltar -->
          <div class="mt-10">
            <a href="/advisory" class="font-mono text-[12px] uppercase tracking-[0.22em] text-[color:var(--jb-fg-3)] hover:text-acid">
              ← Voltar pra Advisory
            </a>
          </div>
        </div>
      </section>
    </Container>
  </main>

  <Footer />
</Layout>

<style>
  .tg-display {
    font-family: var(--font-display);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: -0.045em;
    line-height: 0.92;
    font-size: clamp(2.5rem, 7vw, 4.5rem);
    color: var(--jb-cream);
    margin: 0;
  }
</style>
