---
import Layout from '../layouts/Layout.astro'
import Header from '../components/layout/Header.astro'
import Footer from '../components/layout/Footer.astro'
import Container from '../components/ui/Container.astro'
import Breadcrumbs from '../components/seo/Breadcrumbs.astro'
import { contactInfo as contact, getWhatsAppLink } from '../data/contact'

const seo = {
  title: 'Contato | Joel Burigo',
  description: 'Fala direto comigo. Respondo pessoalmente em até 24 horas.',
  keywords: 'contato Joel Burigo, consultoria vendas, falar com Joel',
}

const channels = [
  {
    label: 'EMAIL',
    value: contact.email.main,
    href: contact.email.mailto,
  },
  {
    label: 'WHATSAPP',
    value: contact.phone.display,
    href: getWhatsAppLink('Olá Joel, gostaria de saber mais sobre as soluções'),
  },
  {
    label: 'LOCALIZAÇÃO',
    value: 'Ribeirão da Ilha, Florianópolis/SC',
    href: null,
  },
  {
    label: 'ATENDIMENTO',
    value: contact.businessHours.weekdays,
    href: null,
  },
]

const faqs = [
  {
    q: 'Qual o melhor caminho pra mim?',
    a: 'Quer o método completo pra implementar com autonomia? VSS. Precisa de acesso direto pra decisões estratégicas? Advisory.',
  },
  {
    q: 'Quanto tempo até ver resultado?',
    a: 'VSS: 90 dias você já tá rodando. Advisory: depende do formato e de onde tu tá hoje.',
  },
  {
    q: 'Trabalha com qualquer nicho?',
    a: 'Já estruturei vendas em 20+ nichos diferentes. Metodologia 6Ps testada em 140+ empresas.',
  },
  {
    q: 'Tem garantia?',
    a: 'VSS tem 15 dias incondicional. Advisory tem garantia de satisfação na primeira sessão.',
  },
]
---

<Layout title={seo.title} description={seo.description} keywords={seo.keywords}>
  <Header />

  <section class="bg-ink pt-20 pb-6">
    <Container>
      <Breadcrumbs items={[{ label: 'Home', href: '/' }, { label: 'Contato', href: '/contato' }]} />
    </Container>
  </section>

  <main class="relative overflow-hidden bg-ink">
    <div class="grid-overlay"></div>

    <Container class="relative z-10">
      <!-- Hero -->
      <section class="py-16 md:py-24">
        <div class="mx-auto max-w-4xl">
          <div class="kicker mb-6">// CONTATO · DIRETO · 24H_RESPONSE</div>
          <h1 class="tg-display">
            Quer <span class="text-fire">ligar a Máquina</span>?
          </h1>
          <p class="mt-6 max-w-2xl font-sans text-lg text-[color:var(--jb-cream)]">
            Respondo pessoalmente em até 24h. Manda mensagem no canal que preferir.
          </p>
          <p class="mt-3 max-w-2xl font-mono text-[12px] uppercase tracking-[0.22em] text-[color:var(--jb-fg-muted)]">
            <span class="text-acid">●</span>&nbsp; FLORIANÓPOLIS/SC &nbsp;·&nbsp; -27.59 / -48.55
          </p>
        </div>
      </section>

      <!-- Canais -->
      <section class="pb-16">
        <div class="mx-auto max-w-5xl">
          <div class="kicker mb-6">// CANAIS · DISPONÍVEIS</div>
          <div class="grid gap-0 border border-[color:var(--jb-hair)] bg-[color:var(--jb-ink-2)] md:grid-cols-2 lg:grid-cols-4">
            {channels.map((c, i) => (
              <div class={`border-[color:var(--jb-hair)] p-6 ${i < 3 ? 'border-b md:border-b-0 md:border-r' : ''} ${i < 2 ? 'md:border-r lg:border-r' : ''} ${i === 1 ? 'md:border-r-0 lg:border-r' : ''}`}>
                <div class="kicker mb-3">// {c.label}</div>
                {c.href ? (
                  <a href={c.href} target={c.href.startsWith('http') ? '_blank' : undefined} rel={c.href.startsWith('http') ? 'noopener noreferrer' : undefined} class="block font-sans text-[color:var(--jb-cream)] transition-colors hover:text-acid">
                    {c.value}
                  </a>
                ) : (
                  <div class="font-sans text-[color:var(--jb-cream)]">{c.value}</div>
                )}
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- Formulário -->
      <section class="pb-16 md:pb-24">
        <div class="mx-auto max-w-4xl">
          <div class="kicker mb-6">// FORMULÁRIO · DIRETO</div>
          <div class="border border-[color:var(--jb-acid-border)] bg-[color:var(--jb-ink-2)] p-6 md:p-10">
            <h2 class="heading-2 mb-3 text-[color:var(--jb-cream)]">Manda sua mensagem</h2>
            <p class="mb-8 font-sans text-[color:var(--jb-fg-2)]">
              Conta teu desafio atual. Quanto mais detalhe, melhor a resposta.
            </p>

            <form class="space-y-6" id="contact-form">
              <div class="grid gap-6 md:grid-cols-2">
                <div>
                  <label for="name" class="mb-2 block font-mono text-[11px] uppercase tracking-[0.22em] text-[color:var(--jb-fg-3)]">
                    Nome *
                  </label>
                  <input
                    type="text"
                    id="name"
                    name="name"
                    required
                    class="w-full border border-[color:var(--jb-hair-strong)] bg-[color:var(--jb-ink)] px-4 py-3 font-sans text-[color:var(--jb-cream)] placeholder:text-[color:var(--jb-fg-muted)] transition-colors focus:border-[color:var(--jb-acid)] focus:outline-none"
                    placeholder="Seu nome completo"
                  />
                </div>
                <div>
                  <label for="email" class="mb-2 block font-mono text-[11px] uppercase tracking-[0.22em] text-[color:var(--jb-fg-3)]">
                    Email *
                  </label>
                  <input
                    type="email"
                    id="email"
                    name="email"
                    required
                    class="w-full border border-[color:var(--jb-hair-strong)] bg-[color:var(--jb-ink)] px-4 py-3 font-sans text-[color:var(--jb-cream)] placeholder:text-[color:var(--jb-fg-muted)] transition-colors focus:border-[color:var(--jb-acid)] focus:outline-none"
                    placeholder="seu@email.com"
                  />
                </div>
              </div>
              <div class="grid gap-6 md:grid-cols-2">
                <div>
                  <label for="phone" class="mb-2 block font-mono text-[11px] uppercase tracking-[0.22em] text-[color:var(--jb-fg-3)]">
                    WhatsApp
                  </label>
                  <input
                    type="tel"
                    id="phone"
                    name="phone"
                    class="w-full border border-[color:var(--jb-hair-strong)] bg-[color:var(--jb-ink)] px-4 py-3 font-sans text-[color:var(--jb-cream)] placeholder:text-[color:var(--jb-fg-muted)] transition-colors focus:border-[color:var(--jb-acid)] focus:outline-none"
                    placeholder="(48) 99999-9999"
                  />
                </div>
                <div>
                  <label for="subject" class="mb-2 block font-mono text-[11px] uppercase tracking-[0.22em] text-[color:var(--jb-fg-3)]">
                    Assunto *
                  </label>
                  <select
                    id="subject"
                    name="subject"
                    required
                    class="w-full border border-[color:var(--jb-hair-strong)] bg-[color:var(--jb-ink)] px-4 py-3 font-sans text-[color:var(--jb-cream)] transition-colors focus:border-[color:var(--jb-acid)] focus:outline-none"
                  >
                    <option value="">Selecione...</option>
                    <option value="vss">Vendas Sem Segredos (VSS)</option>
                    <option value="advisory">Advisory</option>
                    <option value="imprensa">Imprensa / Palestra</option>
                    <option value="other">Outro</option>
                  </select>
                </div>
              </div>
              <div>
                <label for="message" class="mb-2 block font-mono text-[11px] uppercase tracking-[0.22em] text-[color:var(--jb-fg-3)]">
                  Mensagem *
                </label>
                <textarea
                  id="message"
                  name="message"
                  required
                  rows="6"
                  class="w-full border border-[color:var(--jb-hair-strong)] bg-[color:var(--jb-ink)] px-4 py-3 font-sans text-[color:var(--jb-cream)] placeholder:text-[color:var(--jb-fg-muted)] transition-colors focus:border-[color:var(--jb-acid)] focus:outline-none"
                  placeholder="Conta teu desafio atual, faturamento, momento da empresa..."
                ></textarea>
              </div>

              <button type="submit" class="btn-primary min-h-[48px]">
                <span>Enviar mensagem</span>
                <span aria-hidden="true">→</span>
              </button>
              <p class="font-mono text-[11px] uppercase tracking-[0.22em] text-[color:var(--jb-fg-muted)]">
                * Campos obrigatórios
              </p>
            </form>
          </div>
        </div>
      </section>

      <!-- FAQ -->
      <section class="pb-16 md:pb-24">
        <div class="mx-auto max-w-3xl">
          <div class="kicker mb-6">// FAQ · DÚVIDAS_COMUNS</div>
          <h2 class="heading-2 mb-10 text-[color:var(--jb-cream)]">Perguntas frequentes</h2>
          <div class="space-y-0 border border-[color:var(--jb-hair)] bg-[color:var(--jb-ink-2)]">
            {faqs.map((faq, i) => (
              <div class={`p-6 md:p-8 ${i > 0 ? 'border-t border-[color:var(--jb-hair)]' : ''}`}>
                <h3 class="heading-4 mb-3 text-[color:var(--jb-cream)]">{faq.q}</h3>
                <p class="font-sans text-[color:var(--jb-fg-2)]">{faq.a}</p>
              </div>
            ))}
          </div>
        </div>
      </section>
    </Container>
  </main>

  <Footer />
</Layout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement
  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault()
      const formData = new FormData(form)
      const data = Object.fromEntries(formData)
      console.log('Form data:', data)
      alert('Mensagem enviada. Retorno em até 24h.')
      form.reset()
    })
  }
</script>

<style>
  .tg-display {
    font-family: var(--font-display);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: -0.045em;
    line-height: 0.92;
    font-size: clamp(2.5rem, 8vw, 5rem);
    color: var(--jb-cream);
    margin: 0;
  }
</style>
