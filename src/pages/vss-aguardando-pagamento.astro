---
import Layout from '../layouts/Layout.astro'
import Header from '../components/layout/Header.astro'
import Footer from '../components/layout/Footer.astro'
import Container from '../components/ui/Container.astro'
import { contactInfo, getWhatsAppLink } from '../data/contact'
---

<Layout
  title="Aguardando pagamento — VSS | Joel Burigo"
  description="Pedido registrado. Aguardando confirmação do pagamento."
  noIndex={true}
>
  <Header />

  <main class="relative overflow-hidden bg-ink pt-20">
    <div class="grid-overlay"></div>

    <Container class="relative z-10">
      <section class="py-16 md:py-24">
        <div class="mx-auto max-w-4xl">
          <!-- Kicker -->
          <div class="kicker mb-6" style="color: var(--jb-fire);">// VSS · STATUS: PENDING · AGUARDANDO_PAGAMENTO</div>

          <h1 class="status-display">
            <span class="stroke-text">PEDIDO</span>
            <span class="block">REGISTRADO.</span>
          </h1>

          <p class="mt-8 max-w-2xl font-sans text-lg text-[color:var(--jb-cream)]">
            Assim que o pagamento for confirmado, você recebe acesso por email em até 5 minutos.
          </p>

          <!-- Status terminal -->
          <div class="mt-10 border border-[color:var(--jb-hair)] bg-[color:var(--jb-ink-2)] p-6 font-mono text-[13px] leading-[1.8] text-[color:var(--jb-cream)]">
            <div><span class="text-acid">$</span> waiting_for_payment.exe</div>
            <div class="text-[color:var(--jb-fg-muted)]">&gt; monitoring payment gateway...</div>
            <div><span class="text-fire">●</span> PIX · confirmação &lt; 5min</div>
            <div><span class="text-fire">●</span> BOLETO · 1 a 3 dias úteis</div>
            <div><span class="text-acid">▶</span> EMAIL · enviado na confirmação</div>
          </div>

          <!-- Métodos -->
          <div class="mt-10 grid gap-6 md:grid-cols-3">
            <div class="card">
              <div class="kicker mb-3">// PIX</div>
              <h3 class="heading-4 mb-2 text-[color:var(--jb-cream)]">Instantâneo</h3>
              <p class="font-sans text-[color:var(--jb-fg-2)]">Acesso liberado em até 5 minutos após confirmação.</p>
            </div>
            <div class="card">
              <div class="kicker mb-3">// BOLETO</div>
              <h3 class="heading-4 mb-2 text-[color:var(--jb-cream)]">1-3 dias úteis</h3>
              <p class="font-sans text-[color:var(--jb-fg-2)]">Acesso liberado quando o banco confirmar o pagamento.</p>
            </div>
            <div class="card">
              <div class="kicker mb-3">// EMAIL</div>
              <h3 class="heading-4 mb-2 text-[color:var(--jb-cream)]">Confirmação</h3>
              <p class="font-sans text-[color:var(--jb-fg-2)]">Assunto: "Acesso ao Vendas Sem Segredos". Olha também o spam.</p>
            </div>
          </div>

          <!-- FAQ curto -->
          <div class="mt-12 border-t border-[color:var(--jb-hair)] pt-8">
            <div class="kicker mb-6">// PERGUNTAS · FREQUENTES</div>
            <dl class="space-y-5">
              <div>
                <dt class="font-sans font-bold text-[color:var(--jb-cream)]">Não recebi código PIX ou boleto</dt>
                <dd class="mt-1 font-sans text-[color:var(--jb-fg-2)]">Olha a pasta de spam. Se não chegar, manda mensagem no WhatsApp abaixo.</dd>
              </div>
              <div>
                <dt class="font-sans font-bold text-[color:var(--jb-cream)]">Paguei e ainda não recebi acesso</dt>
                <dd class="mt-1 font-sans text-[color:var(--jb-fg-2)]">PIX até 5 min. Boleto até 3 dias úteis. Se passar, fala com a gente.</dd>
              </div>
              <div>
                <dt class="font-sans font-bold text-[color:var(--jb-cream)]">Posso cancelar?</dt>
                <dd class="mt-1 font-sans text-[color:var(--jb-fg-2)]">Pode. Garantia de 15 dias incondicional — devolve 100% sem perguntas.</dd>
              </div>
            </dl>
          </div>

          <!-- CTAs -->
          <div class="mt-10 flex flex-wrap gap-4">
            <a
              href={getWhatsAppLink('Olá! Fiz uma compra do Vendas Sem Segredos e gostaria de confirmar o status do pagamento.')}
              target="_blank"
              rel="noopener noreferrer"
              class="btn-primary min-h-[48px]"
            >
              <span>Falar com suporte</span>
              <span aria-hidden="true">→</span>
            </a>
            <a href="/vendas-sem-segredos" class="btn-secondary min-h-[48px]">Ver detalhes do VSS</a>
          </div>

          <!-- Rodapé contato -->
          <div class="mt-12 border-t border-[color:var(--jb-hair)] pt-6 font-mono text-[11px] uppercase tracking-[0.22em] text-[color:var(--jb-fg-muted)]">
            WHATSAPP: {contactInfo.phone.display} &nbsp;·&nbsp; EMAIL: {contactInfo.email.main}
          </div>
        </div>
      </section>
    </Container>
  </main>

  <Footer />
</Layout>

<style>
  .status-display {
    font-family: var(--font-display);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: -0.045em;
    line-height: 0.92;
    font-size: clamp(2.5rem, 8vw, 5rem);
    color: var(--jb-cream);
    margin: 0;
  }
</style>
