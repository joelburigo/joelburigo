---
import Container from '../ui/Container.astro'
import Button from '../ui/Button.astro'
import VideoPlayer from '../ui/VideoPlayer.astro'
import { cases } from '../../data/cases'
import Icons from '../ui/Icons.astro'
import { getWhatsAppLink } from '../../data/contact'
import hotmartSecurity from '../../assets/images/hotmart-payment-security.png'
import HighLevelForm from '../ui/HighLevelForm.astro'


// Filtrar cases do VSS (6 cases exibidos, 7 disponíveis no arquivo)
const casesVSS = cases.filter(c => c.produto === 'Vendas Sem Segredos').slice(0, 6)

// Mapear cases para formato de depoimentos
const nichoAvatars: Record<string, string> = {
  'Estética e Beleza': '💅',
  'Serviços Masculinos': '✂️',
  'Varejo Feminino': '👗',
  'Odontologia': '🦷',
  'Serviços Jurídicos': '⚖️',
  'Fitness Individual': '💪',
  'Educação e Idiomas': '📚',
}

const depoimentos = casesVSS.map(c => ({
  nome: c.empresa,
  resultado: c.resultado,
  texto: c.solucao.split('.')[0] + '.',
  avatar: nichoAvatars[c.nicho] || '🏢'
}))

const oquee = [
  { icon: 'CheckCircle2', title: 'Implementação Prática', desc: '90 dias de trabalho estruturado, não só teoria' },
  { icon: 'Zap', title: 'Sistema Completo', desc: 'CRM + funis + processos + scripts funcionando' },
  { icon: 'Target', title: 'Funciona Sem Budget', desc: 'COM ou SEM tráfego pago, você escolhe a rota' },
  { icon: 'Users', title: '48 Mentorias ao Vivo', desc: 'Sessões semanais de 60 min com Joel Burigo' },
]

const naoE = [
  { title: 'Curso gravado que te abandona', desc: 'VSS é mentoria ativa com 48 sessões ao vivo' },
  { title: 'Teoria sem implementação', desc: 'Você sai com sistema funcionando, não só conhecimento' },
  { title: 'Solução genérica para qualquer porte', desc: 'Feito especificamente para MPEs de R$10k-500k/mês' },
  { title: 'Dependente de budget alto de tráfego', desc: 'Funciona COM ou SEM tráfego pago (Rota A ou B)' },
]

const diferenciais = [
  { titulo: 'Validado por Mais de 140 Clientes', desc: 'Framework testado em 17 anos e R$ 1 bilhão estruturado', icon: 'Award' },
  { titulo: 'CRM Profissional Incluído', desc: 'Growth CRM por 12 meses (valor R$ 6.996)', icon: 'Zap' },
  { titulo: 'Comunidade Exclusiva', desc: 'Networking com outros donos implementando o sistema', icon: 'Users' },
  { titulo: 'Mentorias Semanais', desc: '48 sessões ao vivo (60 min) para tirar dúvidas', icon: 'Target' },
]

const faq = [
  {
    pergunta: 'Preciso de budget para tráfego pago?',
    resposta: 'NÃO. O VSS tem 2 rotas: Rota A (tráfego pago) e Rota B (prospecção ativa). Você escolhe a que faz sentido pro seu momento. 60% dos alunos começam com Rota B (sem gastar nada).'
  },
  {
    pergunta: 'Quanto tempo por semana preciso dedicar?',
    resposta: 'Recomendamos 2-3 horas semanais para assistir aulas + implementar. As aulas têm 15-35 minutos cada. Nas primeiras 12 semanas você terá 1 mentoria ao vivo semanal de 60-90 minutos.'
  },
  {
    pergunta: 'Funciona para o meu nicho/segmento?',
    resposta: 'O Framework dos 6Ps funciona para qualquer modelo B2B ou B2B2C (serviços, consultorias, SaaS, franquias, etc). Já validamos em 140+ empresas de 30+ nichos diferentes.'
  },
  {
    pergunta: 'O CRM é obrigatório ou posso usar outro?',
    resposta: 'Você PODE usar seu CRM atual (RD, HubSpot, Pipedrive, etc), mas o Growth CRM já vem configurado com os funis e automações prontos. 90% dos alunos preferem usar o incluído.'
  },
  {
    pergunta: 'Qual a garantia?',
    resposta: '15 dias de garantia incondicional. Se entrar e decidir que não é pra você, devolvemos 100% sem perguntas. Sem pegadinhas, sem pressão, reembolso total e simples.'
  }
]


const modulos = [
  { 
    num: '01', 
    nome: 'O Sistema VSS e os 6Ps', 
    aulas: 6,
    desc: 'Bem-vindo ao VSS, conheça Joel Burigo, entenda o Framework dos 6Ps, faça seu diagnóstico completo, compreenda a Máquina de Vendas e monte seu plano de 90 dias.'
  },
  { 
    num: '02', 
    nome: 'P1 + P2: Posicionamento e Público', 
    aulas: 5,
    desc: 'Defina seu posicionamento único, crie sua PUV, mapeie seu público ideal, construa personas detalhadas e desenvolva sua Big Idea memorável.'
  },
  { 
    num: '03', 
    nome: 'P3: Produto e Precificação', 
    aulas: 4,
    desc: 'Estruture ofertas irresistíveis, empilhe valor, defina precificação estratégica por valor e estabeleça metas e KPIs essenciais.'
  },
  { 
    num: '04', 
    nome: 'Domine o Growth CRM', 
    aulas: 5,
    desc: 'Configure seu Growth CRM do zero, organize contatos e leads, importe sua base atual e crie suas primeiras automações e notificações.'
  },
  { 
    num: '05', 
    nome: 'Presença Digital Profissional', 
    aulas: 4,
    desc: 'Construa sua casa digital, crie site/landing pages no CRM, configure Google Meu Negócio + SEO local e otimize redes sociais como vitrine.'
  },
  { 
    num: '06', 
    nome: 'Tráfego Orgânico', 
    aulas: 4,
    desc: 'Domine marketing de conteúdo, SEO prático, redes sociais orgânicas (Instagram + LinkedIn) e crie seu calendário editorial estruturado.'
  },
  { 
    num: '07', 
    nome: 'Tráfego Pago', 
    aulas: 4,
    desc: 'Fundamentos de tráfego pago, primeira campanha Meta Ads, Google Ads (busca e display) e técnicas de otimização e escala.'
  },
  { 
    num: '08', 
    nome: 'Prospecção Ativa Gratuita', 
    aulas: 5,
    desc: 'Alternativa sem budget: construa listas de prospects, use LinkedIn + Instagram para prospecção, domine cold email e WhatsApp ético, e implemente cadências multicanal.'
  },
  { 
    num: '09', 
    nome: 'Funis de Conversão', 
    aulas: 4,
    desc: 'Anatomia de funis de vendas, landing pages de alta conversão, nutrição de leads por email e integração de WhatsApp ao CRM.'
  },
  { 
    num: '10', 
    nome: 'Fechamento e Pós-Venda', 
    aulas: 5,
    desc: 'Qualificação de leads (BANT/SPIN), scripts de atendimento que convertem, tratamento de objeções, técnicas de fechamento e programa de indicações.'
  },
  { 
    num: '11', 
    nome: 'P4 + P5: Sistema Integrado', 
    aulas: 4,
    desc: 'Checklist de integração completa, processos documentados (SOPs), dashboard executivo unificado e preparação para escalar.'
  },
  { 
    num: '12', 
    nome: 'Automações Avançadas', 
    aulas: 4,
    desc: 'Workflows complexos, segmentação comportamental automática, recuperação de carrinho e upsell, e réguas de relacionamento inteligentes.'
  },
  { 
    num: '13', 
    nome: 'Agentes de IA Conversacional', 
    aulas: 4,
    desc: 'Entenda agentes de IA, configure agente de WhatsApp 24/7, implemente handoff inteligente (IA → Humano) e treine seu agente para otimizar resultados.'
  },
  { 
    num: '14', 
    nome: 'Analytics e Melhoria Contínua', 
    aulas: 4,
    desc: 'Métricas que realmente importam, testes A/B e otimização, análise de coorte e churn, e construção de cultura data-driven.'
  },
  { 
    num: '15', 
    nome: 'P6 + Próximos Passos', 
    aulas: 4,
    desc: 'Pessoas e equipe de alta performance, contratação e treinamento de time, plano de 180-365 dias e integração à comunidade VSS.'
  },
]

const inclusos = [
  { titulo: 'Conteúdo Educacional', itens: ['15 módulos estruturados (playbook + vídeos-âncora)', 'Cada aula vira ação em 15–20 min', 'Acesso vitalício', 'Atualizações incluídas'] },
  { titulo: 'Mentorias e Suporte', itens: ['48 sessões ao vivo', 'Sessões semanais', '60 minutos cada', 'Todas gravadas'] },
  { titulo: 'Growth CRM (12 meses)', itens: ['CRM profissional completo', 'Valor: R$ 6.996/ano inclusos', 'Já configurado', 'Funis + automações prontos'] },
  { titulo: 'Templates e Recursos', itens: ['Canvas dos 6Ps', 'Scripts de vendas', 'Landing pages', 'SOPs e processos'] },
]

const resultados = [
  { metrica: 'Previsibilidade', antes: 'Não sabe quanto vai faturar', depois: 'Metas claras e alcançáveis' },
  { metrica: 'Leads', antes: 'Planilha Excel ou papel', depois: 'CRM configurado + automações' },
  { metrica: 'Processo', antes: 'Improviso em cada venda', depois: 'Playbook comercial documentado' },
  { metrica: 'Equipe', antes: 'Só o dono sabe vender', depois: 'Time capacitado e autônomo' },
]
---

<div class="flex min-h-screen flex-col">
  <main class="grow pt-16 md:pt-20">
    <!-- Hero -->
    <section class="relative overflow-hidden bg-dark py-12 md:py-16 lg:py-20">
      
      <Container class="relative z-10">
        <div class="mx-auto max-w-5xl">
          <div class="flex flex-col gap-12">
            <!-- Top Content -->
            <div class="text-center">
              <span class="mb-6 inline-block rounded-full border border-lime/30 bg-lime/20 px-6 py-2 font-display text-sm font-bold text-lime backdrop-blur-sm">
                PROGRAMA DE IMPLEMENTAÇÃO | 90 DIAS
              </span>
              <h1 class="mb-6 font-display text-display-lg text-white md:text-6xl">
                Vendas Sem Segredos
              </h1>
              <p class="mb-4 font-sans text-h3 font-semibold text-white/90">
                Pare de Improvisar. Comece a Escalar.
              </p>
              <p class="mb-10 font-sans text-body-lg text-blue-100">
                Te ensino os 6Ps em 90 dias. Você implementa no seu negócio com minha mentoria semanal. CRM profissional incluído + 48 mentorias ao vivo. Bora estruturar?
              </p>
            </div>

            <!-- Video Full Width -->
            <div class="w-full">
              <VideoPlayer
                videoUrl="https://www.youtube.com/watch?v=nCf8pnEjB5M"
                title="Veja como funciona o Vendas sem Segredos"
                class="w-full"
              />
            </div>

            <!-- CTA Section -->
            <div class="text-center">
              <div class="flex flex-col gap-4 sm:flex-row justify-center">
                <a href="#investimento">
                  <Button variant="primary" size="lg">
                    Bora Estruturar Minhas Vendas? 🚀
                  </Button>
                </a>
              </div>
              
              <div class="mt-8 flex flex-wrap items-center justify-center gap-6 text-white/90">
                <div class="flex items-center gap-2">
                  <Icons name="check-circle-2" class="h-5 w-5 text-lime" />
                  <span class="font-sans text-sm">15 módulos (playbook + vídeos-âncora)</span>
                </div>
                <div class="flex items-center gap-2">
                  <Icons name="check-circle-2" class="h-5 w-5 text-lime" />
                  <span class="font-sans text-sm">CRM por 12 meses</span>
                </div>
                <div class="flex items-center gap-2">
                  <Icons name="check-circle-2" class="h-5 w-5 text-lime" />
                  <span class="font-sans text-sm">48 mentorias ao vivo</span>
                </div>
              </div>
              
              <p class="mt-6 font-display text-sm font-semibold text-lime text-center">
                ⚡ Preço sobe após os primeiros 100 clientes
              </p>
            </div>
          </div>
        </div>
      </Container>
    </section>

    <!-- Prova Social / Depoimentos -->
    <section class="bg-dark py-24">
      <Container>
        <div class="mx-auto max-w-7xl">
          <div class="mb-16 text-center">
            <h2 class="mb-4 font-display text-display-sm text-white">
              Resultados de Quem <span class="text-lime">Implementou</span>
            </h2>
            <p class="mx-auto max-w-3xl font-sans text-body-lg text-gray-200">
              Empresas reais que saíram de vendas aleatórias para vendas previsíveis
            </p>
          </div>

          <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3">
            {depoimentos.map((depoimento) => (
              <div class="rounded-2xl border-2 border-lime/20 bg-white/5 p-8">
                <div class="mb-4 flex items-center gap-4">
                  <div class="text-4xl">{depoimento.avatar}</div>
                  <div>
                    <div class="mb-1 flex gap-1">
                      <Icons name="star" class="h-4 w-4 fill-lime text-lime" />
                      <Icons name="star" class="h-4 w-4 fill-lime text-lime" />
                      <Icons name="star" class="h-4 w-4 fill-lime text-lime" />
                      <Icons name="star" class="h-4 w-4 fill-lime text-lime" />
                      <Icons name="star" class="h-4 w-4 fill-lime text-lime" />
                    </div>
                    <p class="font-display text-sm font-semibold text-white">{depoimento.nome}</p>
                  </div>
                </div>
                <p class="mb-4 font-display text-lg font-bold text-lime">{depoimento.resultado}</p>
                <p class="font-sans text-body text-gray-200">{depoimento.texto}</p>
              </div>
            ))}
          </div>

          <div class="mt-12 text-center">
            <a href="/cases" class="inline-flex items-center gap-2 font-sans text-body text-lime transition-colors hover:text-lime/80">
              Ver Todos os Cases de Sucesso
              <Icons name="trending-up" class="h-5 w-5" />
            </a>
          </div>
        </div>
      </Container>
    </section>

    <!-- Diferenciais -->
    <section class="bg-dark py-24">
      <Container>
        <div class="mx-auto max-w-7xl">
          <div class="mb-16 text-center">
            <h2 class="mb-4 font-display text-display-sm text-white">
              Por Que o VSS é <span class="text-lime">Diferente</span>
            </h2>
          </div>

          <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
            {diferenciais.map((item) => (
              <div class="rounded-xl border-2 border-white/10 bg-white/5 p-8 transition-all hover:border-lime/50">
                <div class="mb-4 flex items-center gap-4">
                  {item.icon === 'Award' && <Icons name="award" class="h-8 w-8 text-lime" />}
                  {item.icon === 'Zap' && <Icons name="zap" class="h-8 w-8 text-lime" />}
                  {item.icon === 'Users' && <Icons name="users" class="h-8 w-8 text-lime" />}
                  {item.icon === 'Target' && <Icons name="target" class="h-8 w-8 text-lime" />}
                  <h3 class="font-display text-h3 text-white">{item.titulo}</h3>
                </div>
                <p class="font-sans text-body text-gray-200">{item.desc}</p>
              </div>
            ))}
          </div>
        </div>
      </Container>
    </section>

    <!-- O Que É / Não É -->
    <section class="bg-dark py-24">
      <Container>
        <div class="mx-auto max-w-7xl">
          <div class="mb-16 text-center">
            <h2 class="mb-4 font-display text-display-sm text-white">
              O Que É o <span class="text-lime">VSS</span>
            </h2>
            <p class="mx-auto max-w-3xl font-sans text-body-lg text-gray-200">
              Programa de implementação guiada onde você estrutura seu sistema de vendas em 90 dias usando o Framework dos 6Ps
            </p>
          </div>

          <div class="grid grid-cols-1 gap-8 lg:grid-cols-2">
            <!-- O Que É -->
            <div class="rounded-2xl border-2 border-lime/20 bg-lime/10 p-8">
              <div class="mb-6 flex items-center gap-3">
                <div class="rounded-full bg-lime p-3">
                  <Icons name="check-circle-2" class="h-6 w-6 text-dark" />
                </div>
                <h3 class="font-display text-h2 text-white">O Que É</h3>
              </div>
              <ul class="space-y-4">
                {oquee.map((item) => (
                  <li class="flex gap-4">
                    <Icons name="check-circle-2" class="h-6 w-6 shrink-0 text-lime" />
                    <div>
                      <p class="font-display text-lg font-semibold text-white">{item.title}</p>
                      <p class="font-sans text-body text-gray-200">{item.desc}</p>
                    </div>
                  </li>
                ))}
              </ul>
            </div>

            <!-- O Que Não É -->
            <div class="rounded-2xl border-2 border-red-500/20 bg-red-500/10 p-8">
              <div class="mb-6 flex items-center gap-3">
                <div class="rounded-full bg-red-500 p-3">
                  <Icons name="x" class="h-6 w-6 text-white" />
                </div>
                <h3 class="font-display text-h2 text-white">O Que Não É</h3>
              </div>
              <ul class="space-y-4">
                {naoE.map((item) => (
                  <li class="flex gap-4">
                    <Icons name="x" class="h-6 w-6 shrink-0 text-red-400" />
                    <div>
                      <p class="font-display text-lg font-semibold text-white">{item.title}</p>
                      <p class="font-sans text-body text-gray-200">{item.desc}</p>
                    </div>
                  </li>
                ))}
              </ul>
            </div>
          </div>

          <!-- Urgência e Escassez -->
          <div class="mt-12 rounded-2xl border-2 border-lime/30 bg-lime/10 p-8">
            <div class="flex items-start gap-4">
              <Icons name="alert-circle" class="h-8 w-8 shrink-0 text-lime" />
              <div>
                <h3 class="mb-3 font-display text-h3 text-white">⏰ Por Que o Preço Sobe Depois dos 100 Primeiros?</h3>
                <p class="mb-4 font-sans text-body text-gray-200">
                  Os 100 primeiros alunos garantem o preço de lançamento. Após isso, o investimento aumenta para 
                  refletir o valor comprovado do programa e a demanda. É a forma de recompensar quem confia e entra 
                  primeiro. Não é escassez artificial, é precificação estratégica.
                </p>
                <p class="font-sans text-body-sm text-lime">
                  ✅ Lote Fundador | Apenas 100 vagas com preço de lançamento
                </p>
              </div>
            </div>
          </div>
        </div>
      </Container>
    </section>

    <!-- Módulos -->
    <section class="bg-dark py-24">
      <Container>
        <div class="mx-auto max-w-7xl">
          <div class="mb-16 text-center">
            <h2 class="mb-4 font-display text-display-sm text-white">
              15 Módulos <span class="text-lime">Estruturados</span>
            </h2>
            <p class="mx-auto max-w-2xl font-sans text-body-lg text-gray-200">
              Playbook digital navegável + 15 vídeos-âncora (um por módulo). Cada aula vira ação em 15–20 minutos.
            </p>
          </div>

          <div class="grid grid-cols-1 gap-4 md:grid-cols-2 lg:grid-cols-3">
            {modulos.map((modulo) => (
              <div class="rounded-xl border-2 border-white/10 bg-white/5 p-6 transition-all hover:border-lime/50 hover:shadow-lg hover:shadow-lime/10">
                <div class="mb-3 flex items-center justify-between">
                  <span class="font-display text-2xl font-bold text-lime">{modulo.num}</span>
                  <span class="rounded-full bg-white/10 px-3 py-1 font-sans text-xs font-semibold text-gray-200">
                    {modulo.aulas} aulas
                  </span>
                </div>
                <h4 class="mb-3 font-display text-lg font-semibold text-white">
                  {modulo.nome}
                </h4>
                <p class="font-sans text-body-sm text-gray-400">
                  {modulo.desc}
                </p>
              </div>
            ))}
          </div>
          
          <!-- CTA Módulos -->
          <div class="mt-16 text-center">
            <a href="#investimento">
              <Button variant="primary" size="lg">
                Quero Começar Agora
              </Button>
            </a>
            <p class="mt-4 font-sans text-sm text-gray-400">Sistema VSS Implementável + CRM + 48 mentorias por 12x de R$ 166,42</p>
          </div>
        </div>
      </Container>
    </section>

    <!-- Jornada de 90 Dias -->
    <section class="bg-dark py-24">
      <Container>
        <div class="mx-auto max-w-7xl">
          <div class="mb-16 text-center">
            <h2 class="mb-4 font-display text-display-sm text-white">
              A Jornada de <span class="text-lime">90 Dias</span>
            </h2>
            <p class="mx-auto max-w-3xl font-sans text-body-lg text-gray-200">
              Transformação estruturada em 5 fases. Do caos à previsibilidade em 13 semanas.
            </p>
          </div>

          <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
            <div class="rounded-2xl border-2 border-white/10 bg-white/5 p-8">
              <div class="mb-4 inline-block rounded-full bg-lime/20 px-4 py-2">
                <span class="font-display text-sm font-bold text-lime">FASE 1: Semanas 1-2</span>
              </div>
              <h3 class="mb-4 font-display text-h3 text-white">Fundamentos</h3>
              <ul class="space-y-3 font-sans text-body-sm text-gray-200">
                <li class="flex items-start gap-2">
                  <Icons name="check-circle-2" class="h-5 w-5 shrink-0 text-lime" />
                  <span>Diagnóstico completo dos 6Ps</span>
                </li>
                <li class="flex items-start gap-2">
                  <Icons name="check-circle-2" class="h-5 w-5 shrink-0 text-lime" />
                  <span>Posicionamento e ICP definidos</span>
                </li>
                <li class="flex items-start gap-2">
                  <Icons name="check-circle-2" class="h-5 w-5 shrink-0 text-lime" />
                  <span>Oferta estruturada e precificada</span>
                </li>
                <li class="flex items-start gap-2">
                  <Icons name="check-circle-2" class="h-5 w-5 shrink-0 text-lime" />
                  <span>Roadmap de 90 dias criado</span>
                </li>
              </ul>
            </div>

            <div class="rounded-2xl border-2 border-white/10 bg-white/5 p-8">
              <div class="mb-4 inline-block rounded-full bg-lime/20 px-4 py-2">
                <span class="font-display text-sm font-bold text-lime">FASE 2: Semanas 3-4</span>
              </div>
              <h3 class="mb-4 font-display text-h3 text-white">Infraestrutura</h3>
              <ul class="space-y-3 font-sans text-body-sm text-gray-200">
                <li class="flex items-start gap-2">
                  <Icons name="check-circle-2" class="h-5 w-5 shrink-0 text-lime" />
                  <span>CRM configurado e operacional</span>
                </li>
                <li class="flex items-start gap-2">
                  <Icons name="check-circle-2" class="h-5 w-5 shrink-0 text-lime" />
                  <span>Site/landing pages publicados</span>
                </li>
                <li class="flex items-start gap-2">
                  <Icons name="check-circle-2" class="h-5 w-5 shrink-0 text-lime" />
                  <span>Base de contatos importada</span>
                </li>
                <li class="flex items-start gap-2">
                  <Icons name="check-circle-2" class="h-5 w-5 shrink-0 text-lime" />
                  <span>Automações básicas funcionando</span>
                </li>
