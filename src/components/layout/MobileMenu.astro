---
interface NavLink {
  name: string
  path: string
}

interface Props {
  navLinks: NavLink[]
  secondaryLinks?: NavLink[]
}

const { navLinks, secondaryLinks = [] } = Astro.props
---

<div class="mobile-menu-wrapper">
  <!-- Toggle Button -->
  <button
    class="mobile-menu-toggle relative z-50 p-2 md:hidden"
    aria-label="Abrir menu"
    data-menu-button
  >
    <svg class="menu-icon h-6 w-6 text-[color:var(--jb-cream)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
    </svg>
    <svg class="close-icon hidden h-6 w-6 text-[color:var(--jb-fire)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
    </svg>
  </button>

  <!-- Overlay -->
  <div class="mobile-menu fixed inset-0 top-0 z-40 hidden h-screen w-screen bg-[color:var(--jb-ink)] px-6 pt-24 md:hidden overflow-y-auto" data-mobile-menu>
    <div class="grid-overlay"></div>

    <!-- Status bar topo (decorativo) -->
    <div class="relative font-mono text-[10px] uppercase tracking-[0.22em] text-[color:var(--jb-fg-muted)] mb-12 flex justify-between">
      <span><span class="dot-live"></span> SYS ONLINE · @joelburigo</span>
      <span>// MENU</span>
    </div>

    <nav class="relative flex flex-col space-y-2">
      {navLinks.map((link) => (
        <a
          href={link.path}
          class="font-display text-4xl uppercase tracking-tight text-[color:var(--jb-cream)] py-3 border-b border-[color:var(--jb-hair)] transition-colors duration-[var(--jb-dur)] hover:text-[color:var(--jb-acid)]"
          data-menu-link
        >
          {link.name} <span class="text-[color:var(--jb-fg-muted)] text-lg">→</span>
        </a>
      ))}
      {secondaryLinks.length > 0 && (
        <div class="pt-6 space-y-2">
          {secondaryLinks.map((link) => (
            <a
              href={link.path}
              class="block font-mono text-sm uppercase tracking-[0.22em] text-[color:var(--jb-fg-3)] py-2 transition-colors duration-[var(--jb-dur)] hover:text-[color:var(--jb-acid)]"
              data-menu-link
            >
              // {link.name}
            </a>
          ))}
        </div>
      )}

      <div class="pt-10">
        <a href="/diagnostico" class="btn-primary w-full justify-center" data-menu-link>
          DIAGNÓSTICO GRÁTIS · 10 MIN →
        </a>
      </div>

      <!-- Footer mono -->
      <div class="relative pt-16 pb-10 font-mono text-[10px] uppercase tracking-[0.22em] text-[color:var(--jb-fg-muted)] text-center">
        ★ SISTEMA &gt; IMPROVISO · FLORIANÓPOLIS/SC
      </div>
    </nav>
  </div>
</div>

<style>
  .mobile-menu {
    opacity: 0;
    transform: translateY(-8px);
    transition: opacity var(--jb-dur) var(--jb-ease), transform var(--jb-dur) var(--jb-ease);
    pointer-events: none;
  }
  .mobile-menu.active {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
    display: block !important;
  }
  .menu-icon, .close-icon { transition: opacity var(--jb-dur) var(--jb-ease); }
  .mobile-menu-toggle.active .menu-icon { display: none; }
  .mobile-menu-toggle.active .close-icon { display: block; }
</style>

<script>
  let cleanupMobileMenu: (() => void) | null = null

  function initMobileMenu() {
    if (cleanupMobileMenu) cleanupMobileMenu()

    const menuButton = document.querySelector('[data-menu-button]') as HTMLButtonElement
    const mobileMenu = document.querySelector('[data-mobile-menu]') as HTMLDivElement
    const menuLinks = document.querySelectorAll('[data-menu-link]')
    if (!menuButton || !mobileMenu) return

    function toggleMenu(e: Event) {
      e.preventDefault()
      e.stopPropagation()
      const isOpen = mobileMenu.classList.contains('active')
      requestAnimationFrame(() => {
        if (isOpen) {
          mobileMenu.classList.remove('active')
          menuButton.classList.remove('active')
          document.body.style.overflow = ''
        } else {
          mobileMenu.classList.add('active')
          menuButton.classList.add('active')
          document.body.style.overflow = 'hidden'
        }
      })
    }

    function closeMenu() {
      requestAnimationFrame(() => {
        mobileMenu.classList.remove('active')
        menuButton.classList.remove('active')
        document.body.style.overflow = ''
      })
    }

    menuButton.addEventListener('click', toggleMenu)
    menuLinks.forEach((link) => link.addEventListener('click', closeMenu))

    cleanupMobileMenu = () => {
      menuButton.removeEventListener('click', toggleMenu)
      menuLinks.forEach((link) => link.removeEventListener('click', closeMenu))
      document.body.style.overflow = ''
    }
  }

  initMobileMenu()
  document.addEventListener('astro:page-load', initMobileMenu)
</script>
