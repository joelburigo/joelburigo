---
import JsonLd from './JsonLd.astro'

interface BreadcrumbItem {
  label: string
  href: string
}

interface Props {
  items: BreadcrumbItem[]
  class?: string
}

const { items = [], class: className = '' } = Astro.props
const siteUrl = 'https://joelburigo.com.br'

const normalizedItems = items.map((item) => ({
  ...item,
  href: item.href.startsWith('http') ? item.href : new URL(item.href, siteUrl).toString(),
}))

const breadcrumbSchema = {
  '@type': 'BreadcrumbList',
  itemListElement: normalizedItems.map((item, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    name: item.label,
    item: item.href,
  })),
}
---

<nav aria-label="Breadcrumb" class={className}>
  <ol class="flex flex-wrap items-center gap-2 font-mono text-[11px] uppercase tracking-[0.22em] text-[color:var(--jb-fg-muted)]">
    {items.map((item, index) => {
      const isLast = index === items.length - 1
      return (
        <li class="flex items-center gap-2">
          {index > 0 && <span class="text-[color:var(--jb-fg-muted)]">/</span>}
          {isLast ? (
            <span class="text-[color:var(--jb-cream)]">{item.label}</span>
          ) : (
            <a href={item.href} class="transition-colors duration-[var(--jb-dur)] hover:text-[color:var(--jb-acid)]">
              {item.label}
            </a>
          )}
        </li>
      )
    })}
  </ol>
</nav>

<JsonLd type="BreadcrumbList" data={breadcrumbSchema} />
