---
import Layout from '../layouts/Layout.astro'
import Header from '../components/layout/Header.astro'
import Footer from '../components/layout/Footer.astro'
import Container from '../components/ui/Container.astro'

const seo = {
  title: 'Diagnóstico concluído | Joel Burigo',
  description: 'Seu diagnóstico 6Ps foi processado. Resultado chegando no WhatsApp e email.',
}
---

<Layout title={seo.title} description={seo.description} noIndex={true}>
  <Header />

  <main class="relative overflow-hidden bg-ink pt-20">
    <div class="grid-overlay"></div>

    <Container class="relative z-10">
      <section class="py-16 md:py-24">
        <div class="mx-auto max-w-4xl">
          <!-- Kicker -->
          <div class="kicker mb-6">// DIAGNÓSTICO · STATUS: PROCESSADO · RESULTADO_ENVIADO</div>

          <h1 class="tg-display">
            <span class="stroke-text">DIAGNÓSTICO</span>
            <span class="block text-acid">CONCLUÍDO.</span>
          </h1>

          <p class="mt-8 max-w-2xl font-sans text-lg text-[color:var(--jb-cream)]">
            Suas respostas foram processadas. O raio-X dos 6Ps tá indo pro teu WhatsApp e email agora.
          </p>

          <!-- Canais -->
          <div class="mt-10 grid gap-6 md:grid-cols-2">
            <div class="card" style="border-color: var(--jb-acid-border);">
              <div class="kicker mb-3" style="color: var(--jb-acid);">// CANAL · WHATSAPP</div>
              <h3 class="heading-4 mb-2 text-[color:var(--jb-cream)]">Resultado completo</h3>
              <p class="font-sans text-[color:var(--jb-fg-2)]">
                Análise automática dos 6Ps + score por P + diagnóstico estratégico chegando no teu WhatsApp agora.
              </p>
            </div>
            <div class="card">
              <div class="kicker mb-3">// CANAL · EMAIL</div>
              <h3 class="heading-4 mb-2 text-[color:var(--jb-cream)]">Link pro raio-X</h3>
              <p class="font-sans text-[color:var(--jb-fg-2)]">
                Também chega por email um link pra acessar o diagnóstico completo com plano de ação.
              </p>
            </div>
          </div>

          <!-- Timeline -->
          <div class="mt-12 border border-[color:var(--jb-hair)] bg-[color:var(--jb-ink-2)] p-8">
            <div class="kicker mb-6">// O_QUE_ACONTECE_AGORA</div>
            <ol class="space-y-6">
              {[
                { n: '01', title: 'Processamento automático', body: 'Suas respostas rodaram nos 6Ps. Score por P, gargalos, prioridades.' },
                { n: '02', title: 'Entrega em instantes', body: 'WhatsApp + email chegam com radar dos 6Ps, análise detalhada e plano de ação personalizado.' },
                { n: '03', title: 'Próximos passos', body: 'Com base no diagnóstico, eu recomendo o caminho: VSS (DIY) ou Advisory (1:1 comigo).' },
              ].map((step) => (
                <li class="flex items-start gap-5">
                  <div class="shrink-0 font-mono text-sm font-bold text-acid" style="letter-spacing: 0.1em;">{step.n}</div>
                  <div>
                    <h3 class="heading-4 mb-1 text-[color:var(--jb-cream)]">{step.title}</h3>
                    <p class="font-sans text-[color:var(--jb-fg-2)]">{step.body}</p>
                  </div>
                </li>
              ))}
            </ol>
          </div>

          <!-- Enquanto aguarda -->
          <div class="mt-12 border-l-2 border-fire bg-[color:var(--jb-ink-2)] p-8">
            <div class="kicker mb-3" style="color: var(--jb-fire);">// ENQUANTO_AGUARDA</div>
            <h2 class="heading-2 mb-4 text-[color:var(--jb-cream)]">Conhece o framework 6Ps.</h2>
            <p class="mb-6 font-sans text-[color:var(--jb-fg-2)]">
              O diagnóstico que você fez é baseado na mesma base aplicada em 140+ empresas. Veja como funciona o VSS completo.
            </p>
            <a href="/vendas-sem-segredos" class="btn-primary min-h-[48px]" data-astro-prefetch>
              <span>Conhecer VSS</span>
              <span aria-hidden="true">→</span>
            </a>
          </div>

          <!-- Links -->
          <div class="mt-12 grid gap-3 sm:grid-cols-2">
            <a href="/blog" class="card group flex items-center justify-between">
              <div>
                <div class="kicker mb-1">// BLOG</div>
                <div class="font-display text-[color:var(--jb-cream)]">Ler artigos</div>
              </div>
              <span class="text-acid text-xl">→</span>
            </a>
            <a href="/cases" class="card group flex items-center justify-between">
              <div>
                <div class="kicker mb-1">// CASES</div>
                <div class="font-display text-[color:var(--jb-cream)]">Resultados reais</div>
              </div>
              <span class="text-acid text-xl">→</span>
            </a>
          </div>

          <!-- Assinatura -->
          <div class="mt-12 border-t border-[color:var(--jb-hair)] pt-8 font-mono text-[11px] uppercase tracking-[0.28em] text-[color:var(--jb-fg-muted)]">
            <span class="text-acid">★</span>&nbsp;&nbsp;SISTEMA <span class="text-fire">&gt;</span> IMPROVISO · LET'S GROW
          </div>
        </div>
      </section>
    </Container>
  </main>

  <Footer />
</Layout>

<style>
  .tg-display {
    font-family: var(--font-display);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: -0.045em;
    line-height: 0.92;
    font-size: clamp(2.5rem, 8vw, 5rem);
    color: var(--jb-cream);
    margin: 0;
  }
</style>
