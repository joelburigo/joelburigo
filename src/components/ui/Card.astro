---
// @ts-ignore - Astro Props interface
interface Props {
  class?: string
  hoverEffect?: boolean
  onClick?: string
  as?: 'div' | 'article'
  variant?: 'default' | 'feat'
}

const {
  class: className = '',
  hoverEffect = true,
  onClick,
  as = 'div',
  variant = 'default',
} = Astro.props

const Component = onClick ? 'article' : as
const isClickable = !!onClick

// Terminal Growth — brutalist cards.
// default: ink-2 bg + hair border, hover fire offset
// feat:    acid-border + gradient bg (pro destaque, ex: VSS na PathwaysSection)
const baseClasses = 'p-6 sm:p-8 transition-all duration-[var(--jb-dur)]'
const variantClasses: Record<string, string> = {
  default: 'bg-[color:var(--jb-ink-2)] border border-[color:var(--jb-hair)]',
  feat: 'border border-[color:var(--jb-acid-border)]',
}
const featStyle = variant === 'feat'
  ? 'background: linear-gradient(180deg, rgba(198,255,0,0.06), var(--jb-ink-2));'
  : ''
const hoverClasses = hoverEffect
  ? (variant === 'feat'
      ? 'hover:border-[color:var(--jb-acid)] hover:-translate-x-[2px] hover:-translate-y-[2px] hover:shadow-[6px_6px_0_var(--jb-acid)]'
      : 'hover:border-[color:var(--jb-fire)] hover:-translate-x-[2px] hover:-translate-y-[2px] hover:shadow-[6px_6px_0_var(--jb-fire)]')
  : ''
const clickableClasses = isClickable ? 'cursor-pointer' : ''
---

<Component
  class:list={[baseClasses, variantClasses[variant], hoverClasses, clickableClasses, className]}
  style={featStyle}
  role={isClickable ? 'button' : undefined}
  tabindex={isClickable ? 0 : undefined}
>
  <slot />
</Component>
