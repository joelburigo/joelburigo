---
import Container from '../ui/Container.astro'

// VSS — Página de produto (detalhe interno) · /vendas-sem-segredos
// Fonte canônica: 02-oferta.md §02.2 + 03-programa-vss.md + 04-playbook-vss.md
// Provas: ANTI_DRIFT §4. Preço: R$ 1.997 à vista ou 12× R$ 166,42.

const stack = [
  { item: 'Sistema VSS Implementável (playbook + 15 vídeos-âncora · acesso vitalício)', valor: 'R$ 1.997' },
  { item: 'Growth CRM completo (12 meses)', valor: 'R$ 6.996' },
  { item: '48 mentorias ao vivo com Joel (rolling 12 meses)', valor: 'R$ 7.200' },
  { item: 'Templates, scripts e recursos', valor: 'R$ 497' },
  { item: 'Comunidade exclusiva (90 dias)', valor: 'R$ 597' },
]

const pPilares = [
  { p: 'P1', nome: 'Posicionamento', resumo: 'Diferenciação + PUV + Big Idea. Cliente entende em 10s.' },
  { p: 'P2', nome: 'Público', resumo: 'ICP cirúrgico + persona + mapa de dores. Conversão sobe.' },
  { p: 'P3', nome: 'Produto', resumo: 'Oferta irresistível + precificação por valor + prova social.' },
  { p: 'P4', nome: 'Programas', resumo: 'Growth CRM + funis + automação + tráfego ou prospecção.' },
  { p: 'P5', nome: 'Processos', resumo: '5 playbooks essenciais + SOPs + dashboard unificado.' },
  { p: 'P6', nome: 'Pessoas', resumo: 'Estrutura de time por estágio + onboarding 30d + rituais.' },
]

const fases = [
  { n: '01', nome: 'Fundamentos', janela: '0–30D', desc: 'Canvas 6Ps + P1 + P2 + P3 · 15 destravamentos' },
  { n: '02', nome: 'Infraestrutura', janela: '30–45D', desc: 'Growth CRM + landing page · 9 destravamentos' },
  { n: '03', nome: 'Atração', janela: '45–75D', desc: 'Orgânico + pago + prospecção · 13 destravamentos' },
  { n: '04', nome: 'Conversão', janela: '75–90D', desc: 'Funis + scripts + objeções · 9 destravamentos' },
  { n: '05', nome: 'Sistema', janela: '90D · MARCO', desc: 'Integração + processos · 4 destravamentos' },
  { n: '06', nome: 'Automação', janela: 'PÓS-90D', desc: 'Workflows + IA conversacional · 8 destravamentos' },
  { n: '07', nome: 'Crescimento', janela: 'PÓS-90D', desc: 'Analytics + P6 + Plano 180–365d · 8 destravamentos' },
]

const paraQuem = [
  'Empreendedor hands-on que quer autonomia',
  'MPE com faturamento R$ 10–100k/mês',
  'Tem 2–3h/semana pra implementar',
  'Quer o método antes de contratar 1:1',
]

const naoEPara = [
  'Quem quer que alguém faça por você (não é DFY)',
  'Quem busca milagre em 7 dias',
  'Quem não tem 6–9h/semana pras primeiras fases',
  'Quem não aceita feedback direto',
]
---

<!-- HERO TERMINAL -->
<section class="relative overflow-hidden bg-ink pb-24 pt-32 md:pt-40">
  <div class="grid-overlay"></div>

  <Container>
    <!-- Status bar -->
    <div class="mb-10 flex flex-wrap items-center justify-between gap-3">
      <div class="flex items-center gap-3">
        <span class="dot-live"></span>
        <span class="mono text-acid">VSS · VENDAS SEM SEGREDOS · PERPÉTUO · SEMPRE ABERTO</span>
      </div>
      <div class="mono text-fg-muted">@joelburigo · FLORIANÓPOLIS/SC</div>
    </div>

    <div class="grid gap-12 lg:grid-cols-[1.3fr_1fr] lg:gap-16">
      <!-- Copy -->
      <div>
        <div class="kicker mb-5">// PRODUTO PRINCIPAL · DIY · R$ 1.997</div>
        <h1 class="mb-8 font-display text-cream" style="font-size: clamp(2.25rem, 6.5vw, 5rem); line-height: 0.9; letter-spacing: -0.045em; text-transform: uppercase;">
          De vendas <span class="text-fire">aleatórias</span> para vendas <span class="text-acid">previsíveis.</span>
          <br /><span class="stroke-text">Em 90 dias</span>.
        </h1>
        <p class="mb-8 font-sans text-cream/85" style="font-size: clamp(1.05rem, 2vw, 1.25rem); line-height: 1.5;">
          VSS é o sistema implementável que estrutura os <span class="text-acid">6Ps das Vendas Escaláveis</span> no teu negócio. Framework formalizado em 2025 a partir de uma base aplicada em <strong class="text-cream">140+ empresas</strong> e <strong class="text-cream">20+ nichos</strong>. Não há fórmula mágica. Há método. E você vai dominar cada etapa — com ou sem budget de tráfego.
        </p>

        <!-- Preço -->
        <div class="mb-8 border border-acid bg-acid-soft p-6">
          <div class="flex flex-wrap items-baseline gap-x-4 gap-y-2">
            <span class="font-display text-acid" style="font-size: clamp(2.5rem, 5vw, 3.5rem); line-height: 1; letter-spacing: -0.04em;">
              R$ 1.997
            </span>
            <span class="mono text-cream/80">À VISTA · ou 12× R$ 166,42</span>
          </div>
          <p class="mt-3 font-sans text-cream/75" style="font-size: 0.875rem;">
            Acesso vitalício ao playbook · Growth CRM 12 meses · 48 mentorias ao vivo (rolling 12m) · Comunidade · Templates. Stack empilhada: <strong class="text-cream">R$ 17.287</strong>.
          </p>
        </div>

        <div class="flex flex-col gap-3 sm:flex-row sm:items-center">
          <a href="/lp/vss" class="btn-primary">Começar agora →</a>
          <a href="/diagnostico" class="btn-secondary">Diagnóstico 6Ps grátis</a>
        </div>
      </div>

      <!-- Terminal window -->
      <div class="border border-white/10 bg-ink-2" style="box-shadow: var(--shadow-terminal);">
        <div class="flex items-center gap-2 border-b border-white/10 px-4 py-3">
          <span class="inline-block h-3 w-3 bg-fire"></span>
          <span class="inline-block h-3 w-3" style="background: #FFB020;"></span>
          <span class="inline-block h-3 w-3 bg-acid"></span>
          <span class="mono ml-3 text-fg-muted">&gt; vss_diag.run --system=6ps</span>
        </div>
        <div class="p-5" style="font-family: var(--font-mono); font-size: 0.8rem; line-height: 1.7;">
          <div class="text-fg-muted">[00:00]</div>
          <div class="text-cream">&gt; scanning máquina de vendas…</div>
          <div class="text-fire">▼ P1 posicionamento .......... 01/05 fraco</div>
          <div class="text-fire">▼ P2 público ................. 02/05 fraco</div>
          <div class="text-fire">▼ P3 produto ................. 02/05 fraco</div>
          <div class="text-fire">▼ P4 programas ............... 00/05 caótico</div>
          <div class="text-fire">▼ P5 processos ............... 00/05 caótico</div>
          <div class="text-fire">▼ P6 pessoas ................. 01/05 fraco</div>
          <div class="mt-2 text-cream">&gt; score total: <span class="text-fire">06/30</span> · status: <span class="text-fire">caótico</span></div>
          <div class="mt-2 text-fg-muted">[00:04]</div>
          <div class="text-cream">&gt; aplicando método VSS (90d)…</div>
          <div class="mt-2 text-acid">▲ P1 ............. 04/05 forte</div>
          <div class="text-acid">▲ P2 ............. 04/05 forte</div>
          <div class="text-acid">▲ P3 ............. 04/05 forte</div>
          <div class="text-acid">▲ P4 ............. 04/05 forte</div>
          <div class="text-acid">▲ P5 ............. 03/05 estruturado</div>
          <div class="text-acid">▲ P6 ............. 03/05 estruturado</div>
          <div class="mt-2 text-cream">&gt; score total: <span class="text-acid">22/30</span> · status: <span class="text-acid">estruturado</span></div>
          <div class="mt-3 text-acid">★ máquina de crescimento: <span style="background: var(--jb-acid); color: var(--jb-ink); padding: 0 6px;">ONLINE</span></div>
          <div class="text-fg-muted" style="animation: blink 1s infinite;">_</div>
        </div>
      </div>
    </div>
  </Container>
</section>

<!-- 6PS PILARES -->
<section class="relative bg-ink-2 py-24">
  <Container>
    <div class="mx-auto mb-14 max-w-3xl">
      <div class="kicker mb-4">// 01_FRAMEWORK</div>
      <h2 class="mb-6 font-display text-cream" style="font-size: clamp(2rem, 5vw, 3.5rem); line-height: 0.92; letter-spacing: -0.04em; text-transform: uppercase;">
        Os <span class="text-acid">6Ps</span> das Vendas Escaláveis
      </h2>
      <p class="font-sans text-cream/70" style="font-size: 1.125rem; line-height: 1.55;">
        Posicionamento → Público → Produto → Programas → Processos → Pessoas. Sequência importa — fraqueza em um compromete todos os seguintes. Não é teoria de MBA. É método formalizado em 2025 a partir de 17+ anos.
      </p>
    </div>

    <div class="grid gap-0 border border-white/10 sm:grid-cols-2 lg:grid-cols-3">
      {pPilares.map((p, i) => (
        <article class="p-8" style={`border-right: ${(i + 1) % 3 === 0 ? '0' : '1px solid var(--jb-hair)'}; border-bottom: ${i < pPilares.length - 3 ? '1px solid var(--jb-hair)' : '0'};`}>
          <div class="font-display text-acid" style="font-size: 2.5rem; line-height: 1; letter-spacing: -0.045em;">
            {p.p}
          </div>
          <h3 class="mb-3 mt-2 font-display text-cream" style="font-size: 1.1rem; letter-spacing: -0.02em; text-transform: uppercase;">
            {p.nome}
          </h3>
          <p class="font-sans text-cream/75" style="font-size: 0.9rem; line-height: 1.5;">
            {p.resumo}
          </p>
        </article>
      ))}
    </div>
  </Container>
</section>

<!-- 7 FASES · 15 MÓDULOS · 66 DESTRAVAMENTOS -->
<section class="relative overflow-hidden bg-ink py-24">
  <div class="grid-overlay"></div>
  <Container>
    <div class="mx-auto mb-14 max-w-3xl">
      <div class="kicker mb-4">// 02_JORNADA</div>
      <h2 class="mb-6 font-display text-cream" style="font-size: clamp(2rem, 5vw, 3.5rem); line-height: 0.92; letter-spacing: -0.04em; text-transform: uppercase;">
        <span class="text-acid">7 fases</span> · 15 módulos · <span class="stroke-text">66 destravamentos</span>
      </h2>
      <p class="font-sans text-cream/70" style="font-size: 1.125rem; line-height: 1.55;">
        Cada destravamento é ação de 15–20 min com entregável tangível. Fases 1–5 em 90 dias. Fases 6–7 avançadas pós-fundação. Vitalício: entra qualquer dia, começa essa semana.
      </p>
    </div>

    <div class="mx-auto max-w-5xl border border-white/10">
      {fases.map((f, i) => (
        <div class="grid gap-0 md:grid-cols-[120px_140px_1fr]" style={`border-top: ${i === 0 ? '0' : '1px solid var(--jb-hair)'};`}>
          <div class="flex items-center border-white/10 p-5 md:border-r" style="background: rgba(198,255,0,0.04);">
            <span class="font-display text-acid" style="font-size: 2.25rem; line-height: 1; letter-spacing: -0.04em;">{f.n}</span>
          </div>
          <div class="flex items-center border-white/10 p-5 md:border-r">
            <div>
              <div class="font-display text-cream" style="font-size: 1rem; text-transform: uppercase; letter-spacing: -0.02em;">{f.nome}</div>
              <div class="mono mt-1 text-fg-muted">{f.janela}</div>
            </div>
          </div>
          <div class="flex items-center p-5">
            <p class="font-sans text-cream/85" style="font-size: 0.95rem; line-height: 1.5;">{f.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </Container>
</section>

<!-- STACK / VALOR -->
<section class="relative bg-ink-2 py-24">
  <Container>
    <div class="mx-auto max-w-4xl">
      <div class="mb-12">
        <div class="kicker mb-4">// 03_STACK · O QUE VOCÊ LEVA</div>
        <h2 class="font-display text-cream" style="font-size: clamp(1.75rem, 4vw, 2.75rem); line-height: 0.95; letter-spacing: -0.035em; text-transform: uppercase;">
          Stack empilhada: <span class="stroke-text">R$ 17.287</span>. Investimento: <span class="text-acid">R$ 1.997</span>.
        </h2>
      </div>

      <div class="border border-white/10">
        {stack.map((s, i) => (
          <div class="grid grid-cols-[1fr_auto] gap-4 p-5 md:p-6" style={`border-top: ${i === 0 ? '0' : '1px solid var(--jb-hair)'};`}>
            <div class="font-sans text-cream" style="font-size: 0.95rem; line-height: 1.4;">
              <span class="mono mr-2 text-acid">▶</span>
              {s.item}
            </div>
            <div class="font-display text-acid" style="font-size: 1rem; white-space: nowrap; letter-spacing: -0.01em;">
              {s.valor}
            </div>
          </div>
        ))}
        <div class="grid grid-cols-[1fr_auto] gap-4 p-5 md:p-6" style="border-top: 1px solid var(--jb-hair); background: rgba(198,255,0,0.06);">
          <div class="font-display text-cream" style="font-size: 1rem; text-transform: uppercase; letter-spacing: -0.02em;">
            Total empilhado
          </div>
          <div class="font-display text-cream" style="font-size: 1.25rem; letter-spacing: -0.02em;">
            R$ 17.287
          </div>
        </div>
        <div class="grid grid-cols-[1fr_auto] gap-4 p-5 md:p-6" style="border-top: 2px solid var(--jb-acid); background: rgba(198,255,0,0.12);">
          <div class="font-display text-cream" style="font-size: 1.25rem; text-transform: uppercase; letter-spacing: -0.02em;">
            Investimento VSS
          </div>
          <div class="font-display text-acid" style="font-size: 1.75rem; letter-spacing: -0.03em;">
            R$ 1.997
          </div>
        </div>
      </div>
      <p class="mt-4 font-sans text-cream/70" style="font-size: 0.9rem;">
        ★ À vista ou 12× de R$ 166,42 · acesso vitalício ao playbook · Growth CRM 12 meses
      </p>
    </div>
  </Container>
</section>

<!-- É × NÃO É -->
<section class="relative overflow-hidden bg-ink py-24">
  <div class="grid-overlay"></div>
  <Container>
    <div class="mx-auto max-w-5xl">
      <div class="mb-12">
        <div class="kicker mb-4">// 04_FIT</div>
        <h2 class="font-display text-cream" style="font-size: clamp(1.75rem, 4vw, 2.75rem); line-height: 0.95; letter-spacing: -0.035em; text-transform: uppercase;">
          VSS <span class="text-acid">é pra você</span>. VSS <span class="text-fire">não é pra você</span>.
        </h2>
      </div>

      <div class="grid gap-0 border border-white/10 md:grid-cols-2">
        <div class="border-b border-white/10 p-8 md:border-b-0 md:border-r" style="background: linear-gradient(180deg, rgba(198,255,0,0.04), transparent);">
          <div class="mono mb-5 text-acid">▲ é pra você se</div>
          <ul class="space-y-4">
            {paraQuem.map((item) => (
              <li class="flex items-start gap-3 font-sans text-cream" style="font-size: 1rem; line-height: 1.45;">
                <span class="text-acid">✓</span>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>
        <div class="p-8" style="background: linear-gradient(180deg, rgba(255,59,15,0.04), transparent);">
          <div class="mono mb-5 text-fire">▼ NÃO é pra você se</div>
          <ul class="space-y-4">
            {naoEPara.map((item) => (
              <li class="flex items-start gap-3 font-sans text-cream/80" style="font-size: 1rem; line-height: 1.45;">
                <span class="text-fire">✗</span>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </Container>
</section>

<!-- GARANTIA + PROVAS -->
<section class="relative bg-ink-2 py-20">
  <Container>
    <div class="mx-auto grid max-w-5xl gap-8 lg:grid-cols-2">
      <div class="border-l-4 border-acid bg-ink p-8 md:p-10">
        <div class="kicker mb-4">// GARANTIA 15 DIAS</div>
        <p class="mb-4 font-display text-cream" style="font-size: clamp(1.35rem, 3vw, 1.75rem); line-height: 1.05; letter-spacing: -0.035em; text-transform: uppercase;">
          15 dias <span class="text-acid">incondicional</span>. Reembolso 100%.
        </p>
        <p class="font-sans text-cream/80" style="font-size: 0.95rem; line-height: 1.55;">
          Testou, não se adaptou — devolvemos tudo. Sem perguntas, sem fricção. Confiança total porque a base do método já foi aplicada em 140+ empresas.
        </p>
      </div>
      <div class="border-l-4 border-fire bg-ink p-8 md:p-10">
        <div class="kicker mb-4" style="color: var(--jb-fire);">// PROVAS</div>
        <div class="grid grid-cols-3 gap-3 border-b border-white/10 pb-4">
          <div><div class="font-display text-acid" style="font-size: 1.75rem; line-height: 1;">17+</div><div class="mono mt-1 text-fg-muted" style="font-size: 0.6rem;">anos</div></div>
          <div><div class="font-display text-acid" style="font-size: 1.75rem; line-height: 1;">140+</div><div class="mono mt-1 text-fg-muted" style="font-size: 0.6rem;">clientes</div></div>
          <div><div class="font-display text-acid" style="font-size: 1.25rem; line-height: 1;">~R$ 1BI</div><div class="mono mt-1 text-fg-muted" style="font-size: 0.6rem;">estruturado</div></div>
        </div>
        <p class="mt-4 font-sans text-cream/80" style="font-size: 0.9rem; line-height: 1.5;">
          <strong class="text-cream">Case ESF:</strong> R$ 160k/mês → R$ 1M/mês (+433%), leads ×8,33.
        </p>
      </div>
    </div>
  </Container>
</section>

<!-- CTA FINAL -->
<section class="relative overflow-hidden bg-ink py-24">
  <div class="grid-overlay"></div>
  <Container>
    <div class="mx-auto max-w-4xl border-2 border-acid p-10 md:p-16" style="background: linear-gradient(180deg, rgba(198,255,0,0.08), #050505);">
      <div class="kicker mb-5">// DECISÃO</div>
      <h2 class="mb-6 font-display text-cream" style="font-size: clamp(1.75rem, 4.5vw, 3rem); line-height: 0.95; letter-spacing: -0.04em; text-transform: uppercase;">
        Daqui <span class="text-acid">90 dias</span> você estará <span class="text-acid">90 dias mais perto</span> do sistema.
        <br />Ou 90 dias mais <span class="text-fire">distante</span>. Escolhe.
      </h2>
      <p class="mb-8 font-sans text-cream/85" style="font-size: 1.125rem; line-height: 1.55;">
        R$ 1.997 à vista ou 12× R$ 166,42. Perpétuo — entra hoje, primeira mentoria na próxima data do calendário. Bora pra cima.
      </p>
      <div class="flex flex-col gap-4 sm:flex-row sm:items-center">
        <a href="/lp/vss" class="btn-primary">Entrar no VSS agora →</a>
        <a href="/diagnostico" class="btn-secondary">Diagnóstico 6Ps grátis</a>
      </div>
      <p class="mt-8 mono text-fg-muted">
        ★ SISTEMA &gt; IMPROVISO · SEMPRE ABERTO · @joelburigo
      </p>
    </div>
  </Container>
</section>
