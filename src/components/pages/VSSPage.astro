<!-- Modal Checkout -->
<div id="checkoutModal" class="checkout-modal">
  <div class="checkout-modal-content">
    <button id="closeCheckoutModal" class="checkout-modal-close" aria-label="Fechar">×</button>
    
    <!-- Header -->
    <div class="checkout-modal-header">
      <h3>
        🚀 Últimas <span class="highlight">100 Vagas</span> com Preço Especial
      </h3>
    </div>

    <!-- Iframe -->
    <div class="checkout-iframe-container">
      <HighLevelForm 
        formId="UY5sq22SQZfoIym1Udp1"
        height="490px"
      />
    </div>

    <!-- Footer -->
    <div class="checkout-modal-footer">
      <p>🔒 Pagamento 100% seguro | Acesso imediato após confirmação</p>
      <img 
        src={hotmartSecurity.src} 
        alt="Formas de pagamento aceitas" 
        loading="lazy"
      />
    </div>
  </div>
