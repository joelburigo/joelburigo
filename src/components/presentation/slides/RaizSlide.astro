---
// Slide 2 · RAIZ — Os 7 inimigos que Joel combate (fonte: 01-marca.md §01.9)
import SlideShell from '../SlideShell.astro'

const inimigos = [
  { n: '01', t: 'O Improviso que Mata', d: '"Dá um jeito" como método. Sem processo documentado.' },
  { n: '02', t: 'Agências Amadoras', d: 'Cobram R$ 3-5k/mês pra postar no Instagram, não estruturam conversão.' },
  { n: '03', t: 'Consultores Engomados', d: 'Cobram R$ 50-100k, entregam PowerPoint de 200 slides e somem.' },
  { n: '04', t: 'Gurus de Promessa Vazia', d: '"Fique milionário em 6 meses", "fórmula secreta", "aperte um botão".' },
  { n: '05', t: 'CRMs Complexos e Caros', d: 'R$ 500-2k/mês, exigem analista dedicado, travam mais que ajudam.' },
  { n: '06', t: 'Marketing de Vaidade', d: 'Foca em likes e alcance. Ignora ROI, conversão e faturamento.' },
  { n: '07', t: 'Dependência de Budget Alto', d: '"Só funciona com R$ 20k/mês em anúncio". Exclui quem começa.' },
]
---

<SlideShell
  variant="default"
  sbLeft="RAIZ · OS 7 INIMIGOS"
  sbRight="// ▲ DIAGNÓSTICO"
  navLeft="★ CICATRIZES QUE VIRARAM METODOLOGIA"
  navRight="03 / 19 · → PRÓXIMO"
>
  <div class="raiz-grid">
    <div class="raiz-head">
      <div class="raiz-kicker">// O QUE JOEL COMBATE</div>
      <h1 class="raiz-h1">
        <span class="stroke-text">7 INIMIGOS</span><br />
        <span class="acid">DA MPE</span>
      </h1>
      <p class="raiz-sub">
        Estes são os padrões que quebram micro e pequena empresa.
        Não é falta de talento. Não é mercado ruim. É isso.
      </p>
    </div>

    <div class="raiz-list">
      {inimigos.map((i) => (
        <div class="raiz-item">
          <div class="raiz-n">{i.n}</div>
          <div class="raiz-body">
            <div class="raiz-t">{i.t}</div>
            <div class="raiz-d">{i.d}</div>
          </div>
        </div>
      ))}
    </div>
  </div>
</SlideShell>

<style>
  .raiz-grid {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 60px;
    height: 100%;
    align-items: center;
  }
  .raiz-kicker {
    font-family: var(--font-mono);
    font-size: clamp(12px, 1vw, 16px);
    letter-spacing: 0.32em;
    color: var(--jb-fire);
    text-transform: uppercase;
    margin-bottom: 20px;
  }
  .raiz-h1 {
    font-family: var(--font-display);
    font-size: clamp(48px, 7vw, 130px);
    line-height: 0.9;
    letter-spacing: -0.045em;
    text-transform: uppercase;
    color: var(--jb-cream);
    margin: 0;
  }
  .raiz-h1 .acid { color: var(--jb-acid); }
  .raiz-sub {
    margin-top: 28px;
    font-size: clamp(14px, 1.2vw, 20px);
    line-height: 1.5;
    color: var(--jb-fg-3);
    max-width: 520px;
  }

  .raiz-list {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }
  .raiz-item {
    background: var(--jb-ink-2);
    border: 1px solid var(--jb-hair);
    padding: 18px 20px;
    display: flex;
    gap: 18px;
    align-items: flex-start;
  }
  .raiz-n {
    font-family: var(--font-display);
    font-size: clamp(28px, 2.8vw, 44px);
    color: var(--jb-fire);
    line-height: 0.9;
    letter-spacing: -0.04em;
    flex-shrink: 0;
  }
  .raiz-t {
    font-family: var(--font-display);
    font-size: clamp(13px, 1.1vw, 18px);
    text-transform: uppercase;
    color: var(--jb-cream);
    letter-spacing: -0.01em;
    line-height: 1.15;
  }
  .raiz-d {
    margin-top: 6px;
    font-size: clamp(11px, 0.85vw, 14px);
    color: var(--jb-fg-3);
    line-height: 1.4;
  }

  @media (max-width: 1024px) {
    .raiz-grid { grid-template-columns: 1fr; gap: 32px; align-content: start; }
    .raiz-list { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 640px) {
    .raiz-list { grid-template-columns: 1fr; }
  }
</style>
