---
import Container from '../ui/Container.astro'
import { Image } from 'astro:assets'
import joelBurigoImage from '../../assets/images/joel-burigo-vendas-sem-segredos-2-800w.webp'
---

<section class="quem-sou section bg-ink relative overflow-hidden">
  <div class="grid-overlay"></div>

  <Container class="relative z-10">
    <!-- Section head -->
    <div class="section-head">
      <div class="kicker">// 00_QUEM-SOU</div>
      <div class="mono section-head-meta">ORIGEM · PALHOÇA/SC · 1987 →</div>
    </div>
    <div class="hair-divider"></div>

    <div class="qs-grid">
      <!-- Foto -->
      <div class="qs-photo-wrap">
        <div class="qs-photo">
          <Image
            src={joelBurigoImage}
            alt="Joel Burigo"
            widths={[480, 800]}
            sizes="(max-width: 768px) 100vw, 40vw"
            loading="lazy"
            class="qs-img"
          />
          <div class="qs-photo-overlay"></div>
        </div>
        <div class="qs-photo-caption mono">
          ● JOEL BURIGO · <span class="text-acid">RIBEIRÃO DA ILHA / SC</span>
        </div>
      </div>

      <!-- Conteúdo -->
      <div class="qs-content">
        <h2 class="qs-title">
          <span class="stroke-text">EXECUTOR</span> QUE QUEBROU,<br />
          RECONSTRUIU E <span class="text-fire">SISTEMATIZOU</span>.
        </h2>

        <p class="qs-lede">
          Sou Joel Burigo. Nasci em 1987, Palhoça/SC, filho de marceneiro e vendedora de loja. Quebrei minha primeira empresa aos 25, em 2012 — calote de sócio. Seis meses num barraco em Ribeirão das Neves/MG, R$ 1.400/mês nos Correios pra colocar encomenda na esteira.
        </p>

        <p class="qs-body">
          Reconstruí batendo porta em 100+ empresas. <strong class="text-cream">17 anos depois</strong>: 140+ clientes atendidos pessoalmente. ~R$ 1 bilhão em vendas estruturadas. Framework 6Ps nascido do erro real, testado em todas.
        </p>

        <p class="qs-body">
          Não sou guru motivacional. Não sou consultor de terno que some depois do PowerPoint. Sou <strong class="text-cream">mentor-executor</strong>: ensino o método e implemento junto. É o que funciona pra MPE brasileira.
        </p>

        <!-- Meta bar -->
        <div class="qs-meta">
          <div class="qs-meta-item">
            <div class="qs-meta-label mono">Origem</div>
            <div class="qs-meta-val">Palhoça/SC · 1987</div>
          </div>
          <div class="qs-meta-item">
            <div class="qs-meta-label mono">Quebra</div>
            <div class="qs-meta-val">Mar/2012 · 25 anos</div>
          </div>
          <div class="qs-meta-item">
            <div class="qs-meta-label mono">Base hoje</div>
            <div class="qs-meta-val">Ribeirão da Ilha / SC</div>
          </div>
          <div class="qs-meta-item">
            <div class="qs-meta-label mono">Foco</div>
            <div class="qs-meta-val">Vendas Escaláveis pra MPE</div>
          </div>
        </div>

        <a href="/sobre" class="btn-secondary qs-cta">
          <span>História completa</span>
          <span aria-hidden="true">→</span>
        </a>
      </div>
    </div>
  </Container>
</section>

<style>
  .section-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    margin-bottom: 1rem;
    flex-wrap: wrap;
  }
  .section-head-meta {
    font-size: 11px;
    color: var(--jb-fg-muted);
  }

  .qs-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: start;
    padding-top: clamp(2rem, 4vw, 3rem);
  }
  @media (min-width: 1024px) {
    .qs-grid { grid-template-columns: 0.9fr 1.1fr; }
  }

  .qs-photo-wrap { display: flex; flex-direction: column; gap: 0.75rem; }

  .qs-photo {
    position: relative;
    aspect-ratio: 4 / 5;
    border: 1px solid var(--jb-hair);
    overflow: hidden;
    background: var(--jb-ink-2);
  }
  :global(.qs-img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(100%) contrast(1.15) brightness(0.92);
    transition: filter var(--transition-slow);
  }
  .qs-photo:hover :global(.qs-img) {
    filter: grayscale(100%) contrast(1.25) brightness(1);
  }
  .qs-photo-overlay {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: linear-gradient(180deg, transparent 60%, rgba(5,5,5,0.5));
  }
  .qs-photo-caption {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--jb-fg-muted);
  }

  .qs-content { display: flex; flex-direction: column; gap: 1.5rem; }

  .qs-title {
    font-family: var(--font-display);
    text-transform: uppercase;
    font-weight: 900;
    letter-spacing: -0.04em;
    line-height: 0.95;
    font-size: clamp(2rem, 5vw, 3.5rem);
    color: var(--jb-cream);
    margin: 0;
  }

  .qs-lede, .qs-body {
    font-family: var(--font-sans);
    font-size: clamp(1rem, 1.4vw, 1.0625rem);
    line-height: 1.6;
    color: var(--jb-cream);
    text-transform: none;
    margin: 0;
  }
  .qs-lede strong, .qs-body strong { font-weight: 700; }

  .qs-meta {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background: var(--jb-hair);
    border: 1px solid var(--jb-hair);
    margin: 0.5rem 0;
  }
  .qs-meta-item {
    background: var(--jb-ink);
    padding: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .qs-meta-label {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--jb-fg-muted);
  }
  .qs-meta-val {
    font-family: var(--font-sans);
    font-size: 14px;
    color: var(--jb-cream);
    font-weight: 500;
  }

  .qs-cta { align-self: flex-start; margin-top: 0.5rem; }
</style>
