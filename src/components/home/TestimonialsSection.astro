---
import Container from '../ui/Container.astro'
import { Image } from 'astro:assets'
import { testimonials } from '../../data/testimonials'

// NOTA: copy dos testemunhos herdada de src/data/testimonials.ts.
// Se for revisar, confrontar com ANTI_DRIFT §4 (provas de autoridade).
---

<section class="testi-section section bg-ink relative overflow-hidden">
  <div class="grid-overlay"></div>

  <Container class="relative z-10">
    <!-- Section head -->
    <div class="section-head">
      <div class="kicker">// 06_DEPOIMENTOS</div>
      <div class="mono section-head-meta">VOZES DE QUEM IMPLEMENTOU</div>
    </div>
    <div class="hair-divider"></div>

    <!-- Intro -->
    <div class="testi-intro">
      <h2 class="testi-title">
        O QUE <span class="text-acid">FUNCIONA</span><br />
        NA <span class="stroke-text">OPERAÇÃO</span>.
      </h2>
      <p class="testi-lede">
        Resultado real de quem pegou o método e executou. Sem retoque, sem roteiro.
      </p>
    </div>

    <!-- Grid brutalist -->
    <div class="testi-grid">
      {testimonials.map((t) => (
        <article class="testi-card">
          <div class="testi-quote-mark" aria-hidden="true">"</div>

          <div class="testi-stars" aria-label={`${t.rating} de 5`}>
            {Array.from({ length: t.rating }).map(() => (
              <span class="testi-star" aria-hidden="true">★</span>
            ))}
          </div>

          <div class="testi-highlight mono">{t.highlight}</div>

          <blockquote class="testi-quote">
            {t.quote}
          </blockquote>

          <footer class="testi-foot">
            <div class="testi-avatar">
              <Image
                src={t.image}
                alt={t.author}
                widths={[56, 112]}
                sizes="56px"
                quality={80}
                class="testi-avatar-img"
              />
            </div>
            <div class="testi-author">
              <div class="testi-author-name">{t.author}</div>
              <div class="testi-author-role mono">{t.role}</div>
            </div>
          </footer>
        </article>
      ))}
    </div>

    <div class="testi-footer">
      <a href="/cases" class="btn-secondary">
        <span>Mais cases</span>
        <span aria-hidden="true">→</span>
      </a>
    </div>
  </Container>
</section>

<style>
  .section-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    margin-bottom: 1rem;
    flex-wrap: wrap;
  }
  .section-head-meta { font-size: 11px; color: var(--jb-fg-muted); }

  .testi-intro {
    padding-top: clamp(2rem, 4vw, 3rem);
    padding-bottom: clamp(2rem, 4vw, 3rem);
    max-width: 960px;
  }
  .testi-title {
    font-family: var(--font-display);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: -0.04em;
    line-height: 0.92;
    font-size: clamp(2rem, 5.5vw, 3.75rem);
    color: var(--jb-cream);
    margin: 0 0 1.25rem 0;
  }
  .testi-lede {
    font-family: var(--font-sans);
    font-size: clamp(1rem, 1.5vw, 1.125rem);
    line-height: 1.6;
    color: var(--jb-cream);
    text-transform: none;
    margin: 0;
    max-width: 52ch;
  }

  .testi-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1px;
    background: var(--jb-hair);
    border: 1px solid var(--jb-hair);
    margin-bottom: clamp(2rem, 4vw, 3rem);
  }
  @media (min-width: 768px) { .testi-grid { grid-template-columns: repeat(3, 1fr); } }

  .testi-card {
    background: var(--jb-ink-2);
    padding: 2rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    position: relative;
    transition: background var(--transition-base);
    min-height: 360px;
  }
  .testi-card:hover { background: var(--jb-ink-3); }

  .testi-quote-mark {
    position: absolute;
    top: 0.75rem;
    right: 1rem;
    font-family: var(--font-display);
    font-size: 5rem;
    line-height: 1;
    color: var(--jb-fire);
    opacity: 0.5;
    pointer-events: none;
  }

  .testi-stars { display: inline-flex; gap: 2px; }
  .testi-star { color: var(--jb-acid); font-size: 1rem; }

  .testi-highlight {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--jb-acid);
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }

  .testi-quote {
    font-family: var(--font-sans);
    font-size: 1rem;
    line-height: 1.55;
    color: var(--jb-cream);
    text-transform: none;
    font-style: italic;
    margin: 0;
    flex: 1;
  }

  .testi-foot {
    display: flex;
    align-items: center;
    gap: 0.875rem;
    padding-top: 1rem;
    border-top: 1px solid var(--jb-hair);
  }
  .testi-avatar {
    width: 44px;
    height: 44px;
    overflow: hidden;
    border: 1px solid var(--jb-acid-border);
    flex-shrink: 0;
  }
  :global(.testi-avatar-img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(100%) contrast(1.1);
  }
  .testi-author-name {
    font-family: var(--font-display);
    font-weight: 900;
    text-transform: uppercase;
    font-size: 0.875rem;
    letter-spacing: -0.01em;
    color: var(--jb-cream);
  }
  .testi-author-role {
    font-size: 10px;
    color: var(--jb-fg-muted);
    letter-spacing: 0.2em;
  }

  .testi-footer {
    display: flex;
    justify-content: center;
  }
</style>
