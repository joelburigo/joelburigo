---
// Slide 5 · 6Ps OPERAÇÃO & ESCALA (P4-P6): Programas, Processos, Pessoas
import SlideShell from '../SlideShell.astro'

const ps = [
  {
    n: 'P4',
    t: 'PROGRAMAS',
    q: 'COMO VENDER?',
    d: 'CRM + funis + automação. Vender sem sistema é roleta-russa. Programas = previsibilidade.',
  },
  {
    n: 'P5',
    t: 'PROCESSOS',
    q: 'COMO OPERAR?',
    d: 'SOPs, rituais e cadências documentadas. Sem processo você não cresce, só repete caos em escala maior.',
  },
  {
    n: 'P6',
    t: 'PESSOAS',
    q: 'QUEM EXECUTA?',
    d: 'Time, papéis, incentivos. Se tua empresa depende de ti, tu não tem empresa — tu tem emprego.',
  },
]
---

<SlideShell
  variant="default"
  sbLeft="6PS · OPERAÇÃO & ESCALA (P4-P6)"
  sbRight="// MÓDULO 02 / 02"
  navLeft="← P1-P3 · FUNDAÇÃO"
  navRight="06 / 19 · → CREDIBILIDADE"
>
  <div class="fund-wrap">
    <div class="fund-head">
      <div class="fund-kicker">// OPERAÇÃO · EXECUÇÃO &amp; ESCALA</div>
      <h2 class="fund-h2">
        <span class="stroke-text">OPERAÇÃO</span> · P4-P6
      </h2>
      <p class="fund-sub">
        Com fundação clara, vem o sistema que multiplica.<br />
        <b>Operação = o que separa "funcionou uma vez" de "funciona sempre".</b>
      </p>
    </div>

    <div class="fund-grid">
      {ps.map((p) => (
        <div class="fund-card">
          <div class="fund-n">{p.n}</div>
          <div class="fund-t">// {p.t}</div>
          <div class="fund-q">{p.q}</div>
          <div class="fund-d">{p.d}</div>
        </div>
      ))}
    </div>
  </div>
</SlideShell>

<style>
  .fund-wrap {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 40px;
    height: 100%;
  }
  .fund-kicker {
    font-family: var(--font-mono);
    font-size: clamp(12px, 1vw, 16px);
    letter-spacing: 0.32em;
    color: var(--jb-fire);
    text-transform: uppercase;
    margin-bottom: 14px;
  }
  .fund-h2 {
    font-family: var(--font-display);
    font-size: clamp(42px, 6vw, 100px);
    line-height: 0.92;
    letter-spacing: -0.04em;
    text-transform: uppercase;
    color: var(--jb-cream);
    margin: 0;
  }
  .fund-sub {
    margin-top: 18px;
    font-size: clamp(13px, 1.2vw, 20px);
    line-height: 1.5;
    color: var(--jb-fg-3);
    max-width: 900px;
  }
  .fund-sub b { color: var(--jb-cream); }

  .fund-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }
  .fund-card {
    background: var(--jb-ink-2);
    border: 1px solid var(--jb-hair);
    padding: 32px 28px;
    position: relative;
    overflow: hidden;
  }
  .fund-card::before {
    content: '';
    position: absolute;
    inset: 0 0 auto 0;
    height: 3px;
    background: var(--jb-fire);
  }
  .fund-n {
    font-family: var(--font-display);
    font-size: clamp(60px, 7vw, 140px);
    line-height: 0.85;
    letter-spacing: -0.05em;
    color: var(--jb-fire);
    text-shadow: 0 0 50px rgba(255, 59, 15, 0.2);
  }
  .fund-t {
    margin-top: 12px;
    font-family: var(--font-mono);
    font-size: clamp(11px, 0.9vw, 14px);
    letter-spacing: 0.28em;
    color: var(--jb-acid);
    text-transform: uppercase;
  }
  .fund-q {
    margin-top: 12px;
    font-family: var(--font-display);
    font-size: clamp(22px, 2.4vw, 42px);
    line-height: 0.95;
    letter-spacing: -0.03em;
    text-transform: uppercase;
    color: var(--jb-cream);
  }
  .fund-d {
    margin-top: 16px;
    font-size: clamp(12px, 1vw, 16px);
    line-height: 1.5;
    color: var(--jb-fg-3);
  }

  @media (max-width: 1024px) {
    .fund-grid { grid-template-columns: 1fr; }
  }
</style>
