---
import Layout from '../layouts/Layout.astro'
import Header from '../components/layout/Header.astro'
import Footer from '../components/layout/Footer.astro'
import Container from '../components/ui/Container.astro'

// Design system canônico vive em docs/conteudo/brand/
// Esta página é apenas um wayfinder pra referências externas.
const seo = {
  title: 'Design System | Joel Burigo',
  description: 'Design system canônico do Joel Burigo — Terminal Growth v3.',
  noIndex: true,
}

const references = [
  {
    label: '// BRAND · README',
    title: 'Foundations + voice',
    path: 'docs/conteudo/brand/README.md',
    href: 'https://github.com/joelburigo/joelburigo-site/blob/main/docs/conteudo/brand/README.md',
    external: true,
  },
  {
    label: '// BRAND · ANTI_DRIFT',
    title: 'Regras duras (palavras, provas, assinaturas)',
    path: 'docs/conteudo/brand/ANTI_DRIFT.md',
    href: 'https://github.com/joelburigo/joelburigo-site/blob/main/docs/conteudo/brand/ANTI_DRIFT.md',
    external: true,
  },
  {
    label: '// BRAND · MASTER.HTML',
    title: 'Referência visual canônica',
    path: 'docs/conteudo/brand/master.html',
    href: 'https://github.com/joelburigo/joelburigo-site/blob/main/docs/conteudo/brand/master.html',
    external: true,
  },
  {
    label: '// STYLES · GLOBAL.CSS',
    title: 'Tokens Terminal Growth em produção',
    path: 'src/styles/global.css',
    href: 'https://github.com/joelburigo/joelburigo-site/blob/main/src/styles/global.css',
    external: true,
  },
]
---

<Layout title={seo.title} description={seo.description} noIndex={seo.noIndex}>
  <Header />

  <main class="relative overflow-hidden bg-ink pt-20">
    <div class="grid-overlay"></div>

    <Container class="relative z-10">
      <section class="py-16 md:py-24">
        <div class="mx-auto max-w-4xl">
          <div class="kicker mb-6">// JB_CORE v3.0 · TERMINAL GROWTH · REV. 2026.04</div>
          <h1 class="ds-display">
            Design <span class="text-acid">System.</span>
          </h1>
          <p class="mt-6 max-w-2xl font-sans text-lg text-[color:var(--jb-cream)]">
            O design system canônico vive em <code class="font-mono text-acid">docs/conteudo/brand/</code>.
            Esta página é apenas o wayfinder pras referências.
          </p>

          <!-- Paleta resumo -->
          <div class="mt-12">
            <div class="kicker mb-4">// PALETA · BICOLOR_DE_ACENTO</div>
            <div class="grid gap-px border border-[color:var(--jb-hair)] bg-[color:var(--jb-hair)] md:grid-cols-5">
              <div class="bg-[#050505] p-6 text-[color:var(--jb-cream)]">
                <div class="font-mono text-[10px] uppercase tracking-[0.2em] text-[color:var(--jb-fg-muted)]">INK</div>
                <div class="font-display text-lg mt-2">#050505</div>
              </div>
              <div class="bg-[#0B0B0B] p-6 text-[color:var(--jb-cream)]">
                <div class="font-mono text-[10px] uppercase tracking-[0.2em] text-[color:var(--jb-fg-muted)]">INK-2</div>
                <div class="font-display text-lg mt-2">#0B0B0B</div>
              </div>
              <div class="bg-[#F5F1E8] p-6 text-[#050505]">
                <div class="font-mono text-[10px] uppercase tracking-[0.2em]">CREAM</div>
                <div class="font-display text-lg mt-2">#F5F1E8</div>
              </div>
              <div class="bg-[#FF3B0F] p-6 text-[#050505]">
                <div class="font-mono text-[10px] uppercase tracking-[0.2em]">FIRE</div>
                <div class="font-display text-lg mt-2">#FF3B0F</div>
              </div>
              <div class="bg-[#C6FF00] p-6 text-[#050505]">
                <div class="font-mono text-[10px] uppercase tracking-[0.2em]">ACID</div>
                <div class="font-display text-lg mt-2">#C6FF00</div>
              </div>
            </div>
          </div>

          <!-- Tipografia resumo -->
          <div class="mt-12">
            <div class="kicker mb-4">// TIPOGRAFIA · 3_FAMÍLIAS</div>
            <div class="space-y-4 border border-[color:var(--jb-hair)] bg-[color:var(--jb-ink-2)] p-6">
              <div>
                <div class="kicker mb-2">// DISPLAY · ARCHIVO_BLACK</div>
                <div class="font-display text-4xl text-[color:var(--jb-cream)]">ABC 123 áéí</div>
              </div>
              <div class="border-t border-[color:var(--jb-hair)] pt-4">
                <div class="kicker mb-2">// BODY · ARCHIVO_400-900</div>
                <div class="font-sans text-lg text-[color:var(--jb-cream)]">The quick brown fox jumps over the lazy dog.</div>
              </div>
              <div class="border-t border-[color:var(--jb-hair)] pt-4">
                <div class="kicker mb-2">// MONO · JETBRAINS_MONO</div>
                <div class="font-mono text-base text-[color:var(--jb-acid)]">$ ./executar_diagnostico --6ps</div>
              </div>
            </div>
          </div>

          <!-- Referências -->
          <div class="mt-12">
            <div class="kicker mb-4">// REFERÊNCIAS · CANÔNICAS</div>
            <div class="space-y-3">
              {references.map((ref) => (
                <a
                  href={ref.href}
                  target={ref.external ? '_blank' : undefined}
                  rel={ref.external ? 'noopener noreferrer' : undefined}
                  class="group block border border-[color:var(--jb-hair)] bg-[color:var(--jb-ink-2)] p-5 transition-all duration-[var(--jb-dur)] hover:border-[color:var(--jb-acid)] hover:-translate-x-[2px] hover:-translate-y-[2px] hover:shadow-[6px_6px_0_var(--jb-acid)]"
                >
                  <div class="flex items-center justify-between gap-4">
                    <div>
                      <div class="kicker mb-1">{ref.label}</div>
                      <div class="font-display text-[color:var(--jb-cream)]">{ref.title}</div>
                      <code class="mt-1 block font-mono text-[11px] text-[color:var(--jb-fg-muted)]">{ref.path}</code>
                    </div>
                    <span class="font-mono text-xl text-acid transition-transform group-hover:translate-x-1">→</span>
                  </div>
                </a>
              ))}
            </div>
          </div>

          <!-- Nota -->
          <div class="mt-12 border-l-2 border-fire bg-[color:var(--jb-ink-2)] p-6">
            <div class="kicker mb-2" style="color: var(--jb-fire);">// NOTA</div>
            <p class="font-sans text-[color:var(--jb-cream)]">
              Design system canônico vive em <code class="font-mono text-acid">docs/conteudo/brand/</code>. Preview navegável em <code class="font-mono text-acid">docs/conteudo/brand/preview/index.html</code>.
              Em produção, tokens <code class="font-mono text-acid">--jb-*</code> ficam em <code class="font-mono text-acid">src/styles/global.css</code>.
            </p>
          </div>

          <!-- Assinatura -->
          <div class="mt-12 border-t border-[color:var(--jb-hair)] pt-8 font-mono text-[11px] uppercase tracking-[0.28em] text-[color:var(--jb-fg-muted)]">
            <span class="text-acid">★</span>&nbsp;&nbsp;SISTEMA <span class="text-fire">&gt;</span> IMPROVISO · JB_CORE v3.0
          </div>
        </div>
      </section>
    </Container>
  </main>

  <Footer />
</Layout>

<style>
  .ds-display {
    font-family: var(--font-display);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: -0.045em;
    line-height: 0.92;
    font-size: clamp(2.5rem, 8vw, 5rem);
    color: var(--jb-cream);
    margin: 0;
  }
</style>
