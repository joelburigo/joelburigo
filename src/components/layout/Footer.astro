---
import Container from '../ui/Container.astro'
import Logo from '../ui/Logo.astro'
import { contactInfo } from '../../data/contact'

const currentYear = new Date().getFullYear()
---

<footer class="relative border-t border-[color:var(--jb-hair)] bg-[color:var(--jb-ink)] text-[color:var(--jb-cream)]">
  <div class="grid-overlay" aria-hidden="true"></div>

  <Container>
    {/* Kicker + meta */}
    <div class="relative flex items-center justify-between border-b border-[color:var(--jb-hair)] py-4 font-mono text-[11px] uppercase tracking-[0.22em] text-[color:var(--jb-fg-muted)]">
      <div class="flex items-center gap-3">
        <span class="dot-live"></span>
        <span class="text-[color:var(--jb-acid)]">// SYS_FOOTER</span>
        <span class="text-[color:var(--jb-hair-strong)] hidden sm:inline">·</span>
        <span class="hidden sm:inline">@joelburigo</span>
      </div>
      <span class="hidden md:inline">EXP. 2004 · GROWTH EST. 2008</span>
    </div>

    {/* Grid 4 colunas */}
    <div class="relative grid grid-cols-1 gap-12 py-20 md:grid-cols-2 md:gap-x-10 md:gap-y-14 lg:grid-cols-4 lg:gap-x-10">
      {/* Col 1 — Marca */}
      <div class="lg:pr-6">
        <a href="/" class="inline-block" aria-label="Joel Burigo · Home">
          <Logo />
        </a>
        <p class="mt-6 font-display text-xl uppercase leading-[0.95] tracking-[-0.03em] text-[color:var(--jb-cream)]">
          Sistema <span class="text-[color:var(--jb-fire)]">&gt;</span> Improviso
        </p>
        <p class="mt-5 max-w-[34ch] font-sans text-[13px] leading-[1.65] text-[color:var(--jb-fg-3)]">
          Framework 6Ps das Vendas Escaláveis. 140+ MPEs · 17+ anos · ~R$ 1 bilhão em vendas estruturadas (estimativa agregada).
        </p>
        <p class="mt-6 font-mono text-[11px] uppercase tracking-[0.22em] text-[color:var(--jb-fg-muted)]">
          ★ Ribeirão da Ilha · Florianópolis/SC
        </p>
      </div>

      {/* Col 2 — Produtos */}
      <div>
        <h3 class="mb-8 font-mono text-[11px] uppercase tracking-[0.22em] text-[color:var(--jb-acid)]">
          // Produtos
        </h3>
        <ul class="space-y-5 font-mono text-[13px] uppercase tracking-[0.22em]">
          <li>
            <a
              href="/vendas-sem-segredos"
              class="jb-foot-link group inline-flex flex-col gap-1 text-[color:var(--jb-cream)] transition-colors duration-[var(--jb-dur)] hover:text-[color:var(--jb-acid)]"
            >
              <span>VSS</span>
              <span class="font-mono text-[10px] normal-case tracking-[0.18em] text-[color:var(--jb-fg-muted)]">vendas sem segredos</span>
            </a>
          </li>
          <li>
            <a
              href="/advisory"
              data-astro-prefetch
              class="jb-foot-link group inline-flex flex-col gap-1 text-[color:var(--jb-cream)] transition-colors duration-[var(--jb-dur)] hover:text-[color:var(--jb-acid)]"
            >
              <span>Advisory</span>
              <span class="font-mono text-[10px] normal-case tracking-[0.18em] text-[color:var(--jb-fg-muted)]">1:1 com Joel</span>
            </a>
          </li>
          <li class="pt-3">
            <a
              href="/diagnostico"
              class="jb-foot-link inline-flex items-center gap-2 text-[color:var(--jb-fire)] transition-colors duration-[var(--jb-dur)] hover:text-[color:var(--jb-acid)]"
            >
              <span>Diagnóstico</span>
              <span class="font-mono">→</span>
            </a>
          </li>
        </ul>
      </div>

      {/* Col 3 — Recursos */}
      <div>
        <h3 class="mb-8 font-mono text-[11px] uppercase tracking-[0.22em] text-[color:var(--jb-acid)]">
          // Recursos
        </h3>
        <ul class="space-y-4 font-mono text-[13px] uppercase tracking-[0.22em]">
          <li>
            <a href="/blog" class="jb-foot-link text-[color:var(--jb-cream)] transition-colors duration-[var(--jb-dur)] hover:text-[color:var(--jb-acid)]">Blog</a>
          </li>
          <li>
            <a href="/cases" class="jb-foot-link text-[color:var(--jb-cream)] transition-colors duration-[var(--jb-dur)] hover:text-[color:var(--jb-acid)]">Cases</a>
          </li>
          <li>
            <a href="/sobre" class="jb-foot-link text-[color:var(--jb-cream)] transition-colors duration-[var(--jb-dur)] hover:text-[color:var(--jb-acid)]">Sobre</a>
          </li>
          <li>
            <a href="/contato" class="jb-foot-link text-[color:var(--jb-cream)] transition-colors duration-[var(--jb-dur)] hover:text-[color:var(--jb-acid)]">Contato</a>
          </li>
        </ul>
      </div>

      {/* Col 4 — Social + Email */}
      <div>
        <h3 class="mb-8 font-mono text-[11px] uppercase tracking-[0.22em] text-[color:var(--jb-acid)]">
          // Conexão
        </h3>
        <ul class="space-y-4 font-mono text-[13px] uppercase tracking-[0.22em]">
          <li>
            <a
              href={contactInfo.social.instagram.url}
              target="_blank"
              rel="noopener noreferrer"
              class="jb-foot-link inline-flex items-center gap-2 text-[color:var(--jb-cream)] transition-colors duration-[var(--jb-dur)] hover:text-[color:var(--jb-acid)]"
            >
              <span>Instagram</span>
              <span class="font-mono text-[color:var(--jb-fg-muted)]">→</span>
            </a>
          </li>
          <li>
            <a
              href={contactInfo.social.linkedin.url}
              target="_blank"
              rel="noopener noreferrer"
              class="jb-foot-link inline-flex items-center gap-2 text-[color:var(--jb-cream)] transition-colors duration-[var(--jb-dur)] hover:text-[color:var(--jb-acid)]"
            >
              <span>LinkedIn</span>
              <span class="font-mono text-[color:var(--jb-fg-muted)]">→</span>
            </a>
          </li>
          <li>
            <a
              href={contactInfo.social.youtube.url}
              target="_blank"
              rel="noopener noreferrer"
              class="jb-foot-link inline-flex items-center gap-2 text-[color:var(--jb-cream)] transition-colors duration-[var(--jb-dur)] hover:text-[color:var(--jb-acid)]"
            >
              <span>YouTube</span>
              <span class="font-mono text-[color:var(--jb-fg-muted)]">→</span>
            </a>
          </li>
          <li class="pt-5">
            <a
              href={contactInfo.email.mailto}
              class="jb-foot-link inline-block text-[color:var(--jb-fg-3)] normal-case tracking-normal transition-colors duration-[var(--jb-dur)] hover:text-[color:var(--jb-acid)]"
            >
              {contactInfo.email.main}
            </a>
          </li>
        </ul>
      </div>
    </div>

    {/* Aviso legal colapsável */}
    <div class="relative border-t border-[color:var(--jb-hair)] py-8">
      <details class="group mx-auto max-w-4xl">
        <summary class="flex cursor-pointer list-none items-center justify-center gap-2 font-mono text-[11px] uppercase tracking-[0.22em] text-[color:var(--jb-fg-muted)] transition-colors duration-[var(--jb-dur)] hover:text-[color:var(--jb-acid)]">
          <span>// Aviso legal e isenção de responsabilidade</span>
          <span class="text-[color:var(--jb-acid)] transition-transform duration-[var(--jb-dur)] group-open:rotate-180">▼</span>
        </summary>
        <div class="mt-8 space-y-6 font-sans text-[12px] leading-[1.65] text-[color:var(--jb-fg-muted)]">
          <div>
            <p class="mb-2 font-mono text-[11px] uppercase tracking-[0.22em] text-[color:var(--jb-fg-3)]">Resultados e desempenho</p>
            <p>As informações, estratégias e metodologias apresentadas neste site são baseadas na experiência de Joel Burigo e sua equipe ao longo de 17+ anos com empresas B2B e B2C. Todo o conteúdo é fornecido exclusivamente para fins educacionais.</p>
          </div>
          <div>
            <p class="mb-2 font-mono text-[11px] uppercase tracking-[0.22em] text-[color:var(--jb-fg-3)]">Sem garantia de resultados</p>
            <p>Os cases e resultados apresentados não constituem garantia de que você alcançará os mesmos resultados. Cada negócio é único e o desempenho depende de dedicação, contexto de mercado, recursos e execução. Resultados passados não garantem resultados futuros.</p>
          </div>
          <div>
            <p class="mb-2 font-mono text-[11px] uppercase tracking-[0.22em] text-[color:var(--jb-fg-3)]">Esforço requerido</p>
            <p>O sucesso requer trabalho consistente, disciplina e correta implementação. Sistema &gt; Improviso — não existe fórmula mágica.</p>
          </div>
          <div>
            <p class="mb-2 font-mono text-[11px] uppercase tracking-[0.22em] text-[color:var(--jb-fg-3)]">Responsabilidade</p>
            <p>Ao utilizar este site e os serviços oferecidos, você é o único responsável pelos resultados. Growth Master LTDA e Joel Burigo não se responsabilizam por perdas ou prejuízos decorrentes da aplicação das informações fornecidas.</p>
          </div>
        </div>
      </details>
    </div>

    {/* Linha final — coordenadas + legal + assinatura */}
    <div class="relative border-t border-[color:var(--jb-hair)] py-6">
      <div class="flex flex-col gap-3 font-mono text-[10px] uppercase tracking-[0.22em] text-[color:var(--jb-fg-muted)] md:flex-row md:items-center md:justify-between">
        <div class="flex flex-wrap items-center gap-x-3 gap-y-1">
          <span>FLORIANÓPOLIS/SC</span>
          <span class="text-[color:var(--jb-hair-strong)]">·</span>
          <span class="text-[color:var(--jb-acid)]">-27.59</span>
          <span class="text-[color:var(--jb-hair-strong)]">·</span>
          <span class="text-[color:var(--jb-acid)]">-48.55</span>
        </div>

        <div class="flex flex-wrap items-center gap-x-3 gap-y-1">
          <span>© {currentYear} Growth Master LTDA</span>
          <span class="text-[color:var(--jb-hair-strong)]">·</span>
          <span>CNPJ {contactInfo.company.cnpj}</span>
        </div>

        <div class="flex flex-wrap items-center gap-x-4 gap-y-1">
          <a href="/privacidade" class="transition-colors duration-[var(--jb-dur)] hover:text-[color:var(--jb-acid)]">Privacidade</a>
          <a href="/termos" class="transition-colors duration-[var(--jb-dur)] hover:text-[color:var(--jb-acid)]">Termos</a>
        </div>
      </div>

      <div class="mt-6 text-center font-mono text-[10px] uppercase tracking-[0.28em] text-[color:var(--jb-fg-muted)]">
        <span class="text-[color:var(--jb-acid)]">★</span>
        <span>SISTEMA</span>
        <span class="text-[color:var(--jb-fire)]">&gt;</span>
        <span>IMPROVISO</span>
        <span class="text-[color:var(--jb-hair-strong)]">·</span>
        <span>@joelburigo</span>
        <span class="text-[color:var(--jb-hair-strong)]">·</span>
        <span>EXP. 2004 · GROWTH EST. 2008</span>
      </div>
    </div>
  </Container>
</footer>

<style>
  /* Underline acid nos links mono do footer */
  .jb-foot-link {
    position: relative;
  }
  .jb-foot-link::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: -2px;
    width: 0;
    height: 1px;
    background: var(--jb-acid);
    transition: width var(--jb-dur) var(--jb-ease);
  }
  .jb-foot-link:hover::after,
  .jb-foot-link:focus-visible::after {
    width: 100%;
  }
</style>
