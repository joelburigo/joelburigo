---
// Slide 1 · PROBLEMA — Stat gigante fire (60% MPEs fecham em 5 anos)
import SlideShell from '../SlideShell.astro'
---

<SlideShell
  variant="fire"
  sbLeft="DADO · SEBRAE 2024"
  sbRight="// ▲ MERCADO"
  navLeft="★ FONTE: SEBRAE · ANUÁRIO 2024"
  navRight="02 / 19 · → PRÓXIMO"
  navAcid={false}
>
  <div class="prob-wrap">
    <div class="prob-mega">60%</div>
    <div class="prob-sub">
      Das MPEs fecham em até 5 anos.<br />
      A maioria não quebra por falta de mercado — quebra por falta de sistema.
    </div>
    <p class="prob-assin">
      ★ IMPROVISO MATA MAIS EMPRESA QUE CRISE
    </p>
  </div>
</SlideShell>

<style>
  .prob-wrap {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    height: 100%;
    text-align: center;
    color: var(--jb-ink);
  }
  .prob-mega {
    font-family: var(--font-display);
    font-size: clamp(160px, 28vw, 500px);
    line-height: 0.85;
    letter-spacing: -0.07em;
    color: var(--jb-ink);
  }
  .prob-sub {
    font-family: var(--font-display);
    font-size: clamp(20px, 3vw, 50px);
    line-height: 1.1;
    letter-spacing: -0.02em;
    text-transform: uppercase;
    color: var(--jb-ink);
    max-width: 1400px;
    margin-top: 16px;
  }
  .prob-assin {
    margin-top: 32px;
    font-family: var(--font-mono);
    font-size: clamp(12px, 1.2vw, 18px);
    letter-spacing: 0.28em;
    color: var(--jb-ink);
    font-weight: 700;
  }
</style>
